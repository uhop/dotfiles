#!/usr/bin/env bash
# playbash-clean — cleanup stack: chezmoi update, claude-config refresh,
# then cln -y. Same playbash conventions as playbash-daily/-weekly
# (sourced helpers, structured events via $PLAYBASH_REPORT).

set -euCo pipefail
shopt -s expand_aliases

source "${PLAYBASH_LIBS:-$HOME/.local/libs}/playbash.sh"

playbash_step "chezmoi"
playbash_info "running chezmoi update"
chezmoi update

playbash_step "claude-config"
playbash_info "refreshing ~/.claude/ from claude-config"
claude-config-update

playbash_step "system"
playbash_info "running cln -y"
cln -y
