#!/usr/bin/env bash
#
# bootstrap-dotfiles — thin wrapper over install.sh for remote or self-bootstrap.
#
# Remote mode (default):   ssh to <host>, pipe install.sh over, run it unattended.
# Self-bootstrap:          run install.sh locally, then jot-deploy <prefix>.
#
# The heavy lifting — OS-specific prerequisite install, Homebrew, chezmoi init
# --apply — lives in install.sh at the repo root. This wrapper owns the
# surrounding flow: SSH reachability check, install.sh invocation, and the
# optional --from-jot tail that pulls secrets via jot-deploy after apply.

set -euCo pipefail
shopt -s expand_aliases

. ~/.local/libs/bootstrap.sh

script_name=$(basename "$0")

deps::need ssh curl

args::program "$script_name" "2.0.0" "Thin wrapper over install.sh for remote or self-bootstrap"

args_program_header="${BOLD}bootstrap-dotfiles${RESET_BOLD} provisions a fresh machine by running
${BOLD}install.sh${RESET_BOLD} — either remotely via SSH or locally with --from-jot.

Default: SSH to ${BOLD}<host>${RESET_BOLD}, pipe install.sh over, run it unattended. install.sh
is fetched from the GitHub raw URL; override the repo or branch if needed.

With ${BOLD}--from-jot <prefix>${RESET_BOLD}: run install.sh locally (self-bootstrap), then
invoke ${BOLD}jot-deploy${RESET_BOLD} to pull secrets + system files from S3."

args_program_usage="${BOLD}bootstrap-dotfiles${RESET_BOLD} <host> [--branch <br>]
       ${BOLD}bootstrap-dotfiles${RESET_BOLD} --from-jot <prefix> [--branch <br>]"

args::option "--github-user" "GitHub user owning the dotfiles repo (default: \$GITHUB_USERNAME or uhop)" "name"
args::option "--branch" "Branch of the dotfiles repo to fetch install.sh from (default: main)" "branch"
args::option "--from-jot" "Self-bootstrap locally; run jot-deploy <prefix> after chezmoi apply" "prefix"
args::option "-v, --version" "Show version"
args::option "-h, --help" "Show help"
args::option "--bash-completion" "Show bash completion"

args::parse "$@"
set -- "${args_cleaned[@]}"

DIM="$FG_WHITE"

GITHUB_USER="${GITHUB_USERNAME:-uhop}"
[[ -v args_options["--github-user"] ]] && GITHUB_USER="${args_options["--github-user"]}"

BRANCH="main"
[[ -v args_options["--branch"] ]] && BRANCH="${args_options["--branch"]}"

FROM_JOT=""
[[ -v args_options["--from-jot"] ]] && FROM_JOT="${args_options["--from-jot"]}"

HOST="${1:-}"

INSTALL_URL="https://raw.githubusercontent.com/${GITHUB_USER}/dotfiles/${BRANCH}/install.sh"
REPO_ARG="${GITHUB_USER}/dotfiles"

# ---------------------------------------------------------------------------
# Remote mode
# ---------------------------------------------------------------------------

if [[ -z "$FROM_JOT" ]]; then
  if [[ -z "$HOST" ]]; then
    ansi::warn "${ERROR}No host specified${RESET_ALL}"
    args::try_help
    exit 1
  fi

  ansi::out "${INFO}Checking SSH access to $HOST...${RESET_ALL}"
  if ! ssh -o BatchMode=yes -o ConnectTimeout=5 "$HOST" true 2>/dev/null; then
    ansi::warn "${ERROR}Cannot reach $HOST via passwordless SSH.${RESET_ALL}"
    ansi::err "Run ${BOLD}bootstrap-remote $HOST${RESET_ALL} first to set up SSH access."
    exit 1
  fi
  ansi::out "${OK}SSH access OK${RESET_ALL}"

  ansi::out "${INFO}Running install.sh on $HOST (unattended)...${RESET_ALL}"
  ansi::out "${DIM}  URL:    $INSTALL_URL${RESET_ALL}"
  ansi::out "${DIM}  Takes:  ~5-15 min depending on network${RESET_ALL}"
  ansi::out "${DIM}  Needs:  passwordless sudo on $HOST${RESET_ALL}"
  echo

  # --yes is mandatory over SSH because the target has no TTY for prompts.
  # -t on ssh allocates a pseudo-tty so the user sees live output.
  echoRun ssh -t "$HOST" \
    "curl -fsSL '$INSTALL_URL' | sh -s -- --yes --repo '$REPO_ARG' --branch '$BRANCH'"

  echo
  ansi::out "${OK}Bootstrap complete on $HOST${RESET_ALL}"
  ansi::out "${DIM}Open a new shell to use it:${RESET_ALL}"
  ansi::out "  ${BOLD}ssht $HOST${RESET_ALL}"
  exit 0
fi

# ---------------------------------------------------------------------------
# Self-bootstrap mode (--from-jot)
# ---------------------------------------------------------------------------

if [[ -n "$HOST" ]]; then
  ansi::warn "${WARN}--from-jot ignores the <host> argument (always operates locally).${RESET_ALL}"
fi

# Chicken-and-egg pre-flight: jot-deploy needs AWS credentials and an age
# decryption key on local disk before it can pull anything. Those must have
# arrived out-of-band (USB, scp from another machine, password manager).
missing=()
[[ ! -f "$HOME/.env" ]] && missing+=("~/.env (AWS credentials)")
have_decryption_key=false
[[ -f "$HOME/.ssh/age.key" ]] && have_decryption_key=true
for _b in id_ed25519 id_rsa id_ecdsa; do
  [[ -f "$HOME/.ssh/$_b" ]] && have_decryption_key=true && break
done
$have_decryption_key || missing+=("~/.ssh/age.key or ~/.ssh/{id_ed25519,id_rsa,id_ecdsa} (decryption key)")

if (( ${#missing[@]} > 0 )); then
  ansi::warn "${ERROR}--from-jot pre-flight failed. Missing files:${RESET_ALL}"
  for m in "${missing[@]}"; do
    ansi::warn "  - $m"
  done
  ansi::warn ""
  ansi::warn "These secrets must arrive out-of-band (USB, password manager, scp from another machine)"
  ansi::warn "before --from-jot can pull anything from S3. See:"
  ansi::warn "  ${BOLD}https://github.com/$GITHUB_USER/dotfiles/wiki/Jot#bootstrap-sequence${RESET_ALL}"
  exit 1
fi

# Download and run install.sh locally (unattended).
INSTALL_SH="/tmp/install-dotfiles.sh"
ansi::out "${INFO}Downloading install.sh...${RESET_ALL}"
ansi::out "${DIM}  $INSTALL_URL${RESET_ALL}"
echoRun curl -fsSL -o "$INSTALL_SH" "$INSTALL_URL"
command chmod +x "$INSTALL_SH"

ansi::out "${INFO}Running install.sh (unattended, ~5-15 min)...${RESET_ALL}"
echo
echoRun "$INSTALL_SH" --yes --repo "$REPO_ARG" --branch "$BRANCH"

# After install.sh completes, chezmoi has deployed ~/.local/bin (jot, jot-deploy)
# and brew has installed aws. Neither is in our running shell's PATH — add
# the known locations so the jot-deploy call below resolves.
for d in "$HOME/.local/bin" /opt/homebrew/bin /usr/local/bin /home/linuxbrew/.linuxbrew/bin; do
  [[ -d "$d" ]] && PATH="$d:$PATH"
done
export PATH

echo
ansi::out "${INFO}Deploying system files from jot bundle: ${BOLD}$FROM_JOT${RESET_ALL}"

if ! command -v jot-deploy >/dev/null 2>&1; then
  ansi::warn "${WARN}jot-deploy not found on PATH after install.sh.${RESET_ALL}"
  ansi::warn "Open a new shell and run manually:"
  ansi::warn "  ${BOLD}jot-deploy $FROM_JOT --apply${RESET_ALL}"
  exit 0
fi

ansi::out "${DIM}Report (dry-run) first:${RESET_ALL}"
echo
echoRun jot-deploy "$FROM_JOT"
echo

ansi::prompt "Apply these changes? [Y/n] "
read -r response
case "${response^^}" in
  N|NO|NOPE)
    ansi::out "Skipped. Re-run manually when ready: ${BOLD}jot-deploy $FROM_JOT --apply${RESET_ALL}"
    ;;
  *)
    echoRun jot-deploy "$FROM_JOT" --apply
    ;;
esac

echo
ansi::out "${OK}Self-bootstrap complete. A reboot is recommended.${RESET_ALL}"
