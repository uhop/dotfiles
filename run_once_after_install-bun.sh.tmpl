#!/usr/bin/env bash
# run_once_after_install-bun.sh.tmpl — install bun via the upstream installer.

{{ template "install-prelude.sh" . }}

if command -v bun &> /dev/null; then
  exit 0
fi

echo "${PROMPT}Installing bun...${RESET}"
bash_profile_backup=""
if [ -f ~/.bash_profile ]; then
  bash_profile_backup=$(mktemp)
  cp ~/.bash_profile "$bash_profile_backup"
fi
curl -fsSL https://bun.sh/install | bash
if [ -n "$bash_profile_backup" ]; then
  cp "$bash_profile_backup" ~/.bash_profile
  rm -f "$bash_profile_backup"
fi
