#!/usr/bin/env node
// playbash — run bash playbooks on remote hosts.
//
// Milestone 4: subcommands (run/debug/list/hosts) and inventory lookup.

import {spawn} from 'node:child_process';
import {randomBytes} from 'node:crypto';
import {lookup as dnsLookup} from 'node:dns/promises';
import {readdirSync, readFileSync, mkdirSync, createWriteStream, existsSync, unlinkSync} from 'node:fs';
import {tmpdir, homedir, networkInterfaces} from 'node:os';
import {join} from 'node:path';
import {parseArgs} from 'node:util';

const USAGE = `usage:
  playbash run   <playbook> <host> [-n LINES] [--self]
  playbash debug <playbook> <host> [--self]
  playbash list
  playbash hosts
  playbash log   [path]

Options for run:
  -n, --lines N    height of the live output rectangle (default 5)
                   pass 0 to disable the rectangle and stream output raw
  --self           allow running on the local host (default: refuse)

<host> is looked up in ~/.config/playbash/inventory.json. If not found,
the literal string is passed to ssh, so any ~/.ssh/config alias still works.
<playbook> resolves to ~/.local/bin/playbash-<playbook> on the target host.

\`debug\` is equivalent to \`run\` with the rectangle disabled and info
events surfaced in the summary — for when you want to see everything.

Self detection is by IP: if the target's resolved address is bound to a
local interface, the run is refused unless --self is passed. With --self,
the playbook runs locally as a child process (no ssh) using the same
sidecar/summary pipeline.

\`playbash log\` prints a per-run log file with terminal-hostile escape
sequences stripped — safe to view in any terminal. With no path, picks
the most recent log under ~/.cache/playbash/runs/.`;

const INVENTORY_PATH = join(homedir(), '.config', 'playbash', 'inventory.json');
const PLAYBOOK_DIR = join(homedir(), '.local', 'bin');
const PLAYBOOK_PREFIX = 'playbash-';

function die(msg, code = 2) {
  process.stderr.write(`playbash: ${msg}\n`);
  process.exit(code);
}

// --- Inventory ---

function loadInventory() {
  const empty = {hosts: new Map(), groups: new Map(), path: INVENTORY_PATH, present: false};
  if (!existsSync(INVENTORY_PATH)) return empty;
  let raw;
  try {
    raw = JSON.parse(readFileSync(INVENTORY_PATH, 'utf8'));
  } catch (err) {
    die(`inventory at ${INVENTORY_PATH} is not valid JSON: ${err.message}`);
  }
  if (!raw || typeof raw !== 'object' || Array.isArray(raw)) {
    die(`inventory at ${INVENTORY_PATH} must be a JSON object`);
  }
  const hosts = new Map();
  const groups = new Map();
  for (const [name, value] of Object.entries(raw)) {
    if (typeof value === 'string') {
      hosts.set(name, {address: value});
    } else if (Array.isArray(value)) {
      // Group entry — loaded for `playbash hosts` but not yet resolvable.
      groups.set(name, value);
    } else if (value && typeof value === 'object') {
      if (typeof value.address !== 'string') {
        die(`inventory entry "${name}" has no string "address"`);
      }
      hosts.set(name, value);
    } else {
      die(`inventory entry "${name}" has unsupported type`);
    }
  }
  return {hosts, groups, path: INVENTORY_PATH, present: true};
}

// Resolve a host argument to an ssh-target string.
// If the name matches a host entry, return its address. If it matches a
// group entry, refuse (groups are deferred). Otherwise pass the name
// through verbatim so ~/.ssh/config aliases still work.
function resolveHost(name, inventory) {
  if (inventory.groups.has(name)) {
    die(`"${name}" is a group; running on multiple hosts is not yet supported`);
  }
  const entry = inventory.hosts.get(name);
  return entry ? entry.address : name;
}

// --- Self detection ---

// Set of IPs bound to any local interface, plus the loopback ranges.
// Computed once on demand.
let _localIps = null;
function localIpSet() {
  if (_localIps) return _localIps;
  const set = new Set();
  const ifaces = networkInterfaces();
  for (const list of Object.values(ifaces)) {
    if (!list) continue;
    for (const i of list) set.add(i.address);
  }
  // Loopback families. We don't enumerate 127.0.0.0/8 — just check the
  // prefix at lookup time. ::1 is added explicitly.
  set.add('::1');
  _localIps = set;
  return set;
}

function isLoopback(ip) {
  if (!ip) return false;
  if (ip === '::1') return true;
  return ip.startsWith('127.');
}

// Resolve `address` (a hostname or IP literal) and return true if it
// points at a local interface. DNS failure → false (conservative).
async function isSelfAddress(address) {
  let ip;
  try {
    const res = await dnsLookup(address);
    ip = res.address;
  } catch {
    return false;
  }
  if (isLoopback(ip)) return true;
  return localIpSet().has(ip);
}

// --- Live rectangle renderer (unchanged from milestone 3) ---

const ANSI_RE = /\x1b\[[0-9;?]*[a-zA-Z]/g;

function visibleLength(s) {
  return s.replace(ANSI_RE, '').length;
}

// Strip escape sequences that would interfere with the rectangle's cursor
// management. Keeps SGR (color) so the rectangle is still pretty. The full
// uncut byte stream still goes to the log file unchanged.
//
// Chunk boundaries can split an escape sequence; we accept the rare case
// of a partial sequence leaking through. Tools tend to emit escape
// sequences in single writes, so this is rare in practice.
function sanitizeForRect(input) {
  const text = typeof input === 'string' ? input : input.toString('utf8');
  return text
    // OSC: ESC ] ... BEL or ESC \
    .replace(/\x1b\][^\x07\x1b]*(?:\x07|\x1b\\)/g, '')
    // DCS / SOS / PM / APC: ESC [PX^_] ... ESC \
    .replace(/\x1b[PX^_][\s\S]*?\x1b\\/g, '')
    // CSI sequences whose final byte is NOT 'm' (SGR is 'm', drop the rest)
    .replace(/\x1b\[[0-9;?<>!]*[A-Za-ln-z]/g, '')
    // Two-char ESC sequences (ESC c reset, ESC =/> keypad, ESC 7/8 save/restore, etc.)
    .replace(/\x1b[=>cDEHMNOZ()78]/g, '');
}

function truncateToWidth(s, width) {
  if (visibleLength(s) <= width) return s;
  let out = '';
  let visible = 0;
  let i = 0;
  while (i < s.length && visible < width) {
    if (s[i] === '\x1b' && s[i + 1] === '[') {
      let j = i + 2;
      while (j < s.length && !/[a-zA-Z]/.test(s[j])) j++;
      out += s.slice(i, j + 1);
      i = j + 1;
    } else {
      out += s[i];
      visible++;
      i++;
    }
  }
  return out + '\x1b[0m';
}

class Rectangle {
  constructor(height) {
    this.height = height;
    this.committed = [];
    this.current = '';
    // Set when we see CR; cleared on the next byte. Allows us to treat
    // CRLF as a single line ending and a lone CR as a progress-bar
    // line-reset, even when the CR and the following byte arrive in
    // different chunks.
    this.pendingCR = false;
    this.active = process.stdout.isTTY && height > 0;
  }
  start() {
    if (!this.active) return;
    process.stdout.write('\n'.repeat(this.height));
  }
  feed(chunk) {
    const text = typeof chunk === 'string' ? chunk : chunk.toString('utf8');
    for (let i = 0; i < text.length; i++) {
      const ch = text[i];
      if (this.pendingCR) {
        this.pendingCR = false;
        if (ch === '\n') {
          // CRLF — line ending. Commit and continue.
          this.commit();
          continue;
        }
        // Lone CR — progress-bar style line reset. Fall through to
        // process the current byte as a fresh line.
        this.current = '';
      }
      if (ch === '\r') {
        this.pendingCR = true;
      } else if (ch === '\n') {
        this.commit();
      } else {
        this.current += ch;
      }
    }
    this.redraw();
  }
  commit() {
    this.committed.push(this.current);
    if (this.committed.length > this.height - 1) this.committed.shift();
    this.current = '';
  }
  redraw() {
    if (!this.active) return;
    const width = process.stdout.columns || 80;
    let out = `\x1b[${this.height}A`;
    for (let i = 0; i < this.height - 1; i++) {
      const line = this.committed[i] || '';
      out += '\r\x1b[2K' + truncateToWidth(line, width) + '\n';
    }
    out += '\r\x1b[2K' + truncateToWidth(this.current, width) + '\n';
    process.stdout.write(out);
  }
  finish() {
    if (!this.active) return;
    let out = `\x1b[${this.height}A`;
    for (let i = 0; i < this.height; i++) out += '\r\x1b[2K\n';
    out += `\x1b[${this.height}A`;
    process.stdout.write(out);
  }
}

// --- Sidecar parsing + summary rendering ---

function parseSidecar(text) {
  const events = [];
  for (const line of text.split('\n')) {
    if (!line.trim()) continue;
    try {
      events.push(JSON.parse(line));
    } catch {
      process.stderr.write(`playbash: ignoring malformed sidecar line: ${line}\n`);
    }
  }
  return events;
}

function renderSummary(events, {verbose}) {
  if (events.length === 0) return;
  const byLevel = {info: [], warn: [], error: [], action: []};
  for (const ev of events) if (byLevel[ev.level]) byLevel[ev.level].push(ev);

  if (byLevel.action.length) {
    process.stderr.write('  actions:\n');
    for (const ev of byLevel.action) {
      const kind = ev.kind || 'unknown';
      const target = ev.target ? ` [${ev.target}]` : '';
      process.stderr.write(`    ${kind}${target} — ${ev.msg}\n`);
    }
  }
  if (byLevel.warn.length) {
    process.stderr.write('  warnings:\n');
    for (const ev of byLevel.warn) {
      const target = ev.target ? `${ev.target}: ` : '';
      process.stderr.write(`    ${target}${ev.msg}\n`);
    }
  }
  if (byLevel.error.length) {
    process.stderr.write('  errors:\n');
    for (const ev of byLevel.error) process.stderr.write(`    ${ev.msg}\n`);
  }
  if (verbose && byLevel.info.length) {
    process.stderr.write('  info:\n');
    for (const ev of byLevel.info) {
      const step = ev.step ? `[${ev.step}] ` : '';
      process.stderr.write(`    ${step}${ev.msg}\n`);
    }
  }
}

// --- run / debug ---

function sshCapture(host, remote) {
  return new Promise((resolve, reject) => {
    const proc = spawn('ssh', [host, '--', remote], {stdio: ['ignore', 'pipe', 'pipe']});
    let stdout = '', stderr = '';
    proc.stdout.on('data', c => (stdout += c));
    proc.stderr.on('data', c => (stderr += c));
    proc.on('error', reject);
    proc.on('close', code => resolve({code, stdout, stderr}));
  });
}

// Shared pipeline for both remote and local execution. Backends supply
// `makeChild` (returns the ChildProcess to read output from) and
// `getSidecarText` (returns the JSON-lines payload after the child exits
// and handles cleanup).
async function runPipeline({playbook, hostName, rectHeight, verbose, label, makeChild, getSidecarText}) {
  const cols = process.stdout.columns || 80;
  const rows = process.stdout.rows || 24;

  const logDir = join(homedir(), '.cache', 'playbash', 'runs');
  mkdirSync(logDir, {recursive: true});
  const stamp = new Date().toISOString().replace(/[:.]/g, '-');
  const logPath = join(logDir, `${stamp}-${hostName}-${playbook}.log`);
  const log = createWriteStream(logPath);

  const rect = new Rectangle(rectHeight);
  const start = Date.now();
  rect.start();

  const result = await new Promise((resolve, reject) => {
    let child;
    try {
      child = makeChild({cols, rows});
    } catch (err) {
      reject(err);
      return;
    }
    child.stdout.on('data', chunk => {
      // Log gets the raw byte stream (forensic copy). Both display modes
      // (rectangle and raw passthrough) get the sanitized version, so
      // terminal queries from remote tools cannot reach the user's
      // terminal regardless of -n setting. Use `playbash log` to view
      // the raw log file safely.
      log.write(chunk);
      const cleaned = sanitizeForRect(chunk);
      if (rect.active) rect.feed(cleaned);
      else process.stdout.write(cleaned);
    });
    child.stderr.on('data', chunk => log.write(chunk));
    child.on('error', reject);
    child.on('close', (code, signal) => resolve({code, signal}));
  }).catch(err => {
    rect.finish();
    die(`failed to spawn: ${err.message}`, 1);
  });

  rect.finish();
  await new Promise(resolve => log.end(resolve));

  let events = [];
  try {
    const text = await getSidecarText();
    events = parseSidecar(text);
  } catch (err) {
    process.stderr.write(`playbash: failed to fetch sidecar: ${err.message}\n`);
  }

  const elapsed = ((Date.now() - start) / 1000).toFixed(1);
  const status = result.signal
    ? `signal ${result.signal}`
    : result.code === 0
      ? 'ok'
      : `exit ${result.code}`;
  process.stderr.write(`playbash: ${hostName} ${playbook}${label} — ${status} (${elapsed}s)\n`);
  renderSummary(events, {verbose});
  process.stderr.write(`playbash: log ${logPath}\n`);

  process.exit(result.code ?? 1);
}

async function runRemote({playbook, hostName, address, rectHeight, verbose}) {
  const reportPath = `/tmp/playbash-report-${randomBytes(8).toString('hex')}.jsonl`;
  await runPipeline({
    playbook, hostName, rectHeight, verbose, label: '',
    makeChild: ({cols, rows}) => {
      const inner =
        `PLAYBASH_REPORT=${reportPath} ` +
        `PLAYBASH_HOST=${hostName} ` +
        `COLUMNS=${cols} LINES=${rows} ` +
        `~/.local/bin/playbash-${playbook}`;
      // Wrap in remote script(1) — Option D from the milestone-3 PTY
      // discussion. The PTY is allocated on the *target*; ssh has plain
      // pipes locally on both sides; terminal queries from remote tools
      // (OSC 11, CPR) are answered by the remote PTY and never reach
      // our local terminal, so they cannot be echoed back to the user's
      // shell after we exit. Also: we don't need `-tt`, which was
      // forwarding those queries in the first place.
      //
      // util-linux script(1) syntax (-q quiet, -f flush after each write,
      // -e return wrapped command's exit code). Targets are assumed to be
      // Linux. macOS targets would need BSD script syntax — defer until
      // someone actually wants to run a playbook against the Mac.
      const wrapped = `script -qfec '${inner}' /dev/null`;
      return spawn('ssh', [address, '--', wrapped], {
        stdio: ['ignore', 'pipe', 'pipe'],
      });
    },
    getSidecarText: async () => {
      const fetch = await sshCapture(address, `cat ${reportPath} 2>/dev/null; rm -f ${reportPath}`);
      return fetch.stdout;
    },
  });
}

async function runLocally({playbook, hostName, rectHeight, verbose}) {
  // Local sidecar lives in $TMPDIR. No ssh, no PTY allocation — the
  // playbook runs as a direct child of Node. Tools that depend on a tty
  // (e.g. interactive `apt`) will see a pipe; that matches "the bare
  // script run by hand from a non-tty context."
  const reportPath = join(tmpdir(), `playbash-report-${randomBytes(8).toString('hex')}.jsonl`);
  const playbookPath = join(homedir(), '.local', 'bin', `playbash-${playbook}`);
  if (!existsSync(playbookPath)) {
    die(`local playbook not found: ${playbookPath}`);
  }
  await runPipeline({
    playbook, hostName, rectHeight, verbose, label: ' (local)',
    makeChild: ({cols, rows}) => spawn(playbookPath, [], {
      stdio: ['ignore', 'pipe', 'pipe'],
      env: {
        ...process.env,
        PLAYBASH_REPORT: reportPath,
        PLAYBASH_HOST: hostName,
        COLUMNS: String(cols),
        LINES: String(rows),
      },
    }),
    getSidecarText: async () => {
      let text = '';
      try { text = readFileSync(reportPath, 'utf8'); } catch {}
      try { unlinkSync(reportPath); } catch {}
      return text;
    },
  });
}

// --- list / hosts ---

function cmdLog(pathArg) {
  const logDir = join(homedir(), '.cache', 'playbash', 'runs');
  let target = pathArg;
  if (!target) {
    let entries;
    try {
      entries = readdirSync(logDir);
    } catch (err) {
      die(`no log directory at ${logDir}: ${err.message}`);
    }
    const logs = entries.filter(f => f.endsWith('.log')).sort();
    if (logs.length === 0) die(`no logs in ${logDir}`);
    target = join(logDir, logs[logs.length - 1]);
  }
  let raw;
  try {
    raw = readFileSync(target);
  } catch (err) {
    die(`cannot read ${target}: ${err.message}`);
  }
  process.stdout.write(sanitizeForRect(raw));
  process.stderr.write(`\nplaybash: log ${target}\n`);
}

function cmdList() {
  let entries;
  try {
    entries = readdirSync(PLAYBOOK_DIR);
  } catch (err) {
    die(`cannot read ${PLAYBOOK_DIR}: ${err.message}`);
  }
  const playbooks = entries
    .filter(f => f.startsWith(PLAYBOOK_PREFIX))
    .map(f => f.slice(PLAYBOOK_PREFIX.length))
    .sort();
  if (playbooks.length === 0) {
    process.stderr.write(`no playbooks found in ${PLAYBOOK_DIR} (looking for ${PLAYBOOK_PREFIX}*)\n`);
    return;
  }
  for (const p of playbooks) process.stdout.write(`${p}\n`);
}

async function cmdHosts() {
  const inv = loadInventory();
  if (!inv.present) {
    process.stderr.write(`no inventory at ${inv.path}\n`);
    return;
  }
  const hostNames = [...inv.hosts.keys()].sort();
  const groupNames = [...inv.groups.keys()].sort();
  if (hostNames.length === 0 && groupNames.length === 0) {
    process.stderr.write(`inventory at ${inv.path} is empty\n`);
    return;
  }
  if (hostNames.length > 0) {
    // Resolve each host to find which entries are self.
    const selfFlags = await Promise.all(
      hostNames.map(name => isSelfAddress(inv.hosts.get(name).address))
    );
    const width = Math.max(...hostNames.map(n => n.length));
    const addrWidth = Math.max(...hostNames.map(n => inv.hosts.get(n).address.length));
    for (let i = 0; i < hostNames.length; i++) {
      const name = hostNames[i];
      const addr = inv.hosts.get(name).address;
      const tag = selfFlags[i] ? '  (self)' : '';
      process.stdout.write(`${name.padEnd(width)}  ${addr.padEnd(addrWidth)}${tag}\n`);
    }
  }
  if (groupNames.length > 0) {
    process.stdout.write('\ngroups (not yet usable, deferred to a future milestone):\n');
    const width = Math.max(...groupNames.map(n => n.length));
    for (const name of groupNames) {
      process.stdout.write(`  ${name.padEnd(width)}  ${inv.groups.get(name).join(', ')}\n`);
    }
  }
}

// --- main dispatcher ---

const {values, positionals} = parseArgs({
  options: {
    lines: {type: 'string', short: 'n', default: '5'},
    self: {type: 'boolean', default: false},
  },
  allowPositionals: true,
});

if (positionals.length === 0) die(USAGE);
const [command, ...rest] = positionals;

// Pick the right execution backend for one host. Refuses self by default.
async function dispatchRun({playbook, hostName, rectHeight, verbose}) {
  const inv = loadInventory();
  const address = resolveHost(hostName, inv);
  const isSelf = await isSelfAddress(address);

  if (isSelf && !values.self) {
    die(
      `"${hostName}" (${address}) resolves to a local interface; refusing to run on self.\n` +
      `pass --self to run locally, or invoke the bare script directly: playbash-${playbook}`
    );
  }
  if (isSelf) {
    await runLocally({playbook, hostName, rectHeight, verbose});
  } else {
    await runRemote({playbook, hostName, address, rectHeight, verbose});
  }
}

switch (command) {
  case 'list': {
    if (rest.length > 0) die(`list takes no arguments`);
    cmdList();
    break;
  }
  case 'hosts': {
    if (rest.length > 0) die(`hosts takes no arguments`);
    await cmdHosts();
    break;
  }
  case 'log': {
    if (rest.length > 1) die(`log takes at most one argument (a path)`);
    cmdLog(rest[0]);
    break;
  }
  case 'run': {
    if (rest.length !== 2) die(`run takes <playbook> <host>\n${USAGE}`);
    const [playbook, hostName] = rest;
    if (!/^[a-zA-Z0-9._-]+$/.test(playbook)) die(`invalid playbook name "${playbook}"`);
    const rectHeight = parseInt(values.lines, 10);
    if (!Number.isFinite(rectHeight) || rectHeight < 0) {
      die(`--lines must be a non-negative integer (0 disables the rectangle)`);
    }
    await dispatchRun({playbook, hostName, rectHeight, verbose: false});
    break;
  }
  case 'debug': {
    if (rest.length !== 2) die(`debug takes <playbook> <host>\n${USAGE}`);
    const [playbook, hostName] = rest;
    if (!/^[a-zA-Z0-9._-]+$/.test(playbook)) die(`invalid playbook name "${playbook}"`);
    await dispatchRun({playbook, hostName, rectHeight: 0, verbose: true});
    break;
  }
  default:
    die(`unknown command "${command}"\n${USAGE}`);
}
