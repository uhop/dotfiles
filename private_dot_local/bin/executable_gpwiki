#!/usr/bin/env bash

set -euCo pipefail
shopt -s expand_aliases

echoRun() {
  echo -e "\033[36m$@\033[0m"
  eval "$@"
}

echoRun "git pull --recurse-submodules"
[ -d wiki ] && [ -f wiki/.git ] && echoRun "cd wiki; git-pull-main" || true
[ -d external_wiki ] && [ -f external_wiki/.git ] && echoRun "cd external_wiki; git-pull-main" || true
