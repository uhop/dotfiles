#!/usr/bin/env bash

set -euCo pipefail
shopt -s expand_aliases

. ~/.local/libs/bootstrap.sh
. ~/.local/libs/playbash.sh

script_name=$(basename "$0")

deps::need docker jq

# --- Program definition ---

args::program "$script_name" "1.5.0" "Manage Docker Compose setups" "https://github.com/uhop/dotfiles/wiki/Dcm"

args_program_header="${BOLD}dcm${RESET_BOLD} manages Docker Compose service lifecycles
with automatic AppArmor recovery on Linux. Optional per-stack scripts
(daily.sh / weekly.sh / health.sh / pre-update.sh / post-update.sh)
extend the lifecycle without compose-yaml changes."

args_program_usage="${BOLD}dcm${RESET_BOLD}                          # Update current dir (pull + up)
${BOLD}dcm${RESET_BOLD} update ~/servers/monitor # Update specific setup
${BOLD}dcm${RESET_BOLD} status ~/servers         # Status for all setups under ~/servers
${BOLD}dcm${RESET_BOLD} daily ~/servers          # Run daily.sh for each setup (no-op if absent)
${BOLD}dcm${RESET_BOLD} check ~/servers          # Run health.sh for each setup
${BOLD}dcm${RESET_BOLD} prune                    # Prune unused Docker images globally"

args_program_default_command="update"

args::option "update, up, u" "Pull images, recreate changed containers" "dir" "opt"
args::option "down, d" "Compose down (stop and remove)" "dir" "opt"
args::option "stop" "Compose stop (pause without removing)" "dir" "opt"
args::option "start" "Compose start (resume stopped services)" "dir" "opt"
args::option "restart" "Compose restart" "dir" "opt"
args::option "status, s" "Compose ps (show running services)" "dir" "opt"
args::option "prune, p" "Prune unused Docker images globally"
args::option "rollback, r" "Roll back to image versions captured before the last update" "dir" "opt"
args::option "daily" "Run per-stack daily.sh (no-op if absent)" "dir" "opt"
args::option "weekly" "Run per-stack weekly.sh (no-op if absent)" "dir" "opt"
args::option "check" "Run per-stack health.sh and report (no-op if absent)" "dir" "opt"

args::option "--force" "Pass --force-recreate to docker compose up"
args::option "-n, --dry-run" "Show commands without running"
args::option "-v, --version" "Show version"
args::option "-h, --help" "Show help"
args::option "--bash-completion" "Show bash completion"

args::parse "$@"
set -- "${args_cleaned[@]}"

# --- Defaults and option extraction ---

DRY_RUN=0
[[ -v args_options["-n"] ]] && DRY_RUN=1

OPT_FORCE=0
[[ -v args_options["--force"] ]] && OPT_FORCE=1

IS_LINUX=0
[[ "$(uname -s)" == "Linux" ]] && IS_LINUX=1

# --- Helpers ---

find_compose_file() {
  local dir="$1"
  local name
  for name in compose.yaml compose.yml docker-compose.yaml docker-compose.yml; do
    if [ -f "$dir/$name" ]; then
      echo "$dir/$name"
      return
    fi
  done
  echo ""
}

validate_compose_dir() {
  local dir="$1"
  if [ ! -d "$dir" ]; then
    ansi::err "${ERROR}'$dir' is not a directory${RESET_ALL}"
    return 1
  fi
  local cf
  cf="$(find_compose_file "$dir")"
  if [ -z "$cf" ]; then
    ansi::err "${ERROR}No compose file found in '$dir'${RESET_ALL}"
    return 1
  fi
  return 0
}

# Run a per-stack convention script if it exists. Caller must already
# be cd'd into the compose dir. Sets SERVICE_NAME (basename of the dir)
# and COMPOSE_FILE (path to the discovered compose file) for the script.
# Honors --dry-run. Returns the script's exit code (or 0 if absent).
run_convention_script() {
  local name="$1"
  local script="./$name"

  [ -e "$script" ] || return 0

  if [ "$DRY_RUN" -eq 1 ]; then
    ansi::out "${INFO}[dry-run] $name${RESET_ALL}"
    return 0
  fi

  local service_name compose_file
  service_name="$(basename "$(pwd)")"
  compose_file="$(find_compose_file ".")"

  if [ -x "$script" ]; then
    SERVICE_NAME="$service_name" COMPOSE_FILE="$compose_file" "$script"
  else
    SERVICE_NAME="$service_name" COMPOSE_FILE="$compose_file" bash "$script"
  fi
}

is_apparmor_error() {
  local stderr_text="$1"
  if [ "$IS_LINUX" -eq 0 ]; then
    return 1
  fi
  if echo "$stderr_text" | grep -qi "permission denied" && \
     echo "$stderr_text" | grep -qiE "cannot (kill|stop) container"; then
    return 0
  fi
  return 1
}

# Global temp file for cleanup (set by run_compose)
_RUN_COMPOSE_TEMP_FILE=""

# Cleanup function for temp files
_cleanup_run_compose() {
  if [ -n "$_RUN_COMPOSE_TEMP_FILE" ] && [ -f "$_RUN_COMPOSE_TEMP_FILE" ]; then
    rm -f "$_RUN_COMPOSE_TEMP_FILE"
  fi
}

# Run a docker compose command with AppArmor recovery.
# Must be called from within the target compose directory.
# Captures stderr via tee so user sees errors in real-time; on failure checks for AppArmor pattern and retries once.
run_compose() {
  _RUN_COMPOSE_TEMP_FILE="$(mktemp)"
  trap _cleanup_run_compose EXIT

  if [ "$DRY_RUN" -eq 1 ]; then
    ansi::out "${INFO}[dry-run] docker compose $*${RESET_ALL}"
    return 0
  fi

  local rc=0
  echoRunTee /dev/null "$_RUN_COMPOSE_TEMP_FILE" docker compose "$@" || rc=$?

  if [ "$rc" -eq 0 ]; then
    return 0
  fi

  local stderr_text
  stderr_text="$(cat "$_RUN_COMPOSE_TEMP_FILE")"

  if is_apparmor_error "$stderr_text"; then
    ansi::warn "${WARN}AppArmor conflict detected, clearing stale profiles...${RESET_ALL}"
    sudo aa-remove-unknown || true

    # Retry once
    rc=0
    echoRunTee /dev/null "$_RUN_COMPOSE_TEMP_FILE" docker compose "$@" || rc=$?

    if [ "$rc" -eq 0 ]; then
      ansi::out "${OK}Retry succeeded after AppArmor fix${RESET_ALL}"
      return 0
    fi
  fi

  return "$rc"
}

run_or_dry() {
  if [ "$DRY_RUN" -eq 1 ]; then
    ansi::out "${INFO}[dry-run] $*${RESET_ALL}"
  else
    echoRun "$@"
  fi
}

# Capture a snapshot of image IDs keyed by container name.
# Output: lines of "container_name image_id" pairs.
snapshot_images() {
  docker compose images --format json 2>/dev/null \
    | jq -r '.[] | "\(.ContainerName) \(.ID)"' 2>/dev/null || true
}

# Capture a structured snapshot for rollback: per service, the current
# image:tag reference and the image ID it currently resolves to. Persisted
# to <dir>/.dcm-rollback.json by cmd_update before each pull.
snapshot_for_rollback() {
  local entries
  entries="$(docker compose images --format json 2>/dev/null \
    | jq '[.[] | {service: .Service, container: .ContainerName, image: "\(.Repository):\(.Tag)", id: .ID}]')"
  if [[ -z "$entries" || "$entries" == "[]" || "$entries" == "null" ]]; then
    return 1
  fi
  jq -n --arg ts "$(date -Is)" --argjson entries "$entries" \
    '{timestamp: $ts, services: $entries}'
}

DCM_ROLLBACK_FILE=".dcm-rollback.json"

# Compare before/after snapshots and report changes.
# Args: $1 = before snapshot (string), $2 = after snapshot (string)
# Output: lines to stderr describing what changed.
report_changes() {
  local before="$1" after="$2"
  local -A before_map=() after_map=()
  local name id

  while read -r name id; do
    [[ -n "$name" ]] && before_map["$name"]="$id"
  done <<< "$before"

  while read -r name id; do
    [[ -n "$name" ]] && after_map["$name"]="$id"
  done <<< "$after"

  local updated=() unchanged=()
  for name in "${!after_map[@]}"; do
    if [[ -v before_map["$name"] && "${before_map[$name]}" == "${after_map[$name]}" ]]; then
      unchanged+=("$name")
    else
      updated+=("$name")
    fi
  done

  if [[ ${#updated[@]} -eq 0 ]]; then
    ansi::out "  ${INFO}no images changed${RESET_ALL}"
  else
    for name in "${updated[@]}"; do
      ansi::out "  ${OK}updated:${RESET_ALL} $name"
    done
    for name in "${unchanged[@]}"; do
      ansi::out "  unchanged: $name"
    done
  fi
}

# Show a compact one-line-per-service status summary. Includes stopped/exited
# services (-a) so a fully-down stack is visible as ✗ lines instead of silence.
# Uses ASCII Unit Separator (\x1f) instead of \t because bash's `read` collapses
# consecutive whitespace IFS chars, which would shift fields when Health is empty.
report_status() {
  local service state health status printed=0
  while IFS=$'\x1f' read -r service state health status; do
    [[ -z "$service" ]] && continue
    printed=1
    case "$state" in
      running)
        if [[ "$health" == "unhealthy" ]]; then
          ansi::out "  ${WARN}$service${RESET_ALL}: running (unhealthy)"
        else
          ansi::out "  ${OK}✓${RESET_ALL} $service: $status"
        fi
        ;;
      *)
        local label="$state"
        [[ -n "$health" ]] && label="$state ($health)"
        ansi::out "  ${ERROR}✗${RESET_ALL} $service: $label — $status"
        ;;
    esac
  done < <(docker compose ps -a --format json 2>/dev/null \
    | jq -r '"\(.Service)\u001f\(.State)\u001f\(.Health // "")\u001f\(.Status)"')

  if [[ "$printed" -eq 0 ]]; then
    ansi::out "  ${INFO}(no services)${RESET_ALL}"
  fi
}

# --- Commands ---
# Each cmd_* function cd's into the target dir so docker compose
# auto-detects the compose file. Runs in a subshell to preserve cwd.

cmd_update() (
  cd "$1"
  local dir_name
  dir_name="$(basename "$(pwd)")"

  ansi::out "${OK}Updating: ${BOLD}$dir_name${RESET_ALL}"

  # Optional pre-update hook: backups, safety checks. Failure ABORTS
  # the update — don't pull/up if the prep didn't succeed.
  if [ -e "./pre-update.sh" ]; then
    ansi::out "${INFO}Running pre-update.sh${RESET_ALL}"
    run_convention_script pre-update.sh || return $?
  fi

  if [ "$DRY_RUN" -eq 1 ]; then
    ansi::out "${INFO}[dry-run] docker compose images (snapshot before + persist for rollback)${RESET_ALL}"
    ansi::out "${INFO}[dry-run] docker compose pull${RESET_ALL}"
    ansi::out "${INFO}[dry-run] docker compose images (snapshot after)${RESET_ALL}"
  else
    local before after
    before="$(snapshot_images)"
    # Persist the pre-pull snapshot for rollback. Skip if no images yet (first
    # `up` of a brand-new stack has nothing to roll back to).
    snapshot_for_rollback >| "$DCM_ROLLBACK_FILE" 2>/dev/null || rm -f -- "$DCM_ROLLBACK_FILE"
    # --ignore-buildable: services with a `build:` block (locally-built
    # images like vault-storage) are skipped instead of failing the pull
    # with "pull access denied". Compose v2.13+.
    echoRun docker compose pull --ignore-buildable || return $?
    after="$(snapshot_images)"
    report_changes "$before" "$after"
  fi
  if [ "$OPT_FORCE" -eq 1 ]; then
    run_compose up -d --force-recreate || return $?
  else
    run_compose up -d || return $?
  fi

  report_status

  # Optional post-update hook: smoke tests, migrations, notifications.
  # Failure WARNS but doesn't fail the command — the update is already
  # deployed; rolling back via `dcm rollback` is the recovery path.
  if [ -e "./post-update.sh" ]; then
    ansi::out "${INFO}Running post-update.sh${RESET_ALL}"
    if ! run_convention_script post-update.sh; then
      ansi::warn "${WARN}post-update.sh failed (exit $?) — update is already deployed${RESET_ALL}"
    fi
  fi

  ansi::out "${OK}Done: ${BOLD}$dir_name${RESET_ALL}"
)

cmd_daily() (
  cd "$1"
  local target dir_name
  target="$(pwd)"
  dir_name="$(basename "$target")"
  if [ -e "./daily.sh" ]; then
    ansi::out "${OK}Daily: ${BOLD}$dir_name${RESET_ALL}"
    run_convention_script daily.sh
  else
    # No daily.sh → fall back to default refresh (`dcm update`). This
    # lets stacks opt into custom logic by writing daily.sh while
    # stacks with no script still get auto-refreshed each day.
    cmd_update "$target"
  fi
)

cmd_weekly() (
  cd "$1"
  local target dir_name
  target="$(pwd)"
  dir_name="$(basename "$target")"
  if [ -e "./weekly.sh" ]; then
    ansi::out "${OK}Weekly: ${BOLD}$dir_name${RESET_ALL}"
    run_convention_script weekly.sh
  else
    cmd_update "$target"
  fi
)

cmd_check() (
  cd "$1"
  local dir_name
  dir_name="$(basename "$(pwd)")"
  if [ ! -e "./health.sh" ]; then
    ansi::out "${INFO}Check: ${BOLD}$dir_name${RESET_ALL} (no health.sh)"
    return 0
  fi
  ansi::out "${INFO}Check: ${BOLD}$dir_name${RESET_ALL}"
  local rc=0
  run_convention_script health.sh || rc=$?
  case $rc in
    0) ansi::out "  ${OK}✓${RESET_ALL} healthy" ;;
    1) ansi::out "  ${ERROR}✗${RESET_ALL} actionable failure" ;;
    2) ansi::out "  ${WARN}?${RESET_ALL} lookup failed (network/dependency unavailable)" ;;
    3) ansi::out "  ${WARN}?${RESET_ALL} upstream API error" ;;
    *) ansi::out "  ${ERROR}✗${RESET_ALL} unexpected exit $rc" ;;
  esac
  return $rc
)

cmd_down() (
  cd "$1"
  local dir_name
  dir_name="$(basename "$(pwd)")"

  ansi::out "${OK}Bringing down: ${BOLD}$dir_name${RESET_ALL}"
  run_compose down || return $?
  ansi::out "${OK}Done: ${BOLD}$dir_name${RESET_ALL}"
)

cmd_stop() (
  cd "$1"
  local dir_name
  dir_name="$(basename "$(pwd)")"

  ansi::out "${INFO}Stopping: ${BOLD}$dir_name${RESET_ALL}"
  run_compose stop || return $?
  ansi::out "${OK}Done: ${BOLD}$dir_name${RESET_ALL}"
)

cmd_start() (
  cd "$1"
  local dir_name
  dir_name="$(basename "$(pwd)")"

  ansi::out "${INFO}Starting: ${BOLD}$dir_name${RESET_ALL}"
  run_compose start || return $?
  ansi::out "${OK}Done: ${BOLD}$dir_name${RESET_ALL}"
)

cmd_restart() (
  cd "$1"
  local dir_name
  dir_name="$(basename "$(pwd)")"

  ansi::out "${INFO}Restarting: ${BOLD}$dir_name${RESET_ALL}"
  run_compose restart || return $?
  ansi::out "${OK}Done: ${BOLD}$dir_name${RESET_ALL}"
)

cmd_rollback() (
  cd "$1"
  local dir_name
  dir_name="$(basename "$(pwd)")"

  if [[ ! -f "$DCM_ROLLBACK_FILE" ]]; then
    ansi::warn "${WARN}No rollback snapshot for ${BOLD}$dir_name${RESET_ALL} — run ${BOLD}dcm update${RESET_BOLD} first to capture one.${RESET_ALL}"
    return 1
  fi

  ansi::out "${OK}Rolling back: ${BOLD}$dir_name${RESET_ALL}"
  local ts
  ts="$(jq -r '.timestamp // "unknown"' "$DCM_ROLLBACK_FILE")"
  ansi::out "${INFO}Snapshot from: ${BOLD}$ts${RESET_ALL}"

  # Verify every recorded image ID still exists locally; abort early if any
  # were pruned away.
  local missing=()
  local id image
  while IFS=$'\x1f' read -r id image; do
    [[ -z "$id" ]] && continue
    if ! docker image inspect "$id" >/dev/null 2>&1; then
      missing+=("$image (id $id)")
    fi
  done < <(jq -r '.services[] | "\(.id)\u001f\(.image)"' "$DCM_ROLLBACK_FILE")

  if (( ${#missing[@]} > 0 )); then
    ansi::warn "${ERROR}Missing images for rollback (probably pruned):${RESET_ALL}"
    for m in "${missing[@]}"; do
      ansi::warn "  - $m"
    done
    ansi::warn "Cannot roll back. Re-pull current images with ${BOLD}dcm update${RESET_BOLD} or restore manually."
    return 1
  fi

  # Re-tag old IDs back to their image references, then recreate containers.
  while IFS=$'\x1f' read -r id image; do
    [[ -z "$id" ]] && continue
    if [[ "$DRY_RUN" -eq 1 ]]; then
      ansi::out "${INFO}[dry-run] docker tag $id $image${RESET_ALL}"
    else
      echoRun docker tag "$id" "$image"
    fi
  done < <(jq -r '.services[] | "\(.id)\u001f\(.image)"' "$DCM_ROLLBACK_FILE")

  # Force-recreate so containers pick up the re-tagged image even though the
  # tag string itself didn't change.
  run_compose up -d --force-recreate || return $?

  report_status
  ansi::out "${OK}Done: ${BOLD}$dir_name${RESET_ALL}"
)

cmd_status() (
  cd "$1"
  local dir_name
  dir_name="$(basename "$(pwd)")"

  ansi::out "${INFO}Status: ${BOLD}$dir_name${RESET_ALL}"
  report_status
)

cmd_prune() {
  if [ "$DRY_RUN" -eq 1 ]; then
    ansi::out "${INFO}[dry-run] docker image prune -af${RESET_ALL}"
  else
    echoRun docker image prune -af
  fi
}

# --- Discover setups ---
# If target_dir contains a compose file, return just that dir.
# Otherwise, return all immediate subdirs that contain compose files.
find_compose_dirs() {
  local target_dir="$1"

  if [ -n "$(find_compose_file "$target_dir")" ]; then
    # Target dir has a compose file - use it directly
    echo "$target_dir"
    return 0
  fi

  # No compose file in target - check immediate subdirectories
  local dirs=()
  local d
  for d in "$target_dir"/*/; do
    [ -d "$d" ] || continue
    if [ -n "$(find_compose_file "${d%/}")" ]; then
      dirs+=("${d%/}")
    fi
  done

  if [ ${#dirs[@]} -eq 0 ]; then
    ansi::err "${ERROR}No compose file found in '$target_dir' or its immediate subdirectories${RESET_ALL}"
    return 1
  fi

  printf '%s\n' "${dirs[@]}"
}

# --- Run command on one or more directories ---

dispatch() {
  local cmd="$1"
  shift
  local target_dir="${1:-.}"

  local setups
  setups="$(find_compose_dirs "$target_dir")" || exit 1

  local total
  total="$(echo "$setups" | wc -l)"

  if [ "$total" -gt 1 ]; then
    ansi::out "${INFO}Found ${BOLD}$total${RESET_BOLD} compose setup(s) under ${BOLD}$target_dir${RESET_ALL}"
  fi

  # Reset the section accumulator so a prior dispatch (rare in practice
  # but possible if dcm is sourced multiple times) doesn't leak.
  playbash_section_reset

  while IFS= read -r dir; do
    # Blank line before each iteration in multi-dir runs (separates the
    # "Found N..." header from the first stack and stacks from each other).
    # Single-dir runs stay tight: no leading blank.
    [[ "$total" -gt 1 ]] && echo
    playbash_section "$(basename "$dir")" "cmd_$cmd" "$dir"
  done <<< "$setups"

  local failed=${#_PLAYBASH_FAILED_SECTIONS[@]}
  local succeeded=$((total - failed))

  if [ "$total" -gt 1 ]; then
    echo
    ansi::out "${OK}Results: ${BOLD}$succeeded${RESET_BOLD} succeeded, ${BOLD}$failed${RESET_BOLD} failed${RESET_ALL}"
    if [ "$failed" -gt 0 ]; then
      ansi::warn "${WARN}Failed:${RESET_ALL}"
      local name
      for name in "${_PLAYBASH_FAILED_SECTIONS[@]}"; do
        ansi::warn "${WARN}  - ${name}${RESET_ALL}"
      done
    fi
  fi

  # Emit the structured failure event for upstream playbash readers and
  # propagate the exit code. Previously, the bare `if cmd; then s++; fi`
  # loop pattern silently swallowed failures and dispatch always exited
  # 0 — now any failed stack makes dcm itself exit non-zero, which is
  # what `dcms`-via-playbash-section needs to register the failure.
  [ "$failed" -eq 0 ] || playbash_section_report
}

# --- Main ---

cmd="$args_command"

# Skip explicit command word from positional args
if [[ -n "${1:-}" && -v "args_aliases[${1}]" && "${1:-}" != -* ]]; then
  shift
fi

# Resolve target directory from remaining args
target_dir="${1:-}"

case "$cmd" in
  update)  dispatch update "$target_dir" ;;
  down)    dispatch down "$target_dir" ;;
  stop)    dispatch stop "$target_dir" ;;
  start)   dispatch start "$target_dir" ;;
  restart) dispatch restart "$target_dir" ;;
  status)   dispatch status "$target_dir" ;;
  prune)    cmd_prune ;;
  rollback) dispatch rollback "$target_dir" ;;
  daily)    dispatch daily "$target_dir" ;;
  weekly)   dispatch weekly "$target_dir" ;;
  check)    dispatch check "$target_dir" ;;
  *)
    ansi::warn "${ERROR}Unknown command: $cmd${RESET_ALL}"
    exit 1
    ;;
esac
