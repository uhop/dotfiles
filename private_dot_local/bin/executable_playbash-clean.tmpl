#!/usr/bin/env bash
# playbash-daily — daily maintenance stack: chezmoi update, then dcms,
# then upd -ry. Sources playbash.sh so the runner gets structured events,
# but stays directly runnable by hand (helpers fall back to pretty-print
# when $PLAYBASH_REPORT is unset).

set -euCo pipefail
shopt -s expand_aliases

source "${PLAYBASH_LIBS:-$HOME/.local/libs}/playbash.sh"

playbash_step "chezmoi"
playbash_info "running chezmoi update"
chezmoi update

playbash_step "system"
playbash_info "running cln -y"
cln -y
