#!/usr/bin/env bash

set -euCo pipefail
shopt -s expand_aliases

. ~/.local/libs/bootstrap.sh

script_name=$(basename "$0")

args::program "$script_name" "2.0.0" "Set up periodic scheduled tasks"

args_program_header="${BOLD}setup-periodic${RESET_BOLD} creates systemd timers (Linux) or
launchd system daemons (macOS) for recurring tasks.

Schedule format: ${ITALIC}<when> [<days>]${RESET_ALL}
  ${BOLD}when${RESET_BOLD}:  HH:MM (time of day), Nh (every N hours), Nm (every N minutes)
  ${BOLD}days${RESET_BOLD}:  mo-fr (range), mo,we,fr (list), sa-mo (wrap-around), 1,15 (day of month)
  Day names: mo tu we th fr sa su (3-char aliases accepted)"

args_program_usage="${BOLD}setup-periodic${RESET_BOLD} ${ITALIC}name schedule${RESET_ALL} ${ITALIC}\"command\"${RESET_ALL} [options]
${BOLD}setup-periodic${RESET_BOLD} --list
${BOLD}setup-periodic${RESET_BOLD} --remove ${ITALIC}name${RESET_ALL}

Examples:
  setup-periodic maint \"4:00 mo-sa\" \"playbash run @self daily --report\"
  setup-periodic weekly \"4:00 su\" \"playbash run @self weekly --report\"
  setup-periodic backup 4h \"/path/to/backup\"
  setup-periodic health 15m \"health-check\"
  setup-periodic report \"6:00 1,15\" \"generate-report\""

args::option "--email" "Notification email address" "addr"
args::option "--list" "List active periodic tasks"
args::option "--remove" "Remove a periodic task" "name"
args::option "-v, --version" "Show version"
args::option "-h, --help" "Show help"

args::parse "$@"
set -- "${args_cleaned[@]}"

# --- Platform detection ---

OS=$(uname -s)
case $OS in
  Linux)  PLATFORM=systemd ;;
  Darwin) PLATFORM=launchd ;;
  *)
    ansi::err "${BOLD}${FG_RED}Unsupported platform: $OS${RESET_ALL}"
    exit 1
    ;;
esac

# --- Day name helpers ---

day_to_num() {
  case "${1,,}" in
    mo|mon) echo 1 ;;
    tu|tue) echo 2 ;;
    we|wed) echo 3 ;;
    th|thu) echo 4 ;;
    fr|fri) echo 5 ;;
    sa|sat) echo 6 ;;
    su|sun) echo 0 ;;
    *) return 1 ;;
  esac
}

# --- Schedule parser ---

weekdays=()
monthdays=()
when_type=""
when_hour=0
when_minute=0
when_interval=0

parse_days() {
  local spec="$1"
  IFS=',' read -ra tokens <<< "$spec"

  for token in "${tokens[@]}"; do
    if [[ "$token" =~ ^([a-zA-Z]{2,3})-([a-zA-Z]{2,3})$ ]]; then
      local start end
      start=$(day_to_num "${BASH_REMATCH[1]}") || { ansi::err "${BOLD}${FG_RED}Invalid day: ${BASH_REMATCH[1]}${RESET_ALL}"; exit 1; }
      end=$(day_to_num "${BASH_REMATCH[2]}") || { ansi::err "${BOLD}${FG_RED}Invalid day: ${BASH_REMATCH[2]}${RESET_ALL}"; exit 1; }
      if (( start <= end )); then
        for (( d=start; d<=end; d++ )); do weekdays+=("$d"); done
      else
        for (( d=start; d<=6; d++ )); do weekdays+=("$d"); done
        for (( d=0; d<=end; d++ )); do weekdays+=("$d"); done
      fi
    elif [[ "$token" =~ ^[a-zA-Z]{2,3}$ ]]; then
      local num
      num=$(day_to_num "$token") || { ansi::err "${BOLD}${FG_RED}Invalid day: $token${RESET_ALL}"; exit 1; }
      weekdays+=("$num")
    elif [[ "$token" =~ ^[0-9]{1,2}$ ]]; then
      local dom=$((10#$token))
      if (( dom < 1 || dom > 31 )); then
        ansi::err "${BOLD}${FG_RED}Invalid day of month: $token (1-31)${RESET_ALL}"
        exit 1
      fi
      monthdays+=("$dom")
    else
      ansi::err "${BOLD}${FG_RED}Invalid day spec: $token${RESET_ALL}"
      exit 1
    fi
  done

  if [ ${#weekdays[@]} -gt 0 ]; then
    readarray -t weekdays < <(printf '%s\n' "${weekdays[@]}" | sort -nu)
  fi
  if [ ${#monthdays[@]} -gt 0 ]; then
    readarray -t monthdays < <(printf '%s\n' "${monthdays[@]}" | sort -nu)
  fi
}

parse_schedule() {
  local schedule="$1"
  read -ra sched_parts <<< "$schedule"

  if [ ${#sched_parts[@]} -eq 0 ]; then
    ansi::err "${BOLD}${FG_RED}Empty schedule${RESET_ALL}"
    exit 1
  fi

  local when_part="${sched_parts[0]}"
  local days_part="${sched_parts[1]:-}"

  if [[ "$when_part" =~ ^([0-9]{1,2}):([0-9]{2})$ ]]; then
    when_type=time
    when_hour=$((10#${BASH_REMATCH[1]}))
    when_minute=$((10#${BASH_REMATCH[2]}))
    if (( when_hour > 23 || when_minute > 59 )); then
      ansi::err "${BOLD}${FG_RED}Invalid time: $when_part (hour 0-23, minute 0-59)${RESET_ALL}"
      exit 1
    fi
  elif [[ "$when_part" =~ ^([0-9]+)h$ ]]; then
    when_type=interval_h
    when_interval=${BASH_REMATCH[1]}
    if (( when_interval < 1 || when_interval > 23 )); then
      ansi::err "${BOLD}${FG_RED}Invalid hour interval: ${when_interval}h (1-23)${RESET_ALL}"
      exit 1
    fi
  elif [[ "$when_part" =~ ^([0-9]+)m$ ]]; then
    when_type=interval_m
    when_interval=${BASH_REMATCH[1]}
    if (( when_interval < 1 || when_interval > 59 )); then
      ansi::err "${BOLD}${FG_RED}Invalid minute interval: ${when_interval}m (1-59)${RESET_ALL}"
      exit 1
    fi
  else
    ansi::err "${BOLD}${FG_RED}Invalid schedule: $when_part (expected HH:MM, Nh, or Nm)${RESET_ALL}"
    exit 1
  fi

  weekdays=()
  monthdays=()
  if [ -n "$days_part" ]; then
    parse_days "$days_part"
  fi

  if [ "$when_type" = interval_m ] && [ "$PLATFORM" = launchd ]; then
    if [ ${#weekdays[@]} -gt 0 ] || [ ${#monthdays[@]} -gt 0 ]; then
      ansi::err "${BOLD}${FG_RED}Sub-hour intervals with day filter not supported on macOS${RESET_ALL}"
      exit 1
    fi
  fi

  if [ ${#weekdays[@]} -gt 0 ] && [ ${#monthdays[@]} -gt 0 ]; then
    ansi::warn "${BOLD}${FG_YELLOW}Mixing day-of-week and day-of-month: task may run twice on overlapping days.${RESET_ALL}"
  fi
}

# --- Backend: systemd ---

format_systemd_days() {
  local -a names=(Sun Mon Tue Wed Thu Fri Sat)
  local result=""
  local i=0

  while (( i < ${#weekdays[@]} )); do
    local start=${weekdays[$i]}
    local end=$start

    while (( i + 1 < ${#weekdays[@]} )) && (( weekdays[i+1] == end + 1 )); do
      i=$((i + 1))
      end=${weekdays[$i]}
    done

    [ -n "$result" ] && result+=","
    if (( start == end )); then
      result+="${names[$start]}"
    elif (( end == start + 1 )); then
      result+="${names[$start]},${names[$end]}"
    else
      result+="${names[$start]}..${names[$end]}"
    fi

    i=$((i + 1))
  done

  echo "$result"
}

build_systemd_calendar() {
  local time_spec

  case $when_type in
    time)       time_spec="$(printf '%02d:%02d:00' "$when_hour" "$when_minute")" ;;
    interval_h) time_spec="0/${when_interval}:00:00" ;;
    interval_m) time_spec="*:0/${when_interval}:00" ;;
  esac

  local weekday_spec=""
  if [ ${#weekdays[@]} -gt 0 ] && [ ${#weekdays[@]} -lt 7 ]; then
    weekday_spec=$(format_systemd_days)
  fi

  local monthday_spec=""
  if [ ${#monthdays[@]} -gt 0 ]; then
    monthday_spec=$(printf '%02d' "${monthdays[0]}")
    for (( i=1; i<${#monthdays[@]}; i++ )); do
      monthday_spec+=",$(printf '%02d' "${monthdays[$i]}")"
    done
  fi

  if [ -n "$weekday_spec" ] && [ -n "$monthday_spec" ]; then
    echo "${weekday_spec} *-*-* ${time_spec}"
    echo "*-*-${monthday_spec} ${time_spec}"
  elif [ -n "$weekday_spec" ]; then
    echo "${weekday_spec} *-*-* ${time_spec}"
  elif [ -n "$monthday_spec" ]; then
    echo "*-*-${monthday_spec} ${time_spec}"
  else
    echo "*-*-* ${time_spec}"
  fi
}

# --- Backend: launchd ---

build_launchd_dicts() {
  local dicts=""

  local -a run_hours=()
  if [ "$when_type" = interval_h ]; then
    for (( h=0; h<24; h+=when_interval )); do
      run_hours+=("$h")
    done
  fi

  emit_dict() {
    dicts+="    <dict>"$'\n'
    while [ $# -gt 0 ]; do
      dicts+="      <key>$1</key><integer>$2</integer>"$'\n'
      shift 2
    done
    dicts+="    </dict>"$'\n'
  }

  if [ "$when_type" = time ]; then
    if [ ${#weekdays[@]} -gt 0 ]; then
      for wd in "${weekdays[@]}"; do
        emit_dict Weekday "$wd" Hour "$when_hour" Minute "$when_minute"
      done
    fi
    if [ ${#monthdays[@]} -gt 0 ]; then
      for md in "${monthdays[@]}"; do
        emit_dict Day "$md" Hour "$when_hour" Minute "$when_minute"
      done
    fi
    if [ ${#weekdays[@]} -eq 0 ] && [ ${#monthdays[@]} -eq 0 ]; then
      emit_dict Hour "$when_hour" Minute "$when_minute"
    fi
  elif [ "$when_type" = interval_h ]; then
    if [ ${#weekdays[@]} -gt 0 ]; then
      for wd in "${weekdays[@]}"; do
        for h in "${run_hours[@]}"; do
          emit_dict Weekday "$wd" Hour "$h" Minute 0
        done
      done
    elif [ ${#monthdays[@]} -gt 0 ]; then
      for md in "${monthdays[@]}"; do
        for h in "${run_hours[@]}"; do
          emit_dict Day "$md" Hour "$h" Minute 0
        done
      done
    else
      for h in "${run_hours[@]}"; do
        emit_dict Hour "$h" Minute 0
      done
    fi
  fi

  echo -n "$dicts"
}

# --- Schedule description ---

describe_schedule() {
  local -a day_names=(su mo tu we th fr sa)
  local desc=""

  case $when_type in
    time)       desc="at $(printf '%02d:%02d' "$when_hour" "$when_minute")" ;;
    interval_h) desc="every ${when_interval}h" ;;
    interval_m) desc="every ${when_interval}m" ;;
  esac

  if [ ${#weekdays[@]} -gt 0 ] || [ ${#monthdays[@]} -gt 0 ]; then
    local parts=""
    if [ ${#weekdays[@]} -gt 0 ]; then
      for wd in "${weekdays[@]}"; do
        [ -n "$parts" ] && parts+=","
        parts+="${day_names[$wd]}"
      done
    fi
    if [ ${#monthdays[@]} -gt 0 ]; then
      [ -n "$parts" ] && parts+=" + "
      local first=1
      for md in "${monthdays[@]}"; do
        [ "$first" -eq 0 ] && parts+=","
        parts+="day $md"
        first=0
      done
    fi
    desc+=" on $parts"
  fi

  echo "$desc"
}

# --- Resolve notification email ---

email_addr=
if [[ -v args_options["--email"] ]]; then
  email_addr=${args_options["--email"]}
fi
if [ -z "$email_addr" ]; then
  if command -v chezmoi >/dev/null 2>&1 && command -v jq >/dev/null 2>&1; then
    email_addr=$(chezmoi data --format json 2>/dev/null | jq -r '.email // empty' 2>/dev/null) || true
  fi
fi
if [ -z "$email_addr" ]; then
  email_addr=root
fi

# --- --list ---

if [[ -v args_options["--list"] ]]; then
  if [ "$PLATFORM" = systemd ]; then
    unit_dir="$HOME/.config/systemd/user"
    found=0
    if [ -d "$unit_dir" ]; then
      for timer_file in "$unit_dir"/periodic-*.timer; do
        [ -f "$timer_file" ] || continue
        found=1
        timer=$(basename "$timer_file")
        systemctl --user list-timers "$timer" --no-pager 2>/dev/null
      done
    fi
    if [ "$found" -eq 0 ]; then
      ansi::out "${FG_CYAN}No periodic tasks found.${RESET_ALL}"
    fi
  elif [ "$PLATFORM" = launchd ]; then
    found=0
    for plist in /Library/LaunchDaemons/com.periodic.*.plist; do
      [ -f "$plist" ] || continue
      found=1
      label=$(basename "$plist" .plist)
      ansi::out "${BOLD}$label${RESET_ALL}: $plist"
      if sudo launchctl list "$label" >/dev/null 2>&1; then
        ansi::out "  status: loaded"
      else
        ansi::out "  status: not loaded"
      fi
    done
    if [ "$found" -eq 0 ]; then
      ansi::out "${FG_CYAN}No periodic tasks found.${RESET_ALL}"
    fi
  fi
  exit 0
fi

# --- --remove ---

if [[ -v args_options["--remove"] ]]; then
  task_name=${args_options["--remove"]}
  if [ "$PLATFORM" = systemd ]; then
    timer="periodic-${task_name}.timer"
    service="periodic-${task_name}.service"
    unit_dir="$HOME/.config/systemd/user"
    if ! [ -f "$unit_dir/$timer" ]; then
      ansi::err "${FG_RED}Timer $timer not found in $unit_dir${RESET_ALL}"
      exit 1
    fi
    ansi::out "${FG_CYAN}Disabling and removing $timer ...${RESET_ALL}"
    echoRun systemctl --user disable --now "$timer"
    echoRun rm -f "$unit_dir/$timer" "$unit_dir/$service"
    echoRun systemctl --user daemon-reload
    ansi::out "${FG_GREEN}Removed $task_name.${RESET_ALL}"
  elif [ "$PLATFORM" = launchd ]; then
    label="com.periodic.${task_name}"
    plist="/Library/LaunchDaemons/${label}.plist"
    if ! [ -f "$plist" ]; then
      ansi::err "${FG_RED}Plist $plist not found.${RESET_ALL}"
      exit 1
    fi
    ansi::out "${FG_CYAN}Unloading and removing $label ...${RESET_ALL}"
    ansi::out "${BOLD}This requires sudo to unload a system daemon.${RESET_ALL}"
    echoRun sudo launchctl unload "$plist"
    echoRun sudo rm -f "$plist"
    ansi::out "${FG_GREEN}Removed $task_name.${RESET_ALL}"
  fi
  exit 0
fi

# --- Create mode: requires name + schedule + command ---

if [ $# -lt 3 ]; then
  ansi::warn "${FG_RED}Expected: setup-periodic <name> <schedule> \"command\"${RESET_ALL}"
  args::try_help
  exit 1
fi

task_name=$1
schedule=$2
task_command=$3

if ! [[ "$task_name" =~ ^[a-z0-9][a-z0-9-]*$ ]]; then
  ansi::err "${BOLD}${FG_RED}Invalid name: $task_name (lowercase alphanumeric and hyphens, no leading hyphen)${RESET_ALL}"
  exit 1
fi

parse_schedule "$schedule"
sched_desc=$(describe_schedule)

# --- Prerequisites ---

if ! command -v sendmail >/dev/null 2>&1; then
  install_hint="Install msmtp via your package manager."
  if [ "$PLATFORM" = systemd ]; then
    if command -v apt >/dev/null 2>&1; then
      install_hint="${BOLD}sudo apt install msmtp msmtp-mta${RESET_ALL}"
    elif command -v dnf >/dev/null 2>&1; then
      install_hint="${BOLD}sudo dnf install msmtp${RESET_ALL}"
    fi
  else
    install_hint="${BOLD}brew install msmtp${RESET_ALL}"
  fi
  ansi::warn "${BOLD}${FG_RED}sendmail not found.${RESET_ALL}
Notification emails require msmtp. Install it:
  $install_hint"
  exit 1
fi

if ! [ -f "$HOME/.msmtprc" ]; then
  ansi::out "${BOLD}${FG_YELLOW}Warning: ~/.msmtprc not found. sendmail may not be configured.${RESET_ALL}"
fi

# --- Determine wrapper ---

wrapper_cmd=
if [[ "$task_command" == playbash\ * ]]; then
  wrapper_cmd="$HOME/.local/bin/notify-playbash ${task_command#playbash }"
else
  if [ "$PLATFORM" = systemd ]; then
    read -ra cmd_parts <<< "$task_command"
    abs_bin=$(command -v "${cmd_parts[0]}" 2>/dev/null || echo "${cmd_parts[0]}")
    cmd_parts[0]=$abs_bin
    wrapper_cmd="${cmd_parts[*]}"
  else
    wrapper_cmd="$HOME/.local/bin/notify-on-failure $task_command"
  fi
fi

# --- Create: systemd ---

if [ "$PLATFORM" = systemd ]; then
  unit_dir="$HOME/.config/systemd/user"
  mkdir -p "$unit_dir"

  service_name="periodic-${task_name}"
  timer_name="periodic-${task_name}"

  readarray -t on_calendar_lines < <(build_systemd_calendar)

  service_file="$unit_dir/${service_name}.service"
  cat > "$service_file" <<EOF
[Unit]
Description=Periodic $task_name task
EOF

  if [[ "$task_command" != playbash\ * ]]; then
    cat >> "$service_file" <<EOF
OnFailure=email-notify@%n.service
EOF
  fi

  cat >> "$service_file" <<EOF

[Service]
Type=oneshot
ExecStart=$wrapper_cmd
Environment=NOTIFY_EMAIL=$email_addr
EOF

  timer_file="$unit_dir/${timer_name}.timer"
  {
    cat <<EOF
[Unit]
Description=Timer for periodic $task_name task

[Timer]
EOF
    for cal in "${on_calendar_lines[@]}"; do
      echo "OnCalendar=$cal"
    done
    cat <<EOF
Persistent=true

[Install]
WantedBy=timers.target
EOF
  } > "$timer_file"

  if ! [ -f "/var/lib/systemd/linger/$(id -un)" ]; then
    ansi::out "${FG_CYAN}Enabling linger for $(id -un) (timers run at boot without login)...${RESET_ALL}"
    echoRun loginctl enable-linger
  fi

  echoRun systemctl --user daemon-reload
  echoRun systemctl --user enable --now "${timer_name}.timer"

  ansi::out ""
  ansi::out "${FG_GREEN}${BOLD}Created periodic task: $task_name${RESET_ALL}"
  ansi::out "  schedule: $sched_desc"
  ansi::out "  command:  $task_command"
  ansi::out "  wrapper:  $wrapper_cmd"
  ansi::out "  email:    $email_addr"
  ansi::out "  service:  $service_file"
  ansi::out "  timer:    $timer_file"
  ansi::out ""
  ansi::out "Verify with: ${BOLD}systemctl --user list-timers${RESET_ALL}"
fi

# --- Create: launchd ---

if [ "$PLATFORM" = launchd ]; then
  label="com.periodic.${task_name}"
  plist_tmp=$(mktemp "${TMPDIR:-/tmp}/setup-periodic.XXXXXX.plist")
  trap 'rm -f "$plist_tmp"' EXIT

  current_user=$(id -un)
  log_dir="/var/log/periodic"

  read -ra wrapper_parts <<< "$wrapper_cmd"
  wrapper_bin=$(command -v "${wrapper_parts[0]}" 2>/dev/null || echo "$HOME/.local/bin/${wrapper_parts[0]}")
  prog_args=""
  prog_args+="    <string>$wrapper_bin</string>
"
  for (( i = 1; i < ${#wrapper_parts[@]}; i++ )); do
    prog_args+="    <string>${wrapper_parts[i]}</string>
"
  done

  use_start_interval=0
  if [ "$when_type" = interval_m ]; then
    use_start_interval=1
  fi

  {
    cat <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key><string>$label</string>
  <key>UserName</key><string>$current_user</string>
  <key>ProgramArguments</key>
  <array>
$prog_args  </array>
EOF

    if [ "$use_start_interval" -eq 1 ]; then
      echo "  <key>StartInterval</key><integer>$((when_interval * 60))</integer>"
    else
      calendar_dicts=$(build_launchd_dicts)
      cat <<EOF
  <key>StartCalendarInterval</key>
  <array>
$calendar_dicts  </array>
EOF
    fi

    cat <<EOF
  <key>StandardOutPath</key><string>$log_dir/${task_name}.stdout.log</string>
  <key>StandardErrorPath</key><string>$log_dir/${task_name}.stderr.log</string>
  <key>EnvironmentVariables</key>
  <dict>
    <key>NOTIFY_EMAIL</key><string>$email_addr</string>
    <key>PATH</key><string>/usr/local/bin:/usr/bin:/bin:$HOME/.local/bin</string>
    <key>HOME</key><string>$HOME</string>
  </dict>
</dict>
</plist>
EOF
  } > "$plist_tmp"

  plist_dest="/Library/LaunchDaemons/${label}.plist"

  ansi::out ""
  ansi::out "${BOLD}This requires sudo${RESET_ALL} to install a system daemon into"
  ansi::out "  $plist_dest"
  ansi::out "and create the log directory $log_dir."
  ansi::out ""

  echoRun --bold sudo mkdir -p "$log_dir"
  echoRun --bold sudo cp "$plist_tmp" "$plist_dest"
  echoRun --bold sudo chown root:wheel "$plist_dest"
  echoRun --bold sudo chmod 644 "$plist_dest"
  echoRun --bold sudo launchctl load "$plist_dest"

  ansi::out ""
  ansi::out "${FG_GREEN}${BOLD}Created periodic task: $task_name${RESET_ALL}"
  ansi::out "  schedule: $sched_desc"
  ansi::out "  command:  $task_command"
  ansi::out "  wrapper:  $wrapper_cmd"
  ansi::out "  email:    $email_addr"
  ansi::out "  plist:    $plist_dest"
  ansi::out ""
  ansi::out "Verify with: ${BOLD}sudo launchctl list | grep periodic${RESET_ALL}"
fi
