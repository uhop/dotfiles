#!/usr/bin/env bash
# playbash-clean — cleanup stack: chezmoi update, claude-config-update,
# then cln -y. Each step runs as an isolated playbash_section.

set -euCo pipefail
shopt -s expand_aliases

source "${PLAYBASH_LIBS:-$HOME/.local/libs}/playbash.sh"

playbash_section chezmoi       chezmoi update
playbash_section claude-config claude-config-update
playbash_section cleanup       cln -y

playbash_section_report
