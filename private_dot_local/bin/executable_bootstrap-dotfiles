#!/usr/bin/env bash

set -euCo pipefail
shopt -s expand_aliases

. ~/.local/libs/bootstrap.sh

script_name=$(basename "$0")

args::program "$script_name" "1.1.0" "Prepare a remote host (or this host) for dotfiles installation"

args_program_header="${BOLD}bootstrap-dotfiles${RESET_BOLD} detects the target OS and generates a self-contained
install script. Default: SSH to a remote ${BOLD}<host>${RESET_BOLD} and upload the script.
With ${BOLD}--from-jot <prefix>${RESET_BOLD}: self-bootstrap the local machine and pull
system files from S3 via ${BOLD}jot-deploy${RESET_BOLD} when chezmoi finishes."

args_program_usage="${BOLD}bootstrap-dotfiles${RESET_BOLD} <host> [options]
       ${BOLD}bootstrap-dotfiles${RESET_BOLD} --from-jot <s3-prefix> [options]"

args::option "--github-user" "GitHub username for chezmoi (default: \$GITHUB_USERNAME or uhop)" "name"
args::option "--from-jot" "Self-bootstrap on this host; pull system files from <prefix> via jot-deploy" "prefix"
args::option "-v, --version" "Show version"
args::option "-h, --help" "Show help"
args::option "--bash-completion" "Show bash completion"

args::parse "$@"
set -- "${args_cleaned[@]}"

DIM="$FG_WHITE"

GITHUB_USER="${GITHUB_USERNAME:-uhop}"
[[ -v args_options["--github-user"] ]] && GITHUB_USER="${args_options["--github-user"]}"

FROM_JOT=""
if [[ -v args_options["--from-jot"] ]]; then
  FROM_JOT="${args_options["--from-jot"]}"
fi

HOST="${1:-}"

if [[ -n "$FROM_JOT" ]]; then
  # --- Self-bootstrap mode ---
  if [[ -n "$HOST" ]]; then
    ansi::warn "${ERROR}--from-jot ignores the <host> argument (always operates locally).${RESET_ALL}"
  fi

  # Chicken-and-egg pre-flight: the bundle is encrypted, so we need both
  # AWS credentials and the decryption key locally before this can do anything.
  missing=()
  [[ ! -f "$HOME/.env" ]] && missing+=("~/.env (AWS credentials)")
  [[ ! -f "$HOME/.ssh/age.key" && ! -f "$HOME/.ssh/id_rsa" ]] && missing+=("~/.ssh/age.key or ~/.ssh/id_rsa (decryption key)")
  if (( ${#missing[@]} > 0 )); then
    ansi::warn "${ERROR}--from-jot pre-flight failed. Missing files:${RESET_ALL}"
    for m in "${missing[@]}"; do
      ansi::warn "  - $m"
    done
    ansi::warn ""
    ansi::warn "These secrets must arrive out-of-band (USB, password manager, scp from another machine)"
    ansi::warn "before --from-jot can pull anything from S3. See:"
    ansi::warn "  ${BOLD}https://github.com/uhop/dotfiles/wiki/Jot#bootstrap-sequence${RESET_ALL}"
    exit 1
  fi

  ansi::out "${INFO}Detecting local OS...${RESET_ALL}"
  REMOTE_OS=$(uname -s)
  REMOTE_ID="unknown"
  if [ "$REMOTE_OS" = "Linux" ] && [ -r /etc/os-release ]; then
    REMOTE_ID=$(. /etc/os-release && echo "${ID:-linux}")
  fi
  ansi::out "${OK}Local: $REMOTE_OS ($REMOTE_ID)${RESET_ALL}"
  ansi::out "${INFO}Bundle: ${BOLD}$FROM_JOT${RESET_ALL}"
else
  # --- Remote-operator mode (original) ---
  if [ -z "$HOST" ]; then
    ansi::warn "${ERROR}No host specified${RESET_ALL}"
    args::try_help
    exit 1
  fi

  ansi::out "${INFO}Checking SSH access to $HOST...${RESET_ALL}"
  if ! ssh -o BatchMode=yes -o ConnectTimeout=5 "$HOST" true 2>/dev/null; then
    ansi::warn "${ERROR}Cannot reach $HOST via passwordless SSH.${RESET_ALL}"
    ansi::err "Run ${BOLD}bootstrap-remote $HOST${RESET_ALL} first to set up SSH access."
    exit 1
  fi
  ansi::out "${OK}SSH access OK${RESET_ALL}"

  ansi::out "${INFO}Detecting remote OS...${RESET_ALL}"
  REMOTE_OS=$(ssh "$HOST" "uname -s" 2>/dev/null)
  REMOTE_ID="unknown"
  if [ "$REMOTE_OS" = "Linux" ]; then
    REMOTE_ID=$(ssh "$HOST" ". /etc/os-release 2>/dev/null && echo \$ID" 2>/dev/null || echo "linux")
  fi
  ansi::out "${OK}Remote: $REMOTE_OS ($REMOTE_ID)${RESET_ALL}"
fi

# --- Generate install script ---

REMOTE_SCRIPT="/tmp/install-dotfiles.sh"

generate_script() {
  cat <<'SCRIPT_HEADER'
#!/usr/bin/env bash
set -euo pipefail

BOLD="\033[1m"
GREEN="\033[32m"
CYAN="\033[36m"
YELLOW="\033[33m"
RED="\033[31m"
RESET="\033[0m"

step() {
  echo -e "\n${GREEN}${BOLD}=== $1 ===${RESET}"
}

info() {
  echo -e "${CYAN}$1${RESET}"
}

warn() {
  echo -e "${YELLOW}$1${RESET}"
}

run() {
  echo -e "${CYAN}$ $*${RESET}"
  "$@"
}

ask_yn() {
  local prompt="$1" default="${2:-y}"
  local yn
  if [ "$default" = "y" ]; then
    read -rp "$(echo -e "${YELLOW}${prompt} [Y/n]: ${RESET}")" yn
    yn="${yn:-y}"
  else
    read -rp "$(echo -e "${YELLOW}${prompt} [y/N]: ${RESET}")" yn
    yn="${yn:-n}"
  fi
  [[ "$yn" =~ ^[Yy] ]]
}
SCRIPT_HEADER

  # Platform-specific prerequisites
  case "$REMOTE_OS" in
    Linux)
      case "$REMOTE_ID" in
        ubuntu|debian|pop|linuxmint)
          cat <<'SCRIPT_DEBIAN'

step "Installing prerequisites"
info "These packages are needed to build tools from source and run chezmoi."
run sudo env DEBIAN_FRONTEND=noninteractive apt update
run sudo env DEBIAN_FRONTEND=noninteractive apt install -y build-essential curl git git-gui gitk micro

step "Installing Homebrew"
info "Homebrew manages CLI tools across Linux and macOS."
info "(chezmoi will manage your shell init; ignore Homebrew's 'Next steps' output.)"
if command -v brew &>/dev/null; then
  info "Homebrew is already installed, skipping."
else
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
  eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi
SCRIPT_DEBIAN
          ;;
        fedora|rhel|centos|rocky|almalinux|ol)
          cat <<'SCRIPT_RHEL'

step "Installing prerequisites"
info "These packages are needed to build tools from source and run chezmoi."
# Homebrew's documented Linux prereqs (https://docs.brew.sh/Homebrew-on-Linux#requirements):
#   gcc/g++/make + curl + git + file + ca-certificates.
# Minimal RHEL container images skip POSIX basics (tar/bzip2/xz) that Homebrew
# needs to extract bottles; add them explicitly here so bootstrap works from any base.
run sudo dnf install -y gcc gcc-c++ make curl git git-gui gitk \
  file ca-certificates tar gzip bzip2 xz unzip \
  procps-ng util-linux

step "Installing Homebrew"
info "Homebrew manages CLI tools across Linux and macOS."
info "(chezmoi will manage your shell init; ignore Homebrew's 'Next steps' output.)"
if command -v brew &>/dev/null; then
  info "Homebrew is already installed, skipping."
else
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
  eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi
SCRIPT_RHEL
          ;;
        *)
          cat <<SCRIPT_GENERIC_LINUX

step "Installing prerequisites"
warn "Unsupported Linux distribution: $REMOTE_ID"
warn "Install your distro's equivalents of:"
warn "  - a C/C++ toolchain and make (Debian: build-essential, Arch: base-devel, Alpine: build-base)"
warn "  - git, plus git's GUI/viewer if you want them (git-gui, gitk)"
warn "  - curl"
warn "  - a modern terminal editor (this project uses micro; nano/vim also fine)"
warn "Then install Homebrew: https://brew.sh/"
info "Press Enter to continue after installing prerequisites, or Ctrl+C to abort."
read -r

# Homebrew on Linux installs to /home/linuxbrew/.linuxbrew/ but doesn't get added to
# PATH until the shell is re-sourced. Try the standard location so users who just
# installed it (or have it in an unusual location) don't need to re-login first.
if ! command -v brew &>/dev/null; then
  if [ -x /home/linuxbrew/.linuxbrew/bin/brew ]; then
    eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
  elif [ -x "$HOME/.linuxbrew/bin/brew" ]; then
    eval "$("$HOME/.linuxbrew/bin/brew" shellenv)"
  fi
fi
if ! command -v brew &>/dev/null; then
  warn "Homebrew not found. Install it first: https://brew.sh/"
  exit 1
fi
SCRIPT_GENERIC_LINUX
          ;;
      esac
      ;;
    Darwin)
      cat <<'SCRIPT_MACOS'

step "Installing prerequisites"
if ! xcode-select -p &>/dev/null; then
  info "Installing Xcode Command Line Tools..."
  run xcode-select --install
  info "Wait for the installation to complete, then press Enter."
  read -r
else
  info "Xcode CLT already installed."
fi

step "Installing Homebrew"
if command -v brew &>/dev/null; then
  info "Homebrew is already installed, skipping."
else
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
  if [ -s /opt/homebrew/bin/brew ]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
  elif [ -s /usr/local/bin/brew ]; then
    eval "$(/usr/local/bin/brew shellenv)"
  fi
fi

step "Switching default shell to bash"
info "macOS ships an old bash. Installing a modern version via brew."
if ! brew list bash &>/dev/null; then
  run brew install bash
fi
BREW_BASH="$(brew --prefix)/bin/bash"
if ! grep -qF "$BREW_BASH" /private/etc/shells; then
  info "Adding $BREW_BASH to /etc/shells"
  echo "$BREW_BASH" | sudo tee -a /private/etc/shells
fi
if [ "$SHELL" != "$BREW_BASH" ]; then
  run chsh -s "$BREW_BASH"
fi
SCRIPT_MACOS
      ;;
    *)
      ansi::err "${ERROR}Unsupported OS: $REMOTE_OS${RESET_ALL}"
      exit 1
      ;;
  esac

  # Common: chezmoi install + apply
  cat <<SCRIPT_CHEZMOI

step "Installing chezmoi"
if command -v chezmoi &>/dev/null; then
  info "chezmoi is already installed, skipping."
else
  run brew install chezmoi
fi

step "Applying dotfiles"
info "chezmoi will ask a few questions (name, email, GitHub username, GUI)."
info "Accept the defaults or enter your own values."
echo
run chezmoi init --apply --recurse-submodules=false ${GITHUB_USER}

step "Done!"
info "The dotfiles are installed. A reboot is recommended."
SCRIPT_CHEZMOI

  if [[ -n "$FROM_JOT" ]]; then
    cat <<SCRIPT_JOT_DEPLOY

step "Deploying system files from jot bundle"
info "Pulling ${FROM_JOT} from S3 and installing per its embedded manifest."
# chezmoi added ~/.local/bin (jot, jot-deploy) and brew added aws to PATH, but
# those changes only take effect in new shells. Source them into this one.
export PATH="\$HOME/.local/bin:\$PATH"
if [ -s "\$HOME/.bashrc" ]; then
  # shellcheck disable=SC1091
  . "\$HOME/.bashrc" 2>/dev/null || true
fi

if ! command -v jot-deploy >/dev/null 2>&1; then
  warn "jot-deploy not found — chezmoi may not have finished installing it."
  warn "Run manually after dotfiles install completes:"
  warn "  jot-deploy ${FROM_JOT}            # report-only (default)"
  warn "  jot-deploy ${FROM_JOT} --apply    # install"
else
  info "Report (dry-run) first:"
  run jot-deploy "${FROM_JOT}"
  echo
  if ask_yn "Apply these changes?"; then
    run jot-deploy "${FROM_JOT}" --apply
  else
    info "Skipped --apply. Re-run manually when ready: jot-deploy ${FROM_JOT} --apply"
  fi
fi
SCRIPT_JOT_DEPLOY
  fi

  cat <<'SCRIPT_REBOOT'
echo
if ask_yn "Reboot now?"; then
  sudo reboot
else
  echo -e "${YELLOW}Remember to reboot before using the new environment.${RESET}"
fi
SCRIPT_REBOOT
}

# --- Generate, upload (or write locally), instruct ---

ansi::out "${INFO}Generating install script...${RESET_ALL}"
SCRIPT_CONTENT=$(generate_script)

if [[ -n "$FROM_JOT" ]]; then
  ansi::out "${INFO}Writing $REMOTE_SCRIPT...${RESET_ALL}"
  echo "$SCRIPT_CONTENT" > "$REMOTE_SCRIPT"
  chmod +x "$REMOTE_SCRIPT"
  ansi::out "${OK}Written${RESET_ALL}"

  echo
  ansi::out "${OK}=================================================${RESET_ALL}"
  ansi::out "${OK} Install script is ready: $REMOTE_SCRIPT${RESET_ALL}"
  ansi::out "${OK}=================================================${RESET_ALL}"
  echo
  ansi::out "${DIM}What to expect (~5-15 min depending on network):${RESET_ALL}"
  ansi::out "${DIM}  - one sudo password prompt early (for Homebrew's installer)${RESET_ALL}"
  ansi::out "${DIM}  - four chezmoi questions: hasGui (y/n), Full name, Email, GitHub username${RESET_ALL}"
  ansi::out "${DIM}    (defaults are fine if you're $GITHUB_USER)${RESET_ALL}"
  ansi::out "${DIM}  - jot-deploy report, then 'Apply these changes?' prompt for $FROM_JOT${RESET_ALL}"
  ansi::out "${DIM}  - a final 'Reboot now?' prompt (default yes)${RESET_ALL}"
  echo

  ansi::prompt "Run ${BOLD}$REMOTE_SCRIPT${RESET_ALL} now? [Y/n] "
  read -r response
  case "${response^^}" in
    N|NO|NOPE)
      ansi::out "Run it manually when ready: ${BOLD}$REMOTE_SCRIPT${RESET_ALL}"
      ;;
    *)
      exec "$REMOTE_SCRIPT"
      ;;
  esac
else
  ansi::out "${INFO}Uploading to $HOST:$REMOTE_SCRIPT ...${RESET_ALL}"
  echo "$SCRIPT_CONTENT" | ssh "$HOST" "cat > $REMOTE_SCRIPT && chmod +x $REMOTE_SCRIPT"
  ansi::out "${OK}Uploaded${RESET_ALL}"

  echo
  ansi::out "${OK}=================================================${RESET_ALL}"
  ansi::out "${OK} Install script is ready on $HOST${RESET_ALL}"
  ansi::out "${OK}=================================================${RESET_ALL}"
  echo
  ansi::out "Open another terminal and run:"
  echo
  ansi::out "  ${BOLD}ssht $HOST${RESET_ALL}"
  ansi::out "  ${BOLD}$REMOTE_SCRIPT${RESET_ALL}"
  echo
  ansi::out "${DIM}What to expect (~5-15 min depending on network):${RESET_ALL}"
  ansi::out "${DIM}  - one sudo password prompt early (for Homebrew's installer)${RESET_ALL}"
  ansi::out "${DIM}  - four chezmoi questions: hasGui (y/n), Full name, Email, GitHub username${RESET_ALL}"
  ansi::out "${DIM}    (defaults are fine if you're $GITHUB_USER)${RESET_ALL}"
  ansi::out "${DIM}  - a final 'Reboot now?' prompt (default yes)${RESET_ALL}"
fi
