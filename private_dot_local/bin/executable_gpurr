#!/usr/bin/env bash

set -euCo pipefail
shopt -s expand_aliases

if ! command -v git >/dev/null 2>&1; then
  echo "gpurr: git is required but is not installed" >&2
  exit 1
fi

echoRun() {
  echo -e "\033[36m$@\033[0m"
  eval "$@"
}

echoRun "git pull --recurse-submodules"
echoRun "git submodule foreach git-pull-main"
