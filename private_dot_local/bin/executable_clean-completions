#!/usr/bin/env bash

set -euCo pipefail
shopt -s expand_aliases

. ~/.local/libs/bootstrap.sh

script_name=$(basename "$0")

args::program "$script_name" "1.0.0" "Remove bash completion files generated by options.bash"

args_program_header="${BOLD}clean-completions${RESET_BOLD} finds and removes bash completion files
generated by options.bash in ~/.local/share/bash-completion/completions.

Identifies generated files by the signature comment:
  # options.bash-completion v<N>"

args_program_usage="${BOLD}clean-completions${RESET_BOLD}          # List files that would be removed (dry run)
${BOLD}clean-completions${RESET_BOLD} remove   # Remove the files"

args_program_default_command="list"

args::option "list, l" "List completion files that would be removed"
args::option "remove, r" "Remove the completion files"
args::option "-v, --version" "Show version"
args::option "-h, --help" "Show help"

args::parse "$@"
set -- "${args_cleaned[@]}"

COMP_DIR="${HOME}/.local/share/bash-completion/completions"

if [[ ! -d "$COMP_DIR" ]]; then
  ansi::out "No completion directory: $COMP_DIR"
  exit 0
fi

files=()
while IFS= read -r -d '' f; do
  files+=("$f")
done < <(grep -rl --null 'options\.bash-completion v' "$COMP_DIR" 2>/dev/null || true)

if [[ ${#files[@]} -eq 0 ]]; then
  ansi::out "No options.bash completion files found in ${BOLD}$COMP_DIR${RESET_ALL}"
  exit 0
fi

if [[ "$args_command" == "remove" ]]; then
  for f in "${files[@]}"; do
    rm -v "$f"
  done
  ansi::out "${BOLD}${FG_GREEN}Removed ${#files[@]} file(s).${RESET_ALL} Reload your shell (${BOLD}exec bash${RESET_BOLD}) to apply."
else
  ansi::out "Found ${BOLD}${#files[@]}${RESET_BOLD} options.bash completion file(s):"
  for f in "${files[@]}"; do
    ansi::out "  ${FG_CYAN}$f${RESET_ALL}"
  done
  echo
  ansi::out "Run '${BOLD}$script_name remove${RESET_BOLD}' to delete them."
fi
