#!/usr/bin/env bash

set -euCo pipefail
shopt -s expand_aliases

. ~/.local/libs/bootstrap.sh
. ~/.local/libs/maintenance.sh

script_dir="$(dirname "$(readlink -f "$0")")"
script_name=$(basename "$0")

args::program "$script_name" "1.0" "Clean unused versions and caches of software"
args_program_usage="${args_help_program}${args_program_name}${args_help_reset} ${args_help_option}[options]${args_help_reset}"

args::option "-y, --yes" "Assume \"yes\" to all prompts"
args::option "-v, --version" "Show version"
args::option "-h, --help" "Show help"
args::option "--bash-completion" "Show bash completion"

args::parse "$@"
set -- "${args_cleaned[@]}"

if groups "$(id -un)" | grep -qE '\b(sudo|admin|wheel)\b' || sudo -n true 2>/dev/null; then
  hasSudo=0
else
  hasSudo=1
fi

WARN="${BOLD}${BRIGHT_WHITE}${BG_BLUE}"
PROMPT="${BOLD}${FG_CYAN}"

ASSUME_YES=''
if [[ -v args_options["-y"] ]]; then ASSUME_YES='-y'; fi

# Recovery path: if a previous run was interrupted mid-cleanup, finish it
# now before doing anything else. No-op if no marker exists.
maintenance::cleanup_apparmor_if_marked

{{ if eq .osIdLike "linux-debian" -}}
apt_snapshot=$(maintenance::snapshot_apt)
if [ "$hasSudo" -eq 0 ]; then
  ansi::out "${WARN}apt may require sudo: expect asking for the sudo password.${RESET_ALL}"
  echoRun --bold sudo apt autoremove $ASSUME_YES
  echoRun --bold sudo apt autoclean $ASSUME_YES
fi
maintenance::check_apt_since "$apt_snapshot"
{{- else if or (eq .osIdLike "linux-rhel") (eq .osIdLike "linux-fedora") -}}
if [ "$hasSudo" -eq 0 ]; then
  ansi::out "${WARN}dnf may require sudo: expect asking for the sudo password.${RESET_ALL}"
  echoRun --bold sudo dnf autoremove $ASSUME_YES
  echoRun --bold sudo dnf clean all
fi
{{- end }}

if command -v flatpak &> /dev/null; then
  echoRun --bold flatpak uninstall --unused $ASSUME_YES
fi

echoRun --bold brew autoremove
echoRun --bold brew cleanup --prune=all --scrub

if command -v docker &> /dev/null; then
  echoRun --bold docker system prune -a ${ASSUME_YES/-y/-f}
fi

. "$(brew --prefix nvm)/nvm.sh"
ansi::out "${PROMPT}Update major node versions...${RESET_ALL}"
update-node-versions.js
ansi::out "${PROMPT}Trim minor node versions...${RESET_ALL}"
trim-node-versions.js

