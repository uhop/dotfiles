#!/usr/bin/env bash

set -euCo pipefail
shopt -s expand_aliases

. ~/.local/libs/bootstrap.sh

script_name=$(basename "$0")

# --- Tool detection (before options.bash so errors are immediate) ---

if ! command -v docker &>/dev/null; then
  echo "$script_name: docker is not installed" >&2
  exit 1
fi

if ! command -v jq &>/dev/null; then
  echo "$script_name: jq is not installed" >&2
  exit 1
fi

# --- Program definition ---

args::program "$script_name" "1.2.0" "Manage Docker Compose setups" "https://github.com/uhop/dotfiles/wiki/Dcm"

args_program_header="${BOLD}dcm${RESET_BOLD} manages Docker Compose service lifecycles
with automatic AppArmor recovery on Linux."

args_program_usage="${BOLD}dcm${RESET_BOLD}                          # Update current dir (pull + up)
${BOLD}dcm${RESET_BOLD} update ~/servers/monitor # Update specific setup
${BOLD}dcm${RESET_BOLD} status ~/servers         # Status for all setups under ~/servers
${BOLD}dcm${RESET_BOLD} prune                    # Prune unused Docker images globally"

args_program_default_command="update"

args::option "update, up, u" "Pull images, recreate changed containers" "dir" "opt"
args::option "down, d" "Compose down (stop and remove)" "dir" "opt"
args::option "stop" "Compose stop (pause without removing)" "dir" "opt"
args::option "start" "Compose start (resume stopped services)" "dir" "opt"
args::option "restart" "Compose restart" "dir" "opt"
args::option "status, s" "Compose ps (show running services)" "dir" "opt"
args::option "prune, p" "Prune unused Docker images globally"
args::option "rollback, r" "Roll back to previous image versions (not yet implemented)" "dir" "opt"

args::option "--force" "Pass --force-recreate to docker compose up"
args::option "-n, --dry-run" "Show commands without running"
args::option "-v, --version" "Show version"
args::option "-h, --help" "Show help"
args::option "--bash-completion" "Show bash completion"

args::parse "$@"
set -- "${args_cleaned[@]}"

# --- Defaults and option extraction ---

DRY_RUN=0
[[ -v args_options["-n"] ]] && DRY_RUN=1

OPT_FORCE=0
[[ -v args_options["--force"] ]] && OPT_FORCE=1

IS_LINUX=0
[[ "$(uname -s)" == "Linux" ]] && IS_LINUX=1

# --- Helpers ---

find_compose_file() {
  local dir="$1"
  local name
  for name in compose.yaml compose.yml docker-compose.yaml docker-compose.yml; do
    if [ -f "$dir/$name" ]; then
      echo "$dir/$name"
      return
    fi
  done
  echo ""
}

validate_compose_dir() {
  local dir="$1"
  if [ ! -d "$dir" ]; then
    ansi::err "${ERROR}'$dir' is not a directory${RESET_ALL}"
    return 1
  fi
  local cf
  cf="$(find_compose_file "$dir")"
  if [ -z "$cf" ]; then
    ansi::err "${ERROR}No compose file found in '$dir'${RESET_ALL}"
    return 1
  fi
  return 0
}

is_apparmor_error() {
  local stderr_text="$1"
  if [ "$IS_LINUX" -eq 0 ]; then
    return 1
  fi
  if echo "$stderr_text" | grep -qi "permission denied" && \
     echo "$stderr_text" | grep -qiE "cannot (kill|stop) container"; then
    return 0
  fi
  return 1
}

# Global temp file for cleanup (set by run_compose)
_RUN_COMPOSE_TEMP_FILE=""

# Cleanup function for temp files
_cleanup_run_compose() {
  if [ -n "$_RUN_COMPOSE_TEMP_FILE" ] && [ -f "$_RUN_COMPOSE_TEMP_FILE" ]; then
    rm -f "$_RUN_COMPOSE_TEMP_FILE"
  fi
}

# Run a docker compose command with AppArmor recovery.
# Must be called from within the target compose directory.
# Captures stderr via tee so user sees errors in real-time; on failure checks for AppArmor pattern and retries once.
run_compose() {
  _RUN_COMPOSE_TEMP_FILE="$(mktemp)"
  trap _cleanup_run_compose EXIT

  if [ "$DRY_RUN" -eq 1 ]; then
    ansi::out "${INFO}[dry-run] docker compose $*${RESET_ALL}"
    return 0
  fi

  local rc=0
  echoRunTee /dev/null "$_RUN_COMPOSE_TEMP_FILE" docker compose "$@" || rc=$?

  if [ "$rc" -eq 0 ]; then
    return 0
  fi

  local stderr_text
  stderr_text="$(cat "$_RUN_COMPOSE_TEMP_FILE")"

  if is_apparmor_error "$stderr_text"; then
    ansi::warn "${WARN}AppArmor conflict detected, clearing stale profiles...${RESET_ALL}"
    sudo aa-remove-unknown || true

    # Retry once
    rc=0
    echoRunTee /dev/null "$_RUN_COMPOSE_TEMP_FILE" docker compose "$@" || rc=$?

    if [ "$rc" -eq 0 ]; then
      ansi::out "${OK}Retry succeeded after AppArmor fix${RESET_ALL}"
      return 0
    fi
  fi

  return "$rc"
}

run_or_dry() {
  if [ "$DRY_RUN" -eq 1 ]; then
    ansi::out "${INFO}[dry-run] $*${RESET_ALL}"
  else
    echoRun "$@"
  fi
}

# Capture a snapshot of image IDs keyed by container name.
# Output: lines of "container_name image_id" pairs.
snapshot_images() {
  docker compose images --format json 2>/dev/null \
    | jq -r '.[] | "\(.ContainerName) \(.ID)"' 2>/dev/null || true
}

# Compare before/after snapshots and report changes.
# Args: $1 = before snapshot (string), $2 = after snapshot (string)
# Output: lines to stderr describing what changed.
report_changes() {
  local before="$1" after="$2"
  local -A before_map=() after_map=()
  local name id

  while read -r name id; do
    [[ -n "$name" ]] && before_map["$name"]="$id"
  done <<< "$before"

  while read -r name id; do
    [[ -n "$name" ]] && after_map["$name"]="$id"
  done <<< "$after"

  local updated=() unchanged=()
  for name in "${!after_map[@]}"; do
    if [[ -v before_map["$name"] && "${before_map[$name]}" == "${after_map[$name]}" ]]; then
      unchanged+=("$name")
    else
      updated+=("$name")
    fi
  done

  if [[ ${#updated[@]} -eq 0 ]]; then
    ansi::out "  ${INFO}no images changed${RESET_ALL}"
  else
    for name in "${updated[@]}"; do
      ansi::out "  ${OK}updated:${RESET_ALL} $name"
    done
    for name in "${unchanged[@]}"; do
      ansi::out "  unchanged: $name"
    done
  fi
}

# Show a compact one-line-per-service status summary. Includes stopped/exited
# services (-a) so a fully-down stack is visible as ✗ lines instead of silence.
# Uses ASCII Unit Separator (\x1f) instead of \t because bash's `read` collapses
# consecutive whitespace IFS chars, which would shift fields when Health is empty.
report_status() {
  local service state health status printed=0
  while IFS=$'\x1f' read -r service state health status; do
    [[ -z "$service" ]] && continue
    printed=1
    case "$state" in
      running)
        if [[ "$health" == "unhealthy" ]]; then
          ansi::out "  ${WARN}$service${RESET_ALL}: running (unhealthy)"
        else
          ansi::out "  ${OK}✓${RESET_ALL} $service: $status"
        fi
        ;;
      *)
        local label="$state"
        [[ -n "$health" ]] && label="$state ($health)"
        ansi::out "  ${ERROR}✗${RESET_ALL} $service: $label — $status"
        ;;
    esac
  done < <(docker compose ps -a --format json 2>/dev/null \
    | jq -r '"\(.Service)\u001f\(.State)\u001f\(.Health // "")\u001f\(.Status)"')

  if [[ "$printed" -eq 0 ]]; then
    ansi::out "  ${INFO}(no services)${RESET_ALL}"
  fi
}

# --- Commands ---
# Each cmd_* function cd's into the target dir so docker compose
# auto-detects the compose file. Runs in a subshell to preserve cwd.

cmd_update() (
  cd "$1"
  local dir_name
  dir_name="$(basename "$(pwd)")"

  ansi::out "${OK}Updating: ${BOLD}$dir_name${RESET_ALL}"

  if [ "$DRY_RUN" -eq 1 ]; then
    ansi::out "${INFO}[dry-run] docker compose images (snapshot before)${RESET_ALL}"
    ansi::out "${INFO}[dry-run] docker compose pull${RESET_ALL}"
    ansi::out "${INFO}[dry-run] docker compose images (snapshot after)${RESET_ALL}"
  else
    local before after
    before="$(snapshot_images)"
    echoRun docker compose pull || return $?
    after="$(snapshot_images)"
    report_changes "$before" "$after"
  fi
  if [ "$OPT_FORCE" -eq 1 ]; then
    run_compose up -d --force-recreate || return $?
  else
    run_compose up -d || return $?
  fi

  report_status
  ansi::out "${OK}Done: ${BOLD}$dir_name${RESET_ALL}"
)

cmd_down() (
  cd "$1"
  local dir_name
  dir_name="$(basename "$(pwd)")"

  ansi::out "${OK}Bringing down: ${BOLD}$dir_name${RESET_ALL}"
  run_compose down || return $?
  ansi::out "${OK}Done: ${BOLD}$dir_name${RESET_ALL}"
)

cmd_stop() (
  cd "$1"
  local dir_name
  dir_name="$(basename "$(pwd)")"

  ansi::out "${INFO}Stopping: ${BOLD}$dir_name${RESET_ALL}"
  run_compose stop || return $?
  ansi::out "${OK}Done: ${BOLD}$dir_name${RESET_ALL}"
)

cmd_start() (
  cd "$1"
  local dir_name
  dir_name="$(basename "$(pwd)")"

  ansi::out "${INFO}Starting: ${BOLD}$dir_name${RESET_ALL}"
  run_compose start || return $?
  ansi::out "${OK}Done: ${BOLD}$dir_name${RESET_ALL}"
)

cmd_restart() (
  cd "$1"
  local dir_name
  dir_name="$(basename "$(pwd)")"

  ansi::out "${INFO}Restarting: ${BOLD}$dir_name${RESET_ALL}"
  run_compose restart || return $?
  ansi::out "${OK}Done: ${BOLD}$dir_name${RESET_ALL}"
)

cmd_status() (
  cd "$1"
  local dir_name
  dir_name="$(basename "$(pwd)")"

  ansi::out "${INFO}Status: ${BOLD}$dir_name${RESET_ALL}"
  report_status
)

cmd_prune() {
  if [ "$DRY_RUN" -eq 1 ]; then
    ansi::out "${INFO}[dry-run] docker image prune -af${RESET_ALL}"
  else
    echoRun docker image prune -af
  fi
}

# --- Discover setups ---
# If target_dir contains a compose file, return just that dir.
# Otherwise, return all immediate subdirs that contain compose files.
find_compose_dirs() {
  local target_dir="$1"

  if [ -n "$(find_compose_file "$target_dir")" ]; then
    # Target dir has a compose file - use it directly
    echo "$target_dir"
    return 0
  fi

  # No compose file in target - check immediate subdirectories
  local dirs=()
  local d
  for d in "$target_dir"/*/; do
    [ -d "$d" ] || continue
    if [ -n "$(find_compose_file "${d%/}")" ]; then
      dirs+=("${d%/}")
    fi
  done

  if [ ${#dirs[@]} -eq 0 ]; then
    ansi::err "${ERROR}No compose file found in '$target_dir' or its immediate subdirectories${RESET_ALL}"
    return 1
  fi

  printf '%s\n' "${dirs[@]}"
}

# --- Run command on one or more directories ---

dispatch() {
  local cmd="$1"
  shift
  local target_dir="${1:-.}"
  local succeeded=0 failed=0 failures=""

  local setups
  setups="$(find_compose_dirs "$target_dir")" || exit 1

  local total
  total="$(echo "$setups" | wc -l)"

  if [ "$total" -gt 1 ]; then
    ansi::out "${INFO}Found ${BOLD}$total${RESET_BOLD} compose setup(s) under ${BOLD}$target_dir${RESET_ALL}"
  fi

  while IFS= read -r dir; do
    # Blank line before each iteration in multi-dir runs (separates the
    # "Found N..." header from the first stack and stacks from each other).
    # Single-dir runs stay tight: no leading blank.
    [[ "$total" -gt 1 ]] && echo
    if "cmd_$cmd" "$dir"; then
      succeeded=$((succeeded + 1))
    else
      failed=$((failed + 1))
      failures="${failures}\n  - $(basename "$dir")"
    fi
  done <<< "$setups"

  if [ "$total" -gt 1 ]; then
    echo
    ansi::out "${OK}Results: ${BOLD}$succeeded${RESET_BOLD} succeeded, ${BOLD}$failed${RESET_BOLD} failed${RESET_ALL}"
    if [ "$failed" -gt 0 ]; then
      ansi::warn "${WARN}Failed:${failures}${RESET_ALL}"
    fi
  fi
}

# --- Main ---

cmd="$args_command"

# Skip explicit command word from positional args
if [[ -n "${1:-}" && -v "args_aliases[${1}]" && "${1:-}" != -* ]]; then
  shift
fi

# Resolve target directory from remaining args
target_dir="${1:-}"

case "$cmd" in
  update)  dispatch update "$target_dir" ;;
  down)    dispatch down "$target_dir" ;;
  stop)    dispatch stop "$target_dir" ;;
  start)   dispatch start "$target_dir" ;;
  restart) dispatch restart "$target_dir" ;;
  status)  dispatch status "$target_dir" ;;
  prune)   cmd_prune ;;
  rollback)
    ansi::warn "${WARN}rollback is not yet implemented${RESET_ALL}"
    exit 1
    ;;
  *)
    ansi::warn "${ERROR}Unknown command: $cmd${RESET_ALL}"
    exit 1
    ;;
esac
