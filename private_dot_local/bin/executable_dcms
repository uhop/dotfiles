#!/usr/bin/env bash
# dcms — invoke `dcm` over the whole `~/servers` tree, no-op if the
# tree doesn't exist on this host. Forwards an optional command:
#
#   dcms          → dcm ~/servers  (default: update)
#   dcms daily    → dcm daily ~/servers
#   dcms weekly   → dcm weekly ~/servers
#   dcms check    → dcm check ~/servers
#
# The host-skip behavior matters for fleet-wide playbooks where some
# hosts (e.g. dev laptops) don't have a ~/servers tree.

set -euCo pipefail
shopt -s expand_aliases

. ~/.local/libs/bootstrap.sh

deps::need dcm

if [ ! -d ~/servers ]; then
  echo -e "No \033[1m~/servers\033[0m found: skipping \033[1mdcm\033[0m."
  exit 0
fi

# Skip when the Docker daemon isn't reachable. On a Mac, Docker Desktop is
# started on demand, so the `docker` CLI exists but the daemon is often
# down — `dcm` would otherwise fail at `docker compose pull`/`up`. Mirrors
# the daemon guard in `cln`. (`docker info` also returns non-zero when the
# CLI is absent entirely, which is fine: no daemon → skip.)
if ! docker info &> /dev/null; then
  echo -e "Docker daemon not running: skipping \033[1mdcm\033[0m."
  exit 0
fi

if [ $# -gt 0 ]; then
  echoRun --bold dcm "$@" ~/servers
else
  echoRun --bold dcm ~/servers
fi
