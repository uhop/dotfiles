# This is Git's per-user configuration file.
[user]
	name = {{ .name }}
	email = {{ .email }}
[github]
  user = {{ .githubUsername }}
[core]
	pager = delta
	# editor intentionally left unset — git falls back to $EDITOR / $VISUAL
	# / `vi` in order. The bashrc picks the best available (micro / nvim /
	# vim / vi), so hosts without micro still get a sane default.
	autocrlf = input
	whitespace = trailing-space,-space-before-tab,cr-at-eol
[interactive]
	diffFilter = delta --color-only
[init]
	defaultBranch = main
[pull]
	rebase = false
[color]
	ui = true
[color "diff-highlight"]
	oldNormal = red bold
	oldHighlight = red bold 52
	newNormal = green bold
	newHighlight = green bold 22
[color "diff"]
	meta = 11
	frag = magenta bold
	func = 146 bold
	commit = yellow bold
	old = red bold
	new = green bold
	whitespace = red reverse
# Delta (syntax-highlighting pager). Default: inline, laptop-friendly.
# Wide (side-by-side) layout available on demand via the `dw` alias below,
# or ad-hoc as `git -c delta.features=wide <cmd>`.
[delta]
	syntax-theme = GitHub
	navigate = true
	line-numbers = true
	side-by-side = false
[delta "wide"]
	side-by-side = true
	line-numbers = true
[diff]
	colorMoved = default
# Difftastic is an on-demand structural (AST) diff tool, exposed via
# `git difftool` / the `dft` alias. Not wired into `git diff`, which stays
# line-based through delta — structural diffs are the exception, not the rule.
	tool = difftastic
[difftool]
	prompt = false
[difftool "difftastic"]
	cmd = difft "$LOCAL" "$REMOTE"
[pretty]
  better-oneline = "format:%C(auto)%h%d %s %Cgreen(%cr) %Cblue[%cn]"
  detailed-commit = "format:%C(bold)commit:%Creset %C(bold yellow)%h%Creset %C(yellow)<%H>%Creset %C(auto)%d%Creset%n%C(bold)date:%Creset   %C(bold green)%cd%Creset %C(green)%cr%Creset%n%C(bold)author:%Creset %C(bold blue)%an%Creset %Cblue<%ae>%Creset%n%n%C(cyan)%s%Creset%n%n%C(auto)%b%Creset"
[alias]
	patch = !git --no-pager diff --no-color
	# `dw` = wide (side-by-side) diff via delta's `wide` feature — handy on
	# a big monitor. For wide on any other command, use `-c delta.features=wide`
	# ad-hoc, e.g. `git -c delta.features=wide show`.
	dw = "-c delta.features=wide diff"
	# Structural (AST) diff via difftastic. Separate from `git diff` — that
	# stays line-based through delta.
	dft = difftool
	ls = log --oneline --pretty=better-oneline
	ll = log --oneline --pretty=better-oneline --numstat
	lsf = log --oneline --pretty=better-oneline --graph --follow
	tree = log --oneline --pretty=better-oneline --all --graph
	# re = restore
	# sw = switch
	force-push = push --force-with-lease
	# pick = cherry-pick
	# type = cat-file -t
	# dump = cat-file -p
	aliases = "!f() { git config --get-regexp ^alias\\. | sort; }; f"
	authors-list = shortlog -e -s -n
	authors-count = shortlog -s -n
	sl = log --graph --pretty=detailed-commit
	last = log -1 --pretty=detailed-commit
	trim = "!f() { git branch | grep -v \"main\" | grep -v \"master\" | grep -v \"^*\" | xargs git branch -D; git remote prune origin; }; f"
	merge-span = "!f() { echo $(git log -1 $2 --merges --pretty=format:%P | cut -d' ' -f1)$1$(git log -1 $2 --merges --pretty=format:%P | cut -d' ' -f2); }; f"
	merge-log  = "!git ls `git merge-span .. $1`"
	merge-diff = "!git diff `git merge-span ... $1`"
	precommit = diff --cached --diff-algorithm=minimal -w
	unmerged = diff --name-only --diff-filter=U
	save = !git add -A && git commit -m 'chore: savepoint'
[gui]
	fontui = -family \"Hack Nerd Font Mono\" -size 14 -weight normal -slant roman -underline 0 -overstrike 0
	fontdiff = -family \"Hack Nerd Font Mono\" -size 14 -weight normal -slant roman -underline 0 -overstrike 0
[hub]
	protocol = ssh
[remote "origin"]
	prune = true
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
{{- if eq .githubUsername "uhop" }}
[url "git@github.com:uhop/"]
	pushInsteadOf = https://github.com/uhop/
{{- end }}
[push]
	autoSetupRemote = true
