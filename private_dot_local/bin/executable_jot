#!/usr/bin/env bash

set -euCo pipefail
shopt -s expand_aliases

. ~/.local/libs/bootstrap.sh

script_dir="$(dirname "$(readlink -f "$0")")"
script_name=$(basename "$0")

deps::need aws

args::program "$script_name" "1.2.0" "Encrypted notes editor using S3" "https://github.com/uhop/dotfiles/wiki/Jot"

args_program_header="${BOLD}Jot${RESET_BOLD} reads and writes notes as text files using S3 as storage.
Files are decoded by extension (e.g. ${BOLD}.gz.age${RESET_BOLD} is decrypted then decompressed)."

args_program_default_command="edit"

args::option "edit, e" "Edit file" "file_name"
args::option "list, l" "List available files" "prefix"
args::option "get, g" "Get file to the current directory" "file_name"
args::option "put, p" "Put local file to the S3 bucket" "from_name to_name"
args::option "delete, del, rm, d" "Delete file in the S3 bucket" "file_name"
args::option "rename, mv, r" "Rename file in the S3 bucket" "from_name to_name"

args::option "-x, --exact" "Exact file name match"
args::option "-y, --yes" "Create new file without confirmation"
args::option "-n, --no" "Don't create new file"
args::option "-a, --as" "Codec chain to apply on put (e.g. gz.age); tar auto-prepended for directories" "chain"
args::option "-f, --for" "Encrypt to named recipients (comma-separated); see JOT_RECIPIENTS_DIR" "names"
args::option "-v, --version" "Show version"
args::option "-h, --help" "Show help"
args::option "--bash-completion" "Show bash completion"

args::parse "$@"
set -- "${args_cleaned[@]}"

TMPDIR=$(mktemp -d)
trap 'rm -rf -- "$TMPDIR"' EXIT

# Codec → required binary. Returns non-zero for unknown codecs so callers
# can ignore them (probe path stays cheap).
jot::codec_tool() {
  case "$1" in
    age) echo age ;;
    br)  echo brotli ;;
    bz2) echo bzip2 ;;
    gz)  echo gzip ;;
    xz)  echo xz ;;
    zst) echo zstd ;;
    tar) echo tar ;;
    *)   return 1 ;;
  esac
}

if [ -z "${JOT_AWS_S3_BUCKET:-}" ]; then
  if [ -z "${GITHUB_USERNAME:-}" ]; then
    ansi::err "${ERROR}No AWS bucket name. ${REVERSE}JOT_AWS_S3_BUCKET${RESET_REVERSE} defaults to ${BOLD}\${GITHUB_USERNAME}-notes${RESET_BOLD}, but ${REVERSE}GITHUB_USERNAME${RESET_REVERSE} is also unset. Re-run ${BOLD}chezmoi init${RESET_BOLD} and answer the GitHub username prompt, or set ${BOLD}JOT_AWS_S3_BUCKET${RESET_BOLD} directly in ~/.env.${RESET_ALL}"
  else
    ansi::err "${ERROR}No AWS bucket name is specified by \"${REVERSE}JOT_AWS_S3_BUCKET${RESET_REVERSE}\". Please set it to an accessible bucket for notes.${RESET_ALL}"
  fi
  exit 1
fi

ansi::out "Using AWS bucket: ${BOLD}${JOT_AWS_S3_BUCKET}${RESET_BOLD}"
ansi::out "Testing access to the bucket..."
if ! aws s3api head-bucket --bucket "$JOT_AWS_S3_BUCKET" &>/dev/null; then
  ansi::err "${ERROR}AWS bucket \"${REVERSE}$JOT_AWS_S3_BUCKET${RESET_REVERSE}\" is not accessible or does not exist. Please verify.${RESET_ALL}"
  exit 1
fi

if [ -z "${1:-}" ] || [[ "$args_command" == "list" ]]; then
  prefix="${2:-}"
  echo
  ansi::out "Listing available files:"
  echo
  if ! aws s3 ls "s3://$JOT_AWS_S3_BUCKET/$prefix"; then
    ansi::warn "${ERROR}The previous command failed: make sure that the bucket ${REVERSE}${JOT_AWS_S3_BUCKET}${RESET_REVERSE} exists and accessible.${RESET_ALL}"
    exit 1
  fi
  echo
  ansi::out "To edit a file: jot ${ITALIC}file_name${RESET_ALL}"
  exit 0
fi

# Skip explicit command word from positional args
if [[ -n "${1:-}" && -v "args_aliases[${1}]" && "${1:-}" != -* ]]; then
  shift
fi

asset="${1:-}"
if [[ "$args_command" == "put" ]]; then
  local_file_name="$asset"
  asset="${2:-}"
fi
if [ -z "$asset" ]; then
    ansi::err "${ERROR}No file name is specified for file operations.${RESET_ALL}"
  exit 1
fi

# --- put: directory detection + --as chain handling ---
# Decide the final asset name BEFORE the decode loop builds the extensions list,
# so directories and --as chains both flow through the standard codec pipeline.

clean_chain() {
  # Lenient parsing of a codec chain: strip leading/trailing dots, collapse runs.
  local s="$1"
  s="$(echo "$s" | sed -E 's/^\.+//; s/\.+$//; s/\.{2,}/./g')"
  echo "$s"
}

asset_has_extension() {
  # Returns 0 if the given extension appears anywhere in the dotted asset name.
  local name="$1"
  local target="$2"
  while [[ "$name" == *.* ]]; do
    [[ "${name##*.}" == "$target" ]] && return 0
    name="${name%.*}"
  done
  return 1
}

if [[ "$args_command" == "put" ]]; then
  is_dir=no
  if [[ -d "$local_file_name" ]]; then
    is_dir=yes
  fi

  if [[ -v args_options["-a"] ]]; then
    chain="$(clean_chain "${args_options["-a"]}")"
    if [[ -z "$chain" ]]; then
      ansi::err "${ERROR}--as value is empty after stripping dots.${RESET_ALL}"
      exit 1
    fi
    if [[ "$is_dir" == yes ]] && [[ "${chain%%.*}" != "tar" ]]; then
      chain="tar.${chain}"
    fi
    asset="${asset}.${chain}"
  elif [[ "$is_dir" == yes ]] && ! asset_has_extension "$asset" "tar"; then
    ansi::warn "Source is a directory; appending ${BOLD}.tar${RESET_BOLD} to the asset name."
    asset="${asset}.tar"
  fi
fi

# check if the asset exists
FOUND=yes
ansi::out "Checking access to the file..."
if ! aws s3api head-object --bucket "$JOT_AWS_S3_BUCKET" --key "$asset" &>/dev/null; then
  FOUND=no
fi

# looking for a suitable file using the asset name as a prefix
if [[ "$FOUND" == "no" ]] && ! [[ -v args_options["-x"] ]] && [[ "$args_command" != "put" ]] && [[ "$args_command" != "delete" ]] ; then
    ansi::out "Looking for a prefix ${BOLD}${asset}.${RESET_BOLD}"
    listing=$(aws s3 ls "s3://${JOT_AWS_S3_BUCKET}/${asset}" || echo "")
    set +e
    IFS=$'\n' read -r -d '' -a lines <<< "$listing"
    set -e
    unset listing
    if [[ "${#lines[@]}" -eq 1 ]]; then
      if [[ "${lines[0]}" =~ ^[^[:space:]]+[[:space:]]+[^[:space:]]+[[:space:]]+[^[:space:]]+[[:space:]]+(.+)$ ]]; then
        asset="${BASH_REMATCH[1]}"
        FOUND=yes
        ansi::out "Found file ${BOLD}${asset}${RESET_BOLD}"
      else
        ansi::err "${ERROR}Cannot parse listing of ${REVERSE}${asset}${RESET_REVERSE}.${RESET_ALL}"
        exit 1
      fi
    elif [[ "${#lines[@]}" -gt 1 ]]; then
      ansi::err "${ERROR}Multiple files found with prefix ${REVERSE}${asset}${RESET_REVERSE}. Please specify the full name or better prefix.${RESET_ALL}"
      exit 1
    fi
    unset lines
fi

# creating file if it doesn't exist
if [[ "$FOUND" == "no" ]] && [[ "$args_command" != "put" ]]; then
    if [[ "$args_command" == "delete" ]] || [[ "$args_command" == "rename" ]]; then
      ansi::err "${ERROR}File ${REVERSE}$asset${RESET_REVERSE} does not exist.${RESET_ALL}"
      exit 1
    fi
    if [[ -v args_options["-n"] ]]; then
      ansi::out "File ${BOLD}$asset${RESET_BOLD} does not exist and ${BOLD}--no${RESET_BOLD} is specified."
      exit 0
    fi
    if ! [[ -v args_options["-y"] ]]; then
      ansi::prompt "Do you want to create ${BOLD}$asset${RESET_BOLD}? [Y/n] "
      read response
      case "${response^^}" in
        N | NO | NOPE)
          ansi::out "File ${BOLD}$asset${RESET_BOLD} is not created."
          exit 0
          ;;
        Y | YES | YEP | YEAH | '')
          ;;
        *)
          ansi::err "${ERROR}Invalid response: ${REVERSE}${response}${RESET_ALL}"
          exit 1
          ;;
      esac
    fi
fi

AGE_KEY=${JOT_AGE_KEY:-~/.ssh/age.key}
# Pick the first available standard SSH key (prefer modern) unless overridden.
if [[ -z "${JOT_SSH_PRV:-}" ]]; then
  for _b in id_ed25519 id_rsa id_ecdsa; do
    if [[ -f "$HOME/.ssh/$_b" ]]; then
      JOT_SSH_PRV="$HOME/.ssh/$_b"
      [[ -z "${JOT_SSH_PUB:-}" && -f "$HOME/.ssh/$_b.pub" ]] && JOT_SSH_PUB="$HOME/.ssh/$_b.pub"
      break
    fi
  done
fi
SSH_PUB=${JOT_SSH_PUB:-$HOME/.ssh/id_rsa.pub}
SSH_PRV=${JOT_SSH_PRV:-$HOME/.ssh/id_rsa}
RECIPIENTS_DIR=${JOT_RECIPIENTS_DIR:-~/.config/jot/recipients}

# Resolve --for / -f recipient names to age -R arguments. Each name maps to
# $RECIPIENTS_DIR/<name>.pub (one file per recipient; age -R reads all keys
# in the file). When set, the age encode path uses these instead of the
# default age key / SSH key fallback.
recipients_args=()
if [[ -v args_options["-f"] ]]; then
  IFS=',' read -ra _names <<< "${args_options["-f"]}"
  for raw in "${_names[@]}"; do
    name="${raw// /}"
    [[ -z "$name" ]] && continue
    pub_file="$RECIPIENTS_DIR/$name.pub"
    if [[ ! -f "$pub_file" ]]; then
      ansi::err "${ERROR}Recipient ${BOLD}${name}${RESET_BOLD} not found at ${REVERSE}${pub_file}${RESET_REVERSE}.${RESET_ALL}"
      exit 1
    fi
    recipients_args+=(-R "$pub_file")
  done
  unset _names
  if [[ ${#recipients_args[@]} -eq 0 ]]; then
    ansi::err "${ERROR}--for parsed to no recipients (value: ${REVERSE}${args_options["-f"]}${RESET_REVERSE}).${RESET_ALL}"
    exit 1
  fi
fi

do_command() {
  local command="$1"
  local file_ext="$2"
  local file_short="${3:-}"
  local file_long="$file_short"."$2"

  if [[ "$FOUND" == "no" ]] && [[ "$command" == "d" ]]; then
    rm "$TMPDIR/$file_long"
    touch "$TMPDIR/$file_short"
    return 0
  fi

  if [[ "$command" == "d" || "$command" == "e" ]]; then
    local tool
    if tool=$(jot::codec_tool "$file_ext"); then
      deps::need "$tool"
    fi
  fi

  case "$file_ext" in
    "age")
      if [[ "$command" == "d" ]]; then
        # decode
        if [ -f "$AGE_KEY" ]; then
          ansi::out "Decrypting with age key..."
          age --decrypt -i "$AGE_KEY" -o "$TMPDIR/$file_short" "$TMPDIR/$file_long"
          rm "$TMPDIR/$file_long"
        elif [ -f "$SSH_PRV" ]; then
          ansi::out "Decrypting with ssh private key..."
          age --decrypt -i "$SSH_PRV" -o "$TMPDIR/$file_short" "$TMPDIR/$file_long"
          rm "$TMPDIR/$file_long"
        else
          ansi::err "${ERROR}Keys not found: ${REVERSE}${AGE_KEY}${RESET_REVERSE}, ${REVERSE}${SSH_PRV}${RESET_REVERSE}${RESET_ALL}"
          return 1
        fi
      elif [[ "$command" == "e" ]]; then
        # encode
        if [[ ${#recipients_args[@]} -gt 0 ]]; then
          ansi::out "Encrypting to named recipients..."
          age --encrypt "${recipients_args[@]}" -o "$TMPDIR/$file_long" "$TMPDIR/$file_short"
          rm "$TMPDIR/$file_short"
        elif [ -f "$AGE_KEY" ]; then
          ansi::out "Encrypting with age key..."
          age --encrypt -i "$AGE_KEY" -o "$TMPDIR/$file_long" "$TMPDIR/$file_short"
          rm "$TMPDIR/$file_short"
        elif [ -f "$SSH_PUB" ]; then
          ansi::out "Encrypting with ssh public key..."
          age --encrypt -R "$SSH_PUB" -o "$TMPDIR/$file_long" "$TMPDIR/$file_short"
          rm "$TMPDIR/$file_short"
        else
          ansi::err "${ERROR}Keys not found: ${REVERSE}${AGE_KEY}${RESET_REVERSE}, ${REVERSE}${SSH_PUB}${RESET_REVERSE}${RESET_ALL}"
          return 1
        fi
      fi
      ;;
    "br")
      if [[ "$command" == "d" ]]; then
        # decode
        ansi::out "Decoding with brotli..."
        brotli -d --rm "$TMPDIR/$file_long"
      elif [[ "$command" == "e" ]]; then
        # encode
        ansi::out "Encoding with brotli..."
        brotli -Z --rm "$TMPDIR/$file_short"
      fi
      ;;
    "bz2")
      if [[ "$command" == "d" ]]; then
        # decode
        ansi::out "Decoding with bunzip2..."
        bunzip2 "$TMPDIR/$file_long"
      elif [[ "$command" == "e" ]]; then
        # encode
        ansi::out "Encoding with bzip2..."
        bzip2 -z --best "$TMPDIR/$file_short"
      fi
      ;;
    "gz")
      if [[ "$command" == "d" ]]; then
        # decode
        ansi::out "Decoding with gunzip..."
        gunzip "$TMPDIR/$file_long"
      elif [[ "$command" == "e" ]]; then
        # encode
        ansi::out "Encoding with gzip..."
        gzip -9 "$TMPDIR/$file_short"
      fi
      ;;
    "xz")
      if [[ "$command" == "d" ]]; then
        # decode
        ansi::out "Decoding with xz..."
        xz -d "$TMPDIR/$file_long"
      elif [[ "$command" == "e" ]]; then
        # encode
        ansi::out "Encoding with xz..."
        xz -z -e -9 "$TMPDIR/$file_short"
      fi
      ;;
    "zst")
      if [[ "$command" == "d" ]]; then
        # decode
        ansi::out "Decoding with zstd..."
        unzstd --rm "$TMPDIR/$file_long"
      elif [[ "$command" == "e" ]]; then
        # encode
        ansi::out "Encoding with zstd..."
        zstd --ultra --rm "$TMPDIR/$file_short"
      fi
      ;;
    "tar")
      if [[ "$command" == "d" ]]; then
        # decode: extract archive into the parent of file_short
        ansi::out "Extracting tar archive..."
        local target_parent
        target_parent="$(dirname -- "$TMPDIR/$file_short")"
        [ -d "$target_parent" ] || mkdir -p -- "$target_parent"
        tar xf "$TMPDIR/$file_long" -C "$target_parent"
        rm -- "$TMPDIR/$file_long"
      elif [[ "$command" == "e" ]]; then
        # encode: tar the directory at file_short into file_long
        ansi::out "Creating tar archive..."
        local source_parent source_name
        source_parent="$(dirname -- "$TMPDIR/$file_short")"
        source_name="$(basename -- "$TMPDIR/$file_short")"
        tar cf "$TMPDIR/$file_long" -C "$source_parent" "$source_name"
        rm -rf -- "$TMPDIR/$file_short"
      fi
      ;;
    *)
      return 1
      ;;
  esac
  return 0
}

# delete/rename operations

if [[ "$args_command" == "delete" ]]; then
  ansi::out "Deleting ${BOLD}${asset}${RESET_BOLD} from S3..."
  aws s3 rm "s3://$JOT_AWS_S3_BUCKET/$asset" --quiet
  exit 0
fi

if [[ "$args_command" == "rename" ]]; then
  new_name="${2:-}"
  if [ -z "$new_name" ]; then
    ansi::err "${ERROR}No new name provided.${RESET_ALL}"
    exit 1
  fi
  if ! [[ -v args_options["-y"] ]]; then
    FOUND=yes
    ansi::out "Checking ${BOLD}${new_name}${RESET_BOLD}..."
    if ! aws s3api head-object --bucket "$JOT_AWS_S3_BUCKET" --key "$new_name" &>/dev/null; then
      FOUND=no
    fi
    if [[ "$FOUND" == "yes" ]]; then
      if [[ -v args_options["-n"] ]]; then
        ansi::err "${ERROR}Asset ${BOLD}${new_name}${RESET_BOLD} already exists.${RESET_ALL}"
        exit 1
      fi
      ansi::prompt "Do you want to override ${BOLD}$new_name${RESET_BOLD}? [Y/n] "
      read response
      case "${response^^}" in
        N | NO | NOPE)
          ansi::out "Skipping renaming of ${BOLD}$asset${RESET_BOLD} to ${BOLD}$new_name${RESET_BOLD}."
          exit 0
          ;;
        Y | YES | YEP | YEAH | '')
          ansi::out "Overriding ${BOLD}$new_name${RESET_BOLD}..."
          ;;
        *)
          ansi::err "${ERROR}Invalid response: ${REVERSE}${response}${RESET_ALL}"
          exit 1
          ;;
      esac
    fi
  fi
  ansi::out "Renaming ${BOLD}${asset}${RESET_BOLD} to ${BOLD}${new_name}${RESET_BOLD}..."
  aws s3 mv "s3://$JOT_AWS_S3_BUCKET/$asset" "s3://$JOT_AWS_S3_BUCKET/$new_name" --quiet
  exit 0
fi

# download the asset
if [[ "$FOUND" == "yes" ]] && [[ "$args_command" != "put" ]]; then
  ansi::out "Downloading ${BOLD}${asset}${RESET_BOLD} from S3..."
  aws s3 cp "s3://$JOT_AWS_S3_BUCKET/$asset" "$TMPDIR/$asset" --quiet
else
  touch "$TMPDIR/$asset"
fi

file_name="$asset"
extensions=()

# decode the asset
while true; do
  file_ext="${file_name##*.}"
  file_short="${file_name%.*}"
  if ! do_command t "$file_ext"; then
    break
  fi
  do_command d "$file_ext" "$file_short"
  file_name="$file_short"
  extensions+=("$file_ext")
done

# get/put operations

if [[ "$args_command" == "get" ]]; then
  local_file_name=$(basename "$TMPDIR/$file_name")
  if [[ -d "$TMPDIR/$file_name" ]]; then
    if [[ -e "${local_file_name}" ]]; then
      ansi::err "${ERROR}Local path ${BOLD}${local_file_name}${RESET_BOLD} already exists; refusing to overwrite a directory.${RESET_ALL}"
      exit 1
    fi
    ansi::out "Copying directory ${BOLD}${asset}${RESET_BOLD} to ${BOLD}${local_file_name}/${RESET_BOLD}..."
    cp -r "$TMPDIR/$file_name" "${local_file_name}"
  else
    ansi::out "Copying ${BOLD}${asset}${RESET_BOLD} to ${BOLD}${local_file_name}${RESET_BOLD}..."
    cp -i "$TMPDIR/$file_name" "${local_file_name}"
  fi
  exit 0
fi

if [[ "$args_command" == "put" ]]; then
  parent_dir="$(dirname -- "$TMPDIR/$file_name")"
  [ -d "$parent_dir" ] || mkdir -p -- "$parent_dir"
  if [[ -d "$local_file_name" ]]; then
    ansi::out "Copying directory ${BOLD}${local_file_name}${RESET_BOLD} to ${BOLD}${file_name}/${RESET_BOLD}..."
    cp -r "$local_file_name" "$TMPDIR/$file_name"
  elif [[ -f "$local_file_name" ]]; then
    ansi::out "Copying ${BOLD}${local_file_name}${RESET_BOLD} to ${BOLD}${file_name}${RESET_BOLD}..."
    cp "$local_file_name" "$TMPDIR/$file_name"
  else
    ansi::err "${ERROR}Local path ${BOLD}${local_file_name}${RESET_BOLD} not found.${RESET_ALL}"
    exit 1
  fi
  if ! [[ -v args_options["-y"] ]]; then
    if [[ "$FOUND" == "yes" ]]; then
      if [[ -v args_options["-n"] ]]; then
        ansi::err "${ERROR}Asset ${BOLD}${asset}${RESET_BOLD} already exists.${RESET_ALL}"
        exit 1
      fi
      ansi::prompt "Do you want to override ${BOLD}$asset${RESET_BOLD}? [Y/n] "
      read response
      case "${response^^}" in
        N | NO | NOPE)
          ansi::out "Skipping uploading of ${BOLD}$local_file_name${RESET_BOLD} to ${BOLD}$asset${RESET_BOLD}."
          exit 0
          ;;
        Y | YES | YEP | YEAH | '')
          ansi::out "Overriding ${BOLD}$asset${RESET_BOLD}..."
          ;;
        *)
          ansi::err "${ERROR}Invalid response: ${REVERSE}${response}${RESET_ALL}"
          exit 1
          ;;
      esac
    fi
  fi
fi

# edit the file

if [[ "$args_command" == "edit" ]]; then
  if [[ -d "$TMPDIR/$file_name" ]]; then
    ansi::err "${ERROR}Cannot edit directory archive ${BOLD}${asset}${RESET_BOLD}. Use ${BOLD}jot get${RESET_BOLD}/${BOLD}put${RESET_BOLD} for tar archives.${RESET_ALL}"
    exit 1
  fi
  editor="${VISUAL:-${EDITOR:-nano}}"
  ansi::out "Opening ${BOLD}${asset}${RESET_BOLD} in ${BOLD}${editor}${RESET_BOLD}..."
  cp "$TMPDIR/$file_name" "$TMPDIR/${file_name}.bak"
  "$editor" "$TMPDIR/$file_name"
  if cmp -s "$TMPDIR/${file_name}.bak" "$TMPDIR/$file_name"; then
    ansi::out "No changes: skipping saving."
    exit 0
  fi
fi

# encode the file

# Get the index of the last element
last_index=$(( ${#extensions[@]} - 1 ))

# Iterate from the last index down to 0
for (( i = $last_index; i >= 0; --i )); do
  do_command e "${extensions[$i]}" "$file_name"
  file_name+=".${extensions[$i]}"
done

# upload the asset
ansi::out "Uploading ${BOLD}${asset}${RESET_BOLD} to S3..."
aws s3 cp "$TMPDIR/$asset" "s3://$JOT_AWS_S3_BUCKET/$asset" --quiet
