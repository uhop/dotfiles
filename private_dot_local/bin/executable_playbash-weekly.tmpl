#!/usr/bin/env bash
# playbash-weekly — weekly maintenance stack: chezmoi update, dcms, then
# upd -cy (which runs cln after upd). Same playbash conventions as
# playbash-daily (sourced helpers, structured events via $PLAYBASH_REPORT).

set -euCo pipefail
shopt -s expand_aliases

source "${PLAYBASH_LIBS:-$HOME/.local/libs}/playbash.sh"

playbash_step "chezmoi"
playbash_info "running chezmoi update"
chezmoi update

playbash_step "docker"
playbash_info "refreshing docker images via dcms"
dcms

playbash_step "system"
playbash_info "running upd -cy (with cleanup)"
upd -cy

# upd/cln are now authoritative for reboot/restart/apparmor reporting via
# maintenance.sh — they write the same events to $PLAYBASH_REPORT that
# we used to write here. No post-hoc check needed.
