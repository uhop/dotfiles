#!/usr/bin/env node
// playbash — run bash playbooks on remote hosts.
//
// Entry point: argument parsing, dispatcher, single-host and fan-out
// run pipelines, and the list/hosts/log subcommands. Rendering, inventory,
// and sidecar handling live in sibling modules:
//
//   playbash-render.js    — Rectangle, StatusBoard, COLOR, sanitizer
//   playbash-inventory.js — load/resolve/group/self
//   playbash-sidecar.js   — parse, per-host summary, cross-host aggregation
//   playbash-staging.js   — wrapper staging for vanilla hosts, BatchMode ssh

import {openSync, closeSync, readSync, writeSync} from 'node:fs';
import {parseArgs} from 'node:util';
import {basename} from 'node:path';
import {execSync} from 'node:child_process';

import {
  probeConnectivity,
  runFanout,
  runLocally,
  runRemote,
  validateCustomPlaybookPath
} from '../share/playbash/runner.js';
import {
  cmdBashCompletion,
  cmdCompleteTargets,
  cmdHosts,
  cmdList,
  cmdLog
} from '../share/playbash/commands.js';
import {cmdGet, cmdPut} from '../share/playbash/transfer.js';
import {die} from '../share/playbash/errors.js';
import {COLOR} from '../share/playbash/render.js';
import {
  filterSelf,
  isSelfAddress,
  loadInventory,
  resolveTargets
} from '../share/playbash/inventory.js';
import {runDoctor} from '../share/playbash/doctor.js';

// Hard dependencies: playbash spawns ssh on every remote operation and tar
// for the directory-transfer pipelines in put/get. Catch missing tools
// once at startup instead of letting each spawn fail with ENOENT mid-run.
// Matches the deps::need pattern used by the bash utilities (single
// aggregate diagnostic line, plain stderr, exit 1).
import {spawnSync} from 'node:child_process';
{
  const missing = ['ssh', 'tar'].filter(
    t => spawnSync('sh', ['-c', `command -v ${t}`], {stdio: 'ignore'}).status !== 0
  );
  if (missing.length) {
    process.stderr.write(`playbash: required tool(s) not installed: ${missing.join(' ')}\n`);
    process.exit(1);
  }
}

// Bump on every user-visible change. See dev-docs/playbash-design.md#versioning
// for the versioning policy and bump rules.
const VERSION = '3.4.0';

const WIKI = 'https://github.com/uhop/dotfiles/wiki/Playbash-Server-Management';

const USAGE = `Multi-host playbook runner for system maintenance.

usage:
  playbash run    <targets> <playbook> [-n LINES] [-p N] [--self] [--sudo] [--report]
  playbash push   <targets> <script-path> [-n LINES] [-p N] [--self] [--sudo] [--report]
  playbash debug  <targets> <playbook> [--self] [--sudo]
  playbash exec   <targets> [--] <command...> [-n LINES] [-p N] [--self] [-N] [--sudo]
  playbash put    <targets> <local-path> [<remote-path>] [-p N] [--self] [--sudo] [-N]
  playbash get    <targets> <remote-path> [<local-path>] [-p N] [--self] [--sudo] [-N]
  playbash list
  playbash hosts
  playbash log    [host] [command]
  playbash doctor
  playbash -v, --version            # print version and exit
  playbash --bash-completion        # print bash completion script

options:
  -n, --lines N      live output rectangle height (default 5; exec defaults to 0)
  -p, --parallel N   max concurrent hosts (default 0 = unlimited)
  --self             allow running on the local host
  --sudo             prompt for a password and inject on sudo/doas prompts
  --report           plain-text summary of actionable events to stdout (run/push)
  -N, --no-precheck  skip ssh connectivity pre-flight check

For more information visit: ${WIKI}`;

// Runner machinery (signal handlers, child registry, runHost,
// runHostSingle, runRemote, runLocally, runFanout, probeConnectivity,
// stuck-on-input detector, buildRemoteCommand, buildExecCommand) lives in
// ../share/playbash/runner.js and is imported at the top of this file.

// --- main dispatcher ---

const {values, positionals} = parseArgs({
  options: {
    lines: {type: 'string', short: 'n'},
    self: {type: 'boolean', default: false},
    sudo: {type: 'boolean', default: false},
    report: {type: 'boolean', default: false},
    'no-precheck': {type: 'boolean', short: 'N', default: false},
    parallel: {type: 'string', short: 'p', default: '0'},
    'bash-completion': {type: 'boolean', default: false},
    version: {type: 'boolean', short: 'v', default: false},
    help: {type: 'boolean', short: 'h', default: false}
  },
  allowPositionals: true
});

// null when the user didn't pass -n; a validated number otherwise.
const linesFlag =
  values.lines != null
    ? (() => {
        const n = parseInt(values.lines, 10);
        if (!Number.isFinite(n) || n < 0)
          die(
            `--lines must be a non-negative integer (0 disables the rectangle)`
          );
        return n;
      })()
    : null;

if (values['bash-completion']) {
  cmdBashCompletion();
  process.exit(0);
}

if (values.version) {
  process.stdout.write(`playbash ${VERSION}\n`);
  process.exit(0);
}

if (values.help) {
  process.stdout.write(USAGE + '\n');
  process.exit(0);
}

if (positionals.length === 0) die(USAGE);
const [command, ...rest] = positionals;

// Pick the right execution backend for the user's target argument. The
// argument may be a single name or a comma-separated list mixing host
// names, group names, and the implicit `all` group.
//
// Decision tree:
//   - If the resolved-and-self-filtered list is empty, refuse.
//   - If length is 1: existing single-host pipeline.
//     - If that one host is self and --self was not passed: hard refusal
//       with the bare-script hint (existing behavior).
//   - If length > 1: fan-out path (StatusBoard, parallel runs, aggregated
//     summary). Self entries are silently dropped from the list unless
//     --self is passed; a one-line dim notice is printed before launch.
// Shared target validation: resolve, self-filter, empty-check, precheck,
// offline detection. Used by dispatch, put, and get. Returns validated
// {inventory, resolved, targets, offlineNames, parallelLimit} or dies.
async function resolveAndValidate(targetArg) {
  const inventory = loadInventory();
  const resolved = resolveTargets(targetArg, inventory);
  const {targets, skipped} = await filterSelf(resolved, values.self);

  if (targets.length === 0) {
    if (skipped.length > 0)
      die(`all targets resolved to self; pass --self to include`);
    die('target list resolved to nothing');
  }

  if (skipped.length > 0) {
    process.stderr.write(
      `${COLOR.dim}· skipping self (${skipped.join(', ')}); pass --self to include${COLOR.reset}\n`
    );
  }

  const offlineNames = new Set();
  const offlineReasons = new Map();   // name → short reason from ssh stderr
  if (!values['no-precheck']) {
    // @self targets run locally — skip the SSH connectivity check for them.
    const remoteTargets = targets.filter(t => !t.isSelf);
    if (remoteTargets.length > 0) {
      const {offline, reasons} = await probeConnectivity(remoteTargets);
      for (const t of offline) offlineNames.add(t.name);
      for (const [name, reason] of reasons) offlineReasons.set(name, reason);
      if (offlineNames.size > 0) {
        const labels = [...offlineNames].map(n => {
          const r = offlineReasons.get(n);
          return r && r !== 'offline' ? `${n} (${r})` : n;
        });
        process.stderr.write(
          `${COLOR.dim}· offline: ${labels.join(', ')}${COLOR.reset}\n`
        );
      }
      if (offlineNames.size === remoteTargets.length && !targets.some(t => t.isSelf))
        die('all targets are unreachable');
    }
  }

  const parallelLimit = parseInt(values.parallel, 10);
  if (!Number.isFinite(parallelLimit) || parallelLimit < 0) {
    die(`--parallel must be a non-negative integer (0 = unlimited)`);
  }

  return {inventory, resolved, targets, offlineNames, offlineReasons, parallelLimit};
}

// Prompt the operator for a password with echo disabled. Reads from
// /dev/tty directly so piped stdin doesn't interfere.
function promptPassword() {
  let fd;
  try {
    fd = openSync('/dev/tty', 'r+');
  } catch {
    die('--sudo requires an interactive terminal');
  }
  try {
    writeSync(fd, 'Password: ');
    // Disable echo via stty on the tty fd
    execSync('stty -echo', {stdio: [fd, fd, fd]});
    const buf = Buffer.alloc(1024);
    let pw = '';
    while (true) {
      const n = readSync(fd, buf, 0, 1, undefined);
      if (n === 0) break;
      const ch = buf.toString('utf8', 0, n);
      if (ch === '\n' || ch === '\r') break;
      pw += ch;
    }
    execSync('stty echo', {stdio: [fd, fd, fd]});
    writeSync(fd, '\n');
    buf.fill(0); // clear password bytes from the read buffer
    return pw;
  } finally {
    try { execSync('stty echo', {stdio: [fd, fd, fd]}); } catch {}
    closeSync(fd);
  }
}

// Shared dispatcher for `run`, `push`, `debug`, and `exec`.
async function dispatch({job, targetArg, rectHeight, verbose, report, push, sudoPassword}) {
  const {
    inventory: inv,
    targets,
    offlineNames,
    offlineReasons,
    parallelLimit
  } = await resolveAndValidate(targetArg);

  // Pick single-host vs fan-out based on the *post-self-filter* target
  // count. A two-host call where one target is self and --self was not
  // passed has resolved.length === 2 but targets.length === 1; it should
  // use the single-host pipeline (live rectangle) on the one real host,
  // not the status board.
  if (targets.length === 1) {
    const only = targets[0];
    // With targets.length === 1, either the target is non-self (filterSelf
    // left it alone) or --self was passed and the target happens to be self.
    // The `isSelf && !values.self` case is unreachable: filterSelf would
    // have moved it to `skipped`, and resolveAndValidate would have died
    // with "all targets resolved to self" before dispatch runs.
    const isSelf = await isSelfAddress(only.address);
    if (isSelf) {
      await runLocally({...job, hostName: only.name, rectHeight, verbose, report, sudoPassword});
    } else {
      const managed = !push && inv.hosts.has(only.name);
      if (!push && job.playbook && !managed) {
        process.stderr.write(
          `${COLOR.dim}· ${only.name} not in inventory — pushing playbook${COLOR.reset}\n`
        );
      }
      await runRemote({
        ...job,
        hostName: only.name,
        address: only.address,
        rectHeight,
        verbose,
        report,
        managed,
        sudoPassword
      });
    }
    return;
  }

  if (!push && job.playbook) {
    const nonInv = targets.filter(
      t => !inv.hosts.has(t.name) && !offlineNames.has(t.name)
    );
    if (nonInv.length > 0) {
      process.stderr.write(
        `${COLOR.dim}· pushing playbook to ${nonInv.map(t => t.name).join(', ')} (not in inventory)${COLOR.reset}\n`
      );
    }
  }

  await runFanout({
    ...job,
    targets,
    rectHeight,
    verbose,
    report,
    parallelLimit,
    inventory: inv,
    push,
    offlineNames,
    offlineReasons,
    sudoPassword
  });
}

switch (command) {
  case 'list': {
    if (rest.length > 0) die(`list takes no arguments`);
    cmdList();
    break;
  }
  case 'hosts': {
    if (rest.length > 0) die(`hosts takes no arguments`);
    await cmdHosts();
    break;
  }
  case 'doctor': {
    if (rest.length > 0) die(`doctor takes no arguments`);
    await runDoctor();
    break;
  }
  case 'log': {
    if (rest.length > 2)
      die(`log takes at most two arguments: [host] [command]`);
    cmdLog(rest[0], rest[1]);
    break;
  }
  case '__complete-targets': {
    // Hidden helper for the bash completion script. Not in USAGE.
    cmdCompleteTargets();
    break;
  }
  case 'run':
  case 'debug': {
    if (rest.length !== 2)
      die(`${command} takes <targets> <playbook>\n${USAGE}`);
    const [targetArg, playbookArg] = rest;
    const isCustomPath = playbookArg.includes('/');
    // Captured here once and passed via the job as `customPathKind`;
    // `prepareRemoteJob` trusts it when set and skips its own validation,
    // so non-templated paths don't re-stat per host. Stays null for
    // templated paths — those defer validation to per-host expansion.
    let customPathKind = null;
    if (isCustomPath) {
      if (!playbookArg.includes('{host}')) {
        try {
          customPathKind = validateCustomPlaybookPath(playbookArg);
        } catch (err) {
          die(err.message);
        }
        process.stderr.write(
          customPathKind === 'dir'
            ? `${COLOR.dim}· ${playbookArg} is a directory playbook — using push mode${COLOR.reset}\n`
            : `${COLOR.dim}· ${playbookArg} is a file path — using push mode${COLOR.reset}\n`
        );
      } else {
        process.stderr.write(
          `${COLOR.dim}· ${playbookArg} is a templated path — using push mode${COLOR.reset}\n`
        );
      }
    } else {
      if (!/^[a-zA-Z0-9._-]+$/.test(playbookArg))
        die(`invalid playbook name "${playbookArg}"`);
    }
    const playbook = isCustomPath
      ? basename(playbookArg.replace(/\/+$/, ''))
      : playbookArg;
    const customPath = isCustomPath ? playbookArg : null;
    if (command === 'debug' && linesFlag != null)
      die('debug does not accept -n — use "run <targets> <playbook> -n N" for a rectangle');
    const rectHeight = command === 'debug' ? 0 : (linesFlag ?? 5);
    const verbose = command === 'debug';
    const sudoPassword = values.sudo ? promptPassword() : null;
    await dispatch({
      job: {playbook, customPath, customPathKind},
      targetArg,
      rectHeight,
      verbose,
      report: values.report,
      push: isCustomPath,
      sudoPassword
    });
    break;
  }
  case 'push': {
    if (rest.length !== 2) die(`push takes <targets> <script-path>\n${USAGE}`);
    const [targetArg, scriptPath] = rest;
    let customPathKind = null;
    if (!scriptPath.includes('{host}')) {
      try {
        customPathKind = validateCustomPlaybookPath(scriptPath);
      } catch (err) {
        die(err.message);
      }
    }
    const playbook = basename(scriptPath.replace(/\/+$/, ''));
    const rectHeight = linesFlag ?? 5;
    const sudoPassword = values.sudo ? promptPassword() : null;
    await dispatch({
      job: {playbook, customPath: scriptPath, customPathKind},
      targetArg,
      rectHeight,
      verbose: false,
      report: values.report,
      push: true,
      sudoPassword
    });
    break;
  }
  case 'exec': {
    if (rest.length < 2) die(`exec takes <targets> <command...>\n${USAGE}`);
    const [targetArg, ...cmdParts] = rest;
    const command = cmdParts.join(' ');
    if (!command) die(`exec requires a command after the target\n${USAGE}`);
    const rectHeight = linesFlag ?? 0;
    const sudoPassword = values.sudo ? promptPassword() : null;
    await dispatch({
      job: {command},
      targetArg,
      rectHeight,
      verbose: false,
      push: false,
      sudoPassword
    });
    break;
  }
  case 'put': {
    if (rest.length < 2 || rest.length > 3)
      die(`put takes <targets> <local-path> [<remote-path>]\n${USAGE}`);
    const validated = await resolveAndValidate(rest[0]);
    const sudoPassword = values.sudo ? promptPassword() : null;
    await cmdPut(validated, rest[1], rest[2], sudoPassword);
    break;
  }
  case 'get': {
    if (rest.length < 2 || rest.length > 3)
      die(`get takes <targets> <remote-path> [<local-path>]\n${USAGE}`);
    const validated = await resolveAndValidate(rest[0]);
    const sudoPassword = values.sudo ? promptPassword() : null;
    await cmdGet(validated, rest[1], rest[2], sudoPassword);
    break;
  }
  default:
    die(`unknown command "${command}"\n${USAGE}`);
}
