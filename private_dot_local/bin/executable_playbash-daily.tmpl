#!/usr/bin/env bash
# playbash-daily — daily maintenance stack: chezmoi update,
# claude-config-update, dcms, then upd -ry. Each step runs as an
# isolated playbash_section so one failure doesn't abort the rest;
# the final playbash_section_report propagates non-zero exit if any
# section failed.

set -euCo pipefail
shopt -s expand_aliases

source "${PLAYBASH_LIBS:-$HOME/.local/libs}/playbash.sh"

playbash_section chezmoi       chezmoi update
playbash_section claude-config claude-config-update

# Skip the Docker-stack refresh when the daemon is unreachable (e.g. macOS
# with Docker Desktop stopped — it starts on demand). `dcms` self-guards
# too, but gating the section here keeps the playbook from logging a
# section for a guaranteed no-op. `docker info` is also non-zero when
# docker isn't installed at all, so this covers docker-less hosts as well.
if docker info &> /dev/null; then
  playbash_section services    dcms daily
fi

playbash_section system        upd -ry

playbash_section_report
