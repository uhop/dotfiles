#!/usr/bin/env bash

set -euCo pipefail
shopt -s expand_aliases

. ~/.local/libs/bootstrap.sh

script_name=$(basename "$0")

args::program "$script_name" "1.0.0" "Update Node.js to the latest minor of every installed major (via nvm)" "https://github.com/uhop/dotfiles/wiki/Utilities#update-node-versions"

args_program_header="${BOLD}update-node-versions${RESET_BOLD} runs ${BOLD}nvm install <major>${RESET_BOLD} for every Node major nvm has installed.
Bash on purpose: nvm runs in-process, so no Node runtime is held open while versions change."

args_program_usage="${BOLD}update-node-versions${RESET_BOLD}       # nvm install <major> for every installed major
${BOLD}update-node-versions${RESET_BOLD} -n    # show the nvm calls without running them"

args::option "-n, --dry-run" "Show the nvm calls without running them"
args::option "-v, --version" "Show version"
args::option "-h, --help" "Show help"
args::option "--bash-completion" "Show bash completion"

args::parse "$@"
set -- "${args_cleaned[@]}"

if [ "$#" -gt 0 ]; then
  ansi::err "${ERROR}Unexpected argument: $1${RESET_ALL}"
  args::try_help
  exit 1
fi

DRY_RUN=0
[[ -v args_options["-n"] ]] && DRY_RUN=1

export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
nvm_sh=""
command -v brew &>/dev/null && nvm_sh="$(brew --prefix nvm 2>/dev/null || true)/nvm.sh"
[ -s "$nvm_sh" ] || nvm_sh="$NVM_DIR/nvm.sh"
if [ ! -s "$nvm_sh" ]; then
  ansi::err "${ERROR}nvm.sh not found (brew prefix or \$NVM_DIR) — install nvm first.${RESET_ALL}"
  exit 1
fi
# nvm.sh is not set -e/-u clean
set +eu
. "$nvm_sh"
set -eu

run_nvm() {
  if [ "$DRY_RUN" -eq 1 ]; then
    ansi::out "${WARN}[dry-run] nvm $*${RESET_ALL}"
  else
    echoRun nvm "$@"
  fi
}

installed_versions() { # stdout: "X.Y.Z<TAB>current?" per installed version
  nvm ls --no-colors | while IFS= read -r line; do
    if [[ $line =~ ^[[:space:]]*(-\>)?[[:space:]]*v([0-9]+\.[0-9]+\.[0-9]+) ]]; then
      printf '%s\t%s\n' "${BASH_REMATCH[2]}" "${BASH_REMATCH[1]:+current}"
    fi
  done
}

mapfile -t majors < <(installed_versions | cut -f1 | cut -d. -f1 | sort -un)

if [ "${#majors[@]}" -eq 0 ]; then
  ansi::out "No Node versions were found."
  exit 0
fi

for major in "${majors[@]}"; do
  run_nvm install "$major"
done

ansi::out "${OK}Done.${RESET_ALL}"
