#!/usr/bin/env bash
# run_onchange_before_install-packages.sh.tmpl — install system + brew packages.
#
# Re-runs whenever this script's rendered content changes (apt list, brew
# templates, hasGui flag, etc.). Bash strict mode, sudo detection, and
# ANSI color macros come from the shared install prelude template.

{{ template "install-prelude.sh" . }}

{{ if eq .pkgManager "apt" -}}
if [ "$hasSudo" -eq 0 ]; then
  echo "${WARN}Both apt and snap require sudo: expect asking for the sudo password.${RESET}"
  echo "${PROMPT}Installing command line apps: sudo apt install...${RESET}"
  sudo env DEBIAN_FRONTEND=noninteractive apt install -y \
    build-essential bash-completion micro wget age mosh dialog \
    gcp bat ncdu jq tmux silversearcher-ag tig httpie prettyping htop parallel tree \
    brotli gh mc ripgrep duf hyperfine zoxide nginx shellcheck clangd git-lfs etckeeper \
    grc golang gopls rustc cargo python3 python3-pylsp net-tools firejail waypipe lnav \
    sshfs
  # Packages whose names or availability differ across Debian-based distros:
  # libfuse2t64 is Ubuntu 24.04+ (time_t transition); Debian 12 ships libfuse2.
  # ttyd is in Ubuntu and Debian testing but not Debian 12 stable.
  sudo env DEBIAN_FRONTEND=noninteractive apt install -y libfuse2t64 2>/dev/null || sudo env DEBIAN_FRONTEND=noninteractive apt install -y libfuse2 || true
  sudo env DEBIAN_FRONTEND=noninteractive apt install -y ttyd || true
fi
{{ if .hasGui -}}
if [ "$hasSudo" -eq 0 ]; then
  echo "${PROMPT}Installing GUI apps: sudo apt install...${RESET}"
  sudo env DEBIAN_FRONTEND=noninteractive apt install -y meld alacritty flatpak gnome-software-plugin-flatpak ttf-mscorefonts-installer firetools
fi
{{- end }}
{{- else if eq .pkgManager "dnf" -}}
if [ "$hasSudo" -eq 0 ]; then
  echo "${WARN}dnf requires sudo: expect asking for the sudo password.${RESET}"
{{/* Enable EPEL + CRB on RHEL clones. Check .osId (not .osIdLike) so clones
     whose ID_LIKE happens to start with or equal "fedora" (e.g., Oracle Linux's
     ID_LIKE="fedora") still get EPEL enabled. Real Fedora has .osId=linux-fedora
     and doesnt need EPEL. */ -}}
{{ if ne .osId "linux-fedora" -}}
  if ! dnf repolist --enabled | grep -q epel; then
    echo "${PROMPT}Enabling EPEL repository...${RESET}"
    sudo dnf install -y epel-release
    sudo dnf config-manager --set-enabled crb 2>/dev/null || sudo dnf config-manager --set-enabled powertools 2>/dev/null || true
  fi
{{- end }}
  echo "${PROMPT}Installing command line apps: sudo dnf install...${RESET}"
  sudo dnf install -y gcc gcc-c++ make bash-completion unzip wget curl git tmux jq \
    python3 golang rust cargo net-tools vim-enhanced
  sudo dnf install -y --skip-broken micro mosh dialog bat ncdu \
    the_silver_searcher tig htop parallel tree brotli mc ripgrep \
    nginx ShellCheck clang-tools-extra git-lfs etckeeper \
    fuse-sshfs lnav || true
  command -v gh &>/dev/null || sudo dnf install -y gh || true
fi
{{ if .hasGui -}}
if [ "$hasSudo" -eq 0 ]; then
  echo "${PROMPT}Installing GUI apps: sudo dnf install...${RESET}"
  sudo dnf install -y meld flatpak
fi
{{- end }}
{{- end }}

{{ if eq .osFamily "darwin" -}}
if [ -f /opt/homebrew/bin/brew ]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
elif [ -f /usr/local/bin/brew ]; then
  eval "$(/usr/local/bin/brew shellenv)"
fi
{{- else -}}
eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
{{- end }}

if command -v brew &>/dev/null && [ -w "$(brew --cellar)" ]; then
  echo "${PROMPT}Installing brew packages...${RESET}"
  brew bundle --file=/dev/stdin <<EOF
{{ template "Brewfile.common" . -}}
{{ if eq .osFamily "darwin" -}}
{{ template "Brewfile.Darwin" . -}}
{{- else if eq .pkgManager "dnf" -}}
{{ template "Brewfile.RedHat" . -}}
{{- end }}
EOF
  brew completions link
fi

{{ if .hasGui -}}
{{ if eq .osFamily "linux" -}}
flatpak remote-add --if-not-exists flathub https://dl.flathub.org/repo/flathub.flatpakrepo
{{- end }}
{{- end }}
