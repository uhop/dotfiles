# -*- mode: bash; -*-

{{- /* Precompute paths at chezmoi apply time */ -}}
{{- $brew_prefix := "" -}}
{{- $brew_bash_git_prompt := "" -}}
{{- $brew_nvm := "" -}}
{{- $pyenv_root := "" -}}
{{- if lookPath "brew" -}}
{{-   $brew_prefix = output "brew" "--prefix" | trim -}}
{{-   $brew_bash_git_prompt = output "brew" "--prefix" "bash-git-prompt" | trim -}}
{{-   $brew_nvm = output "brew" "--prefix" "nvm" | trim -}}
{{- end -}}
{{- if lookPath "pyenv" -}}
{{-   $pyenv_root = output "pyenv" "root" | trim -}}
{{- end }}
# ~/.bashrc: executed by bash(1) for non-login shells.
# see /usr/share/doc/bash/examples/startup-files (in the package bash-doc)
# for examples

__INTERACTIVE=yes
[ -z "$PS1" ] && __INTERACTIVE=

# don't put duplicate lines or lines starting with space in the history.
# See bash(1) for more options
HISTCONTROL=ignoreboth

# append to the history file, don't overwrite it
shopt -s histappend

# for setting history length see HISTSIZE and HISTFILESIZE in bash(1)
HISTSIZE=1000
HISTFILESIZE=2000

# check the window size after each command and, if necessary,
# update the values of LINES and COLUMNS.
shopt -s checkwinsize

# If set, the pattern "**" used in a pathname expansion context will
# match all files and zero or more directories and subdirectories.
#shopt -s globstar

# set a fancy prompt (non-color, unless we know we "want" color)
case "$TERM" in
    xterm-color) color_prompt=yes;;
    xterm-256color) color_prompt=yes;;
    screen-256color) color_prompt=yes;;
esac

# uncomment for a colored prompt, if the terminal has the capability; turned
# off by default to not distract the user: the focus in a terminal window
# should be on the output of commands, not on the prompt
#force_color_prompt=yes

if [ "$__INTERACTIVE" == yes ]; then
	if [ -n "$force_color_prompt" ]; then
	    if [ -x /usr/bin/tput ] && tput setaf 1 >&/dev/null; then
	        # We have color support; assume it's compliant with Ecma-48
	        # (ISO/IEC-6429). (Lack of such support is extremely rare, and such
	        # a case would tend to support setf rather than setaf.)
	        color_prompt=yes
	    else
	        color_prompt=
	    fi
	fi
	if [ "$color_prompt" == yes ]; then
	    PS1='\[\033[01;33m\]\w\[\033[00m\] \$ '
	else
	    PS1='\w \$ '
	fi
fi
{{ if eq .osFamily "linux" }}
[ -x /home/linuxbrew/.linuxbrew/bin/brew ] && eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
{{- else if eq .osFamily "darwin" }}
if [ -s /opt/homebrew/bin/brew ]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
elif [ -s /usr/local/bin/brew ]; then
  eval "$(/usr/local/bin/brew shellenv)"
fi
{{- end }}
{{ if $brew_bash_git_prompt }}
if [ "$__INTERACTIVE" == yes ]; then
	if [ -s "{{ $brew_bash_git_prompt }}/share/gitprompt.sh" ]; then
	    #GIT_PROMPT_ONLY_IN_REPO=1
	    #GIT_PROMPT_FETCH_REMOTE_STATUS=0   # uncomment to avoid fetching remote status
	    #GIT_PROMPT_THEME=Default
	    #GIT_PROMPT_THEME=Single_line_Solarized
	    __GIT_PROMPT_DIR="{{ $brew_bash_git_prompt }}/share"
	    GIT_PROMPT_THEME=Single_line
	    \. "{{ $brew_bash_git_prompt }}/share/gitprompt.sh"
	fi
fi
{{- end }}

unset color_prompt force_color_prompt

# If this is an xterm set the title to user@host:dir
if [ "$__INTERACTIVE" == yes ]; then
	case "$TERM" in
	xterm*|rxvt*)
	    PS1="\[\e]0;\u@\h: \w\a\]$PS1"
	    ;;
	*)
	    ;;
	esac
fi

# set PATH so it includes user's private bin if it exists
[ -d ~/bin ] && PATH="$HOME/bin:$PATH" || true
[ -d ~/.local/bin ] && PATH="$HOME/.local/bin:$PATH" || true
{{ if $brew_prefix }}
# util-linux should be in the path
[ -d "{{ $brew_prefix }}/opt/util-linux/bin" ] && PATH="{{ $brew_prefix }}/opt/util-linux/bin:$PATH" || true
[ -d "{{ $brew_prefix }}/opt/util-linux/sbin" ] && PATH="{{ $brew_prefix }}/opt/util-linux/sbin:$PATH" || true
{{- end }}
{{ if $brew_nvm }}
# NVM for node.js — environment only (PATH, NVM_DIR); full init is interactive-only
if [ -s "{{ $brew_nvm }}/nvm.sh" ]; then
  export NVM_DIR="$HOME/.nvm"
  \. "{{ $brew_nvm }}/nvm.sh"
fi
{{- end }}
{{ if $pyenv_root }}
# pyenv — environment only (PATH, PYENV_ROOT); full init is interactive-only
if command -v pyenv &> /dev/null; then
  export PYENV_ROOT="{{ $pyenv_root }}"
  export PATH="$PYENV_ROOT/bin:$PYENV_ROOT/shims:${PATH}"
fi
{{- end }}

# bun
if [ -s ~/.bun/bin/bun ]; then
  export BUN_INSTALL="$HOME/.bun"
  export PATH=$BUN_INSTALL/bin:$PATH
fi

# lm studio
[ -d ~/.lmstudio/bin ] && PATH="$HOME/.lmstudio/bin:$PATH" || true

export EDITOR=micro
export VISUAL=micro
export BASH_SILENCE_DEPRECATION_WARNING=1
export FORCE_COLOR=3

{{ if .githubUsername -}}
# chezmoi-managed non-secret shell env (~/.env sourcing below can override)
export GITHUB_USERNAME={{ .githubUsername | quote }}
{{ end -}}
{{ if eq .osFamily "linux" -}}
# ssh-agent runs as a systemd user service (see ~/.config/systemd/user/ssh-agent.service)
if [ -n "${XDG_RUNTIME_DIR:-}" ]; then
  export SSH_AUTH_SOCK="$XDG_RUNTIME_DIR/ssh-agent.socket"
fi
{{ end -}}
if [ -s ~/.env ]; then
  set -a
  \. ~/.env
  set +a
fi

if [ -z "${JOT_AWS_S3_BUCKET:-}" ] && [ -n "${GITHUB_USERNAME:-}" ]; then
  export JOT_AWS_S3_BUCKET="${GITHUB_USERNAME}-notes"
fi

# Alias and function definitions.
[ -s ~/.bash_aliases ] && \. ~/.bash_aliases || true

# --- Interactive-only setup (completions, tool init, keybindings) ---

if [ "$__INTERACTIVE" == yes ]; then
{{ if $brew_prefix }}
  if [ -s "{{ $brew_prefix }}/etc/profile.d/bash_completion.sh" ]; then
    \. "{{ $brew_prefix }}/etc/profile.d/bash_completion.sh"
  elif [ -d "{{ $brew_prefix }}/etc/bash_completion.d/" ]; then
    for COMPLETION in "{{ $brew_prefix }}/etc/bash_completion.d/"*
    do
      [ -s "${COMPLETION}" ] && \. "${COMPLETION}"
    done
  fi
{{- end }}

  [ -s ~/.config/git/git-completion.bash ] && \. ~/.config/git/git-completion.bash
{{ if $brew_nvm }}
  if [ -s "{{ $brew_nvm }}/etc/bash_completion.d/nvm" ]; then
    \. "{{ $brew_nvm }}/etc/bash_completion.d/nvm"
  fi
{{- end }}
{{ if $pyenv_root }}
  command -v pyenv &> /dev/null && eval "$(pyenv init -)" || true
{{- end }}

  command -v doas &> /dev/null && complete -cf doas || true
  command -v xc &> /dev/null && complete -C xc xc || true
  command -v zoxide &> /dev/null && eval "$(zoxide init bash)" || true
  command -v playbash &> /dev/null && eval "$(playbash --bash-completion)" || true
  [ -s ~/.config/broot/launcher/bash/br ] && \. ~/.config/broot/launcher/bash/br || true

  if command -v fzf &> /dev/null; then
    eval "$(fzf --bash)"
    if declare -F _fzf_setup_completion >/dev/null; then
      _fzf_setup_completion dir z tree ltr zl
      _fzf_setup_completion path cp mv rm cat
      _fzf_setup_completion path l ls ll la lla l.
      _fzf_setup_completion path mic micro gimme
      _fzf_setup_completion path rcp rmv rup rsy
      _fzf_setup_completion host ping prettyping sftp ssht mosh mosht
    fi
    [ -s ~/.local/vendors/fzf-git.sh ] && \. ~/.local/vendors/fzf-git.sh || true
  fi

  if command -v pet &> /dev/null; then
    function ppet() {
      PREV=$(history | tail -n2 | head -n1 | sed 's/^[[:space:]]*[0-9]*[[:space:]]*//')
      pet new "$(printf %q "$PREV")"
    }

    function pet-select() {
      BUFFER=$(pet search --query "$READLINE_LINE")
      READLINE_LINE=$BUFFER
      READLINE_POINT=${#BUFFER}
    }
    bind -x '"\C-x\C-r": pet-select' 2>/dev/null

    function _pet_move_cursor_to_next_parameter() {
      match="$(echo "$READLINE_LINE" | perl -nle 'print $& if /<.*?>/')"
      if [ -n "$match" ]; then
        default="$(echo "$match" | perl -nle 'print $& if /(?<==).*(?=>)/')"
        match_len=${#match}
        default_len=${#default}

        pre_match=${READLINE_LINE%%$match*}
        parameter_offset=${#pre_match}

        READLINE_POINT="$((${parameter_offset} + ${default_len}))"
        READLINE_LINE="${READLINE_LINE:0:$parameter_offset}${default}${READLINE_LINE:$parameter_offset+$match_len}"
      fi
    }
    bind -x '"\C-n": _pet_move_cursor_to_next_parameter' 2>/dev/null

    if command -v fzf &> /dev/null; then
      export FZF_CTRL_R_OPTS="--reverse --cycle --info=right --color header:italic --header 'alt+s (pet new)' --preview 'echo {}' --preview-window down:3:hidden:wrap --bind '?:toggle-preview' --bind 'alt-s:execute(pet new --tag {2..})+abort'"
    fi
  fi

  if [[ $TERM_PROGRAM != "WarpTerminal" ]]; then
    [ -s ~/.iterm2_shell_integration.bash ] && \. ~/.iterm2_shell_integration.bash || true
  fi

  [ -s /etc/bash_completion ] && ! shopt -oq posix && \. /etc/bash_completion || true

  if declare -F __git_complete &>/dev/null && declare -p __git_alias_completions &>/dev/null 2>&1; then
    for __alias in "${!__git_alias_completions[@]}"; do
      alias "$__alias" &>/dev/null && __git_complete "$__alias" "_git_${__git_alias_completions[$__alias]}"
    done
    unset __alias
  fi

  if [ -z "$WINDSURF_CASCADE_TERMINAL" ]; then
    # [ "$SHLVL" == "1" ] && command -v fastfetch &> /dev/null && fastfetch || true
    if command -v fastfetch &> /dev/null; then
      SPN=$(ps -p $PPID | awk '{print substr($0, index($0, $4))}' | tail -1)
      if [ "$SHLVL" == "2" ] && [[ "$SPN" == *tmux* ]] || [ "$SHLVL" == "1" ]; then
        fastfetch
      fi
      unset SPN
    fi
  fi
fi

unset __INTERACTIVE

# dedupe path, ensure nvm is first
_dedup_path() {
  local result="" nvm_entry="" seen=":"
  local IFS=: p
  for p in $PATH; do
    [[ -z "$p" ]] && continue
    case "$seen" in *:"$p":*) continue ;; esac
    seen+="$p:"
    if [[ "$p" =~ \.nvm ]]; then
      nvm_entry="$p"
    else
      result+="${result:+:}$p"
    fi
  done
  [[ -n "$nvm_entry" ]] && result="$nvm_entry:$result"
  echo "$result"
}
export PATH="$(_dedup_path)"
unset -f _dedup_path
