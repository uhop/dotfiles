#!/usr/bin/env bash

set -euCo pipefail
shopt -s expand_aliases

. ~/.local/libs/bootstrap.sh

script_name=$(basename "$0")

args::program "$script_name" "1.0.0" "Uninstall old Node.js minors, keeping the newest of each major (via nvm)" "https://github.com/uhop/dotfiles/wiki/Utilities#trim-node-versions"

args_program_header="${BOLD}trim-node-versions${RESET_BOLD} keeps the newest minor of every installed Node major and
${BOLD}nvm uninstall${RESET_BOLD}s the rest. Bash on purpose: nvm runs in-process, so the current version can
be switched away (${BOLD}nvm use${RESET_BOLD} persists) before its old install is removed — the failure mode
the previous Node implementation hit on macOS."

args_program_usage="${BOLD}trim-node-versions${RESET_BOLD}       # keep newest minor per major, uninstall the rest
${BOLD}trim-node-versions${RESET_BOLD} -n    # show the nvm calls without running them"

args::option "-n, --dry-run" "Show the nvm calls without running them"
args::option "-v, --version" "Show version"
args::option "-h, --help" "Show help"
args::option "--bash-completion" "Show bash completion"

args::parse "$@"
set -- "${args_cleaned[@]}"

if [ "$#" -gt 0 ]; then
  ansi::err "${ERROR}Unexpected argument: $1${RESET_ALL}"
  args::try_help
  exit 1
fi

DRY_RUN=0
[[ -v args_options["-n"] ]] && DRY_RUN=1

export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
nvm_sh=""
command -v brew &>/dev/null && nvm_sh="$(brew --prefix nvm 2>/dev/null || true)/nvm.sh"
[ -s "$nvm_sh" ] || nvm_sh="$NVM_DIR/nvm.sh"
if [ ! -s "$nvm_sh" ]; then
  ansi::err "${ERROR}nvm.sh not found (brew prefix or \$NVM_DIR) — install nvm first.${RESET_ALL}"
  exit 1
fi
# nvm.sh is not set -e/-u clean
set +eu
. "$nvm_sh"
set -eu

run_nvm() {
  if [ "$DRY_RUN" -eq 1 ]; then
    ansi::out "${WARN}[dry-run] nvm $*${RESET_ALL}"
  else
    echoRun nvm "$@"
  fi
}

installed_versions() { # stdout: "X.Y.Z<TAB>current?" per installed version
  nvm ls --no-colors | while IFS= read -r line; do
    if [[ $line =~ ^[[:space:]]*(-\>)?[[:space:]]*v([0-9]+\.[0-9]+\.[0-9]+) ]]; then
      printf '%s\t%s\n' "${BASH_REMATCH[2]}" "${BASH_REMATCH[1]:+current}"
    fi
  done
}

mapfile -t entries < <(installed_versions | sort -t. -k1,1nr -k2,2nr -k3,3nr)

if [ "${#entries[@]}" -eq 0 ]; then
  ansi::out "No Node versions were found."
  exit 0
fi

prev_major=""
for entry in "${entries[@]}"; do
  ver="${entry%%$'\t'*}"
  flag="${entry#*$'\t'}"
  major="${ver%%.*}"
  if [ "$major" = "$prev_major" ]; then
    if [ "$flag" = "current" ]; then
      run_nvm use "$major"
    fi
    run_nvm uninstall "$ver"
  else
    ansi::out "MAJOR: v$ver"
    prev_major="$major"
  fi
done

ansi::out "${OK}Done.${RESET_ALL}"
