#!/usr/bin/env node
// playbash — run bash playbooks on remote hosts.
//
// Entry point: argument parsing, dispatcher, single-host and fan-out
// run pipelines, and the list/hosts/log subcommands. Rendering, inventory,
// and sidecar handling live in sibling modules:
//
//   playbash-render.js    — Rectangle, StatusBoard, COLOR, sanitizer
//   playbash-inventory.js — load/resolve/group/self
//   playbash-sidecar.js   — parse, per-host summary, cross-host aggregation
//   playbash-staging.js   — wrapper staging for vanilla hosts, BatchMode ssh

import {parseArgs} from 'node:util';
import {basename} from 'node:path';

import {
  probeConnectivity,
  runFanout,
  runLocally,
  runRemote,
  validateCustomPlaybookPath
} from '../share/playbash/runner.js';
import {
  cmdBashCompletion,
  cmdCompleteTargets,
  cmdHosts,
  cmdList,
  cmdLog
} from '../share/playbash/commands.js';
import {cmdGet, cmdPut} from '../share/playbash/transfer.js';
import {die} from '../share/playbash/errors.js';
import {COLOR} from '../share/playbash/render.js';
import {
  filterSelf,
  isSelfAddress,
  loadInventory,
  resolveTargets
} from '../share/playbash/inventory.js';
import {runDoctor} from '../share/playbash/doctor.js';

// Bump on every user-visible change. See dev-docs/playbash-design.md#versioning
// for the versioning policy and bump rules.
const VERSION = '3.0.1';

const USAGE = `usage:
  playbash run    <targets> <playbook> [-n LINES] [-p N] [--self]
  playbash push   <targets> <script-path> [-n LINES] [-p N] [--self]
  playbash debug  <targets> <playbook> [--self]
  playbash exec   <targets> [--] <command...> [options]
  playbash put    <targets> <local-path> [<remote-path>] [-p N] [-N]
  playbash get    <targets> <remote-path> [<local-path>] [-p N] [-N]
  playbash list
  playbash hosts
  playbash log    [host] [command]
  playbash doctor
  playbash -v, --version            # print version and exit
  playbash --bash-completion        # print bash completion script

Options (must come before \`--\` when using exec):
  -n, --lines N    height of the live output rectangle (default 5)
                   pass 0 to disable the rectangle and stream output raw
  -p, --parallel N max concurrent hosts in fan-out (default 0 = unlimited)
  --self           allow running on the local host (default: refuse)
  -N, --no-precheck  skip the ssh connectivity pre-flight check

<targets> is one positional that may be a single host name, a comma-
separated list, a group name, or the implicit "all" group — and any
combination ("db1,web,prod"). Names are looked up in
~/.config/playbash/inventory.json. Unknown names are passed verbatim to
ssh, so any ~/.ssh/config alias works. A single resolved target uses
the live rectangle; multiple targets switch to a status board with
parallel runs and a focused-host live view.

\`run\` treats hosts in the inventory as managed — playbooks are expected
at ~/.local/bin/playbash-<playbook> on the target. Hosts not in the
inventory (bare ssh aliases) are automatically pushed (see below).

\`push\` uploads a local script and its helper library to the target and
runs it — like \`put\` but with execution. Takes <targets> <script-path>
(targets first, mirroring \`put\` and \`exec\`). \`run\` with a file path
(containing /) automatically uses push mode. Only self-contained scripts
work — scripts that depend on chezmoi-managed tools will not.

  Directory playbooks: <script-path> may also be a directory. The directory
  must contain an executable \`main.sh\` entry point; the whole tree is tar'd
  and uploaded into ~/.cache/playbash-staging/<dirname>/. Helpers in the
  directory are reachable from main.sh via \$(dirname "\$0"); the playbash
  helper library is sourced via \$PLAYBASH_LIBS/playbash.sh as usual.

\`exec\` runs an arbitrary command through the same wrapper / rectangle /
fan-out pipeline as \`run\`, without a playbook. Use \`--\` before the
command when it contains flags that might conflict with playbash options
(e.g. \`playbash exec web1 -- ls -p\`). No sidecar events are collected.

\`debug\` is equivalent to \`run\` with the rectangle disabled and info
events surfaced in the summary — for when you want to see everything.

\`put\` uploads a local file or directory to targets. If no remote path is
given, it defaults to the local path. A trailing / on the remote path
means "put the file inside this directory". Directories are transferred
recursively via tar. Paths may contain {host} which expands per-target.

\`get\` downloads a remote file or directory. For multiple targets, the
local path must contain {host} to avoid overwrites. If no local path is
given, the remote file's basename is used (single target) or
{host}-<basename> (multiple targets). Directories are detected and
transferred recursively via tar.

Path resolution: local paths are relative to cwd, remote paths are
relative to the remote user's home directory (ssh default).

Self detection is by IP: if the target's resolved address is bound to a
local interface, the run is refused unless --self is passed. With --self,
the playbook runs locally as a child process (no ssh) using the same
sidecar/summary pipeline.

\`playbash log\` prints a per-run log file with terminal-hostile escape
sequences stripped — safe to view in any terminal. With no args, picks
the most recent log across all hosts. With a host name, picks the most
recent log for that host. With host + command, narrows further. A path
containing / is read directly (backward compat).

\`playbash doctor\` runs a diagnostic checklist over the operator
environment (~/.ssh/config, keys, agent, inventory, local playbooks,
helper library, PTY wrapper, python3) and per-host connectivity for
every inventory host. Output is a green/orange/red checklist with
remediation hints under failures. Exits 1 if any check fails.`;

// Runner machinery (signal handlers, child registry, runHost,
// runHostSingle, runRemote, runLocally, runFanout, probeConnectivity,
// stuck-on-input detector, buildRemoteCommand, buildExecCommand) lives in
// ../share/playbash/runner.js and is imported at the top of this file.

// --- main dispatcher ---

const {values, positionals} = parseArgs({
  options: {
    lines: {type: 'string', short: 'n'},
    self: {type: 'boolean', default: false},
    'no-precheck': {type: 'boolean', short: 'N', default: false},
    parallel: {type: 'string', short: 'p', default: '0'},
    'bash-completion': {type: 'boolean', default: false},
    version: {type: 'boolean', short: 'v', default: false},
    help: {type: 'boolean', short: 'h', default: false}
  },
  allowPositionals: true
});

// null when the user didn't pass -n; a validated number otherwise.
const linesFlag =
  values.lines != null
    ? (() => {
        const n = parseInt(values.lines, 10);
        if (!Number.isFinite(n) || n < 0)
          die(
            `--lines must be a non-negative integer (0 disables the rectangle)`
          );
        return n;
      })()
    : null;

if (values['bash-completion']) {
  cmdBashCompletion();
  process.exit(0);
}

if (values.version) {
  process.stdout.write(`playbash ${VERSION}\n`);
  process.exit(0);
}

if (values.help) {
  process.stdout.write(USAGE + '\n');
  process.exit(0);
}

if (positionals.length === 0) die(USAGE);
const [command, ...rest] = positionals;

// Pick the right execution backend for the user's target argument. The
// argument may be a single name or a comma-separated list mixing host
// names, group names, and the implicit `all` group.
//
// Decision tree:
//   - If the resolved-and-self-filtered list is empty, refuse.
//   - If length is 1: existing single-host pipeline.
//     - If that one host is self and --self was not passed: hard refusal
//       with the bare-script hint (existing behavior).
//   - If length > 1: fan-out path (StatusBoard, parallel runs, aggregated
//     summary). Self entries are silently dropped from the list unless
//     --self is passed; a one-line dim notice is printed before launch.
// Shared target validation: resolve, self-filter, empty-check, precheck,
// offline detection. Used by dispatch, put, and get. Returns validated
// {inventory, resolved, targets, offlineNames, parallelLimit} or dies.
async function resolveAndValidate(targetArg) {
  const inventory = loadInventory();
  const resolved = resolveTargets(targetArg, inventory);
  const {targets, skipped} = await filterSelf(resolved, values.self);

  if (targets.length === 0) {
    if (skipped.length > 0)
      die(`all targets resolved to self; pass --self to include`);
    die('target list resolved to nothing');
  }

  if (skipped.length > 0) {
    process.stderr.write(
      `${COLOR.dim}· skipping self (${skipped.join(', ')}); pass --self to include${COLOR.reset}\n`
    );
  }

  const offlineNames = new Set();
  if (!values['no-precheck']) {
    const {offline} = await probeConnectivity(targets);
    for (const t of offline) offlineNames.add(t.name);
    if (offlineNames.size > 0) {
      process.stderr.write(
        `${COLOR.dim}· offline: ${[...offlineNames].join(', ')}${COLOR.reset}\n`
      );
    }
    if (offlineNames.size === targets.length)
      die('all targets are unreachable');
  }

  const parallelLimit = parseInt(values.parallel, 10);
  if (!Number.isFinite(parallelLimit) || parallelLimit < 0) {
    die(`--parallel must be a non-negative integer (0 = unlimited)`);
  }

  return {inventory, resolved, targets, offlineNames, parallelLimit};
}

// Shared dispatcher for `run`, `push`, `debug`, and `exec`.
async function dispatch({job, targetArg, rectHeight, verbose, push}) {
  const {
    inventory: inv,
    resolved,
    targets,
    offlineNames,
    parallelLimit
  } = await resolveAndValidate(targetArg);

  if (resolved.length === 1) {
    const only = resolved[0];
    const isSelf = await isSelfAddress(only.address);
    if (isSelf && !values.self) {
      const hint = job.playbook
        ? `pass --self to run locally, or invoke the bare script directly: playbash-${job.playbook}`
        : `pass --self to run locally`;
      die(
        `"${only.name}" (${only.address}) resolves to a local interface; refusing to run on self.\n${hint}`
      );
    }
    if (isSelf) {
      await runLocally({...job, hostName: only.name, rectHeight, verbose});
    } else {
      const managed = !push && inv.hosts.has(only.name);
      if (!push && job.playbook && !managed) {
        process.stderr.write(
          `${COLOR.dim}· ${only.name} not in inventory — pushing playbook${COLOR.reset}\n`
        );
      }
      await runRemote({
        ...job,
        hostName: only.name,
        address: only.address,
        rectHeight,
        verbose,
        managed
      });
    }
    return;
  }

  if (!push && job.playbook) {
    const nonInv = targets.filter(
      t => !inv.hosts.has(t.name) && !offlineNames.has(t.name)
    );
    if (nonInv.length > 0) {
      process.stderr.write(
        `${COLOR.dim}· pushing playbook to ${nonInv.map(t => t.name).join(', ')} (not in inventory)${COLOR.reset}\n`
      );
    }
  }

  await runFanout({
    ...job,
    targets,
    rectHeight,
    verbose,
    parallelLimit,
    inventory: inv,
    push,
    offlineNames
  });
}

switch (command) {
  case 'list': {
    if (rest.length > 0) die(`list takes no arguments`);
    cmdList();
    break;
  }
  case 'hosts': {
    if (rest.length > 0) die(`hosts takes no arguments`);
    await cmdHosts();
    break;
  }
  case 'doctor': {
    if (rest.length > 0) die(`doctor takes no arguments`);
    await runDoctor();
    break;
  }
  case 'log': {
    if (rest.length > 2)
      die(`log takes at most two arguments: [host] [command]`);
    cmdLog(rest[0], rest[1]);
    break;
  }
  case '__complete-targets': {
    // Hidden helper for the bash completion script. Not in USAGE.
    cmdCompleteTargets();
    break;
  }
  case 'run':
  case 'debug': {
    if (rest.length !== 2)
      die(`${command} takes <targets> <playbook>\n${USAGE}`);
    const [targetArg, playbookArg] = rest;
    const isCustomPath = playbookArg.includes('/');
    if (isCustomPath) {
      // Templated paths (containing {host}) defer validation to per-host
      // expansion in runRemote/runFanout. Non-templated paths are validated
      // up front so the user gets an error before any ssh work starts.
      if (!playbookArg.includes('{host}')) {
        let kind;
        try {
          kind = validateCustomPlaybookPath(playbookArg);
        } catch (err) {
          die(err.message);
        }
        process.stderr.write(
          kind === 'dir'
            ? `${COLOR.dim}· ${playbookArg} is a directory playbook — using push mode${COLOR.reset}\n`
            : `${COLOR.dim}· ${playbookArg} is a file path — using push mode${COLOR.reset}\n`
        );
      } else {
        process.stderr.write(
          `${COLOR.dim}· ${playbookArg} is a templated path — using push mode${COLOR.reset}\n`
        );
      }
    } else {
      if (!/^[a-zA-Z0-9._-]+$/.test(playbookArg))
        die(`invalid playbook name "${playbookArg}"`);
    }
    const playbook = isCustomPath
      ? basename(playbookArg.replace(/\/+$/, ''))
      : playbookArg;
    const customPath = isCustomPath ? playbookArg : null;
    const rectHeight = command === 'debug' ? 0 : (linesFlag ?? 5);
    const verbose = command === 'debug';
    await dispatch({
      job: {playbook, customPath},
      targetArg,
      rectHeight,
      verbose,
      push: isCustomPath
    });
    break;
  }
  case 'push': {
    if (rest.length !== 2) die(`push takes <targets> <script-path>\n${USAGE}`);
    const [targetArg, scriptPath] = rest;
    if (!scriptPath.includes('{host}')) {
      try {
        validateCustomPlaybookPath(scriptPath);
      } catch (err) {
        die(err.message);
      }
    }
    const playbook = basename(scriptPath.replace(/\/+$/, ''));
    const rectHeight = linesFlag ?? 5;
    await dispatch({
      job: {playbook, customPath: scriptPath},
      targetArg,
      rectHeight,
      verbose: false,
      push: true
    });
    break;
  }
  case 'exec': {
    if (rest.length < 2) die(`exec takes <targets> <command...>\n${USAGE}`);
    const [targetArg, ...cmdParts] = rest;
    const command = cmdParts.join(' ');
    if (!command) die(`exec requires a command after the target\n${USAGE}`);
    const rectHeight = linesFlag ?? 0;
    await dispatch({
      job: {command},
      targetArg,
      rectHeight,
      verbose: false,
      push: false
    });
    break;
  }
  case 'put': {
    if (rest.length < 2 || rest.length > 3)
      die(`put takes <targets> <local-path> [<remote-path>]\n${USAGE}`);
    const validated = await resolveAndValidate(rest[0]);
    await cmdPut(validated, rest[1], rest[2]);
    break;
  }
  case 'get': {
    if (rest.length < 2 || rest.length > 3)
      die(`get takes <targets> <remote-path> [<local-path>]\n${USAGE}`);
    const validated = await resolveAndValidate(rest[0]);
    await cmdGet(validated, rest[1], rest[2]);
    break;
  }
  default:
    die(`unknown command "${command}"\n${USAGE}`);
}
