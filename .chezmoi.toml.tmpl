{{/* Source the detection library once and parse its JSON report. Exposes
     capabilities under `.detect.*` so downstream templates can branch on
     sniffed state (pkgmgr, isImmutable, isContainer, isWsl, hasIpv6, ...)
     instead of re-parsing /etc/os-release piecemeal. See
     dev-docs/bootstrap-detection-design.md. */ -}}
{{- $detectScript := includeTemplate "detect-distro.sh" . -}}
{{- $detectJSON := output "bash" "-c" (printf "%s\ndetect::report_json" $detectScript) -}}
{{- $detect := fromJson $detectJSON -}}

{{- $osFamily := .chezmoi.os -}}
{{- $codespaces := env "CODESPACES" | not | not -}}
{{- $hasGui := promptBoolOnce . "hasGui" "Does this machine have GUI" false -}}
{{- $name := promptStringOnce . "name" "Full name" "Eugene Lazutkin" -}}
{{- $email := promptStringOnce . "email" "Email address" "eugene.lazutkin@gmail.com" -}}
{{- $githubUsernameDefault := "uhop" -}}
{{- if env "GITHUB_USERNAME" -}}
{{-   $githubUsernameDefault = env "GITHUB_USERNAME" -}}
{{- end -}}
{{- $githubUsername := promptStringOnce . "githubUsername" "GitHub username" $githubUsernameDefault -}}

[data]
osFamily = {{ $osFamily | quote }}
codespaces = {{ $codespaces }}
hasGui = {{ $hasGui }}
name = {{ $name | quote }}
email = {{ $email | quote }}
githubUsername = {{ $githubUsername | quote }}

[data.detect]
pkgmgr = {{ $detect.pkgmgr | quote }}
family = {{ $detect.family | quote }}
familyConsistency = {{ $detect.familyConsistency | quote }}
id = {{ $detect.id | quote }}
idLike = {{ $detect.idLike | quote }}
versionId = {{ $detect.versionId | quote }}
name = {{ $detect.name | quote }}
arch = {{ $detect.arch | quote }}
uname = {{ $detect.uname | quote }}
initSystem = {{ $detect.initSystem | quote }}
isImmutable = {{ $detect.isImmutable }}
isContainer = {{ $detect.isContainer }}
isWsl = {{ $detect.isWsl }}
hasIpv6 = {{ $detect.hasIpv6 }}
sudoGroup = {{ $detect.sudoGroup | quote }}
canSudoNopasswd = {{ $detect.canSudoNopasswd }}
hasBrew = {{ $detect.hasBrew }}
hasFlatpak = {{ $detect.hasFlatpak }}
hasSnap = {{ $detect.hasSnap }}
hasNix = {{ $detect.hasNix }}

[diff]
pager = "diff-so-fancy"

[[textconv]]
pattern = "**/*.plist"
command = "plutil"
args = ["-convert", "xml1", "-o", "-", "-"]

[scriptEnv]
GITHUB_USERNAME = {{ $githubUsername | quote }}
