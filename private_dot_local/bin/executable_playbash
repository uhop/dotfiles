#!/usr/bin/env node
// playbash — run bash playbooks on remote hosts.
//
// Milestone 3: live output rectangle. The runner spawns ssh with -tt to
// force a remote PTY, reads the merged byte stream back through a normal
// pipe, and renders the last N raw lines as a fixed-height rectangle in
// the local terminal. Full uncut output still goes to the per-run log.

import {spawn} from 'node:child_process';
import {randomBytes} from 'node:crypto';
import {mkdirSync, createWriteStream} from 'node:fs';
import {homedir} from 'node:os';
import {join} from 'node:path';
import {parseArgs} from 'node:util';

const USAGE = `usage: playbash run <playbook> <host> [-n LINES]

<playbook> resolves to ~/.local/bin/playbash-<playbook> on the target host
(deployed there by chezmoi). <host> is passed verbatim to ssh, so any
~/.ssh/config alias works.

Options:
  -n, --lines N    height of the live output rectangle (default 5)
                   pass 0 to disable the rectangle and stream output raw`;

function die(msg, code = 2) {
  process.stderr.write(`playbash: ${msg}\n`);
  process.exit(code);
}

const {values, positionals} = parseArgs({
  options: {
    lines: {type: 'string', short: 'n', default: '5'},
  },
  allowPositionals: true,
});

if (positionals.length === 0) die(USAGE);
const [command, ...rest] = positionals;
if (command !== 'run') die(`unknown command "${command}"\n${USAGE}`);
if (rest.length !== 2) die(`run takes <playbook> <host>\n${USAGE}`);

const [playbook, host] = rest;
if (!/^[a-zA-Z0-9._-]+$/.test(playbook)) die(`invalid playbook name "${playbook}"`);

const rectHeight = parseInt(values.lines, 10);
if (!Number.isFinite(rectHeight) || rectHeight < 0) die(`--lines must be a non-negative integer (0 disables the rectangle)`);

// Sidecar path: random hex avoids the extra mktemp round trip.
const reportPath = `/tmp/playbash-report-${randomBytes(8).toString('hex')}.jsonl`;

// Forward our terminal size so the remote PTY is the right width — `apt`,
// progress bars, and `tput cols` will read it. Defaults are safe fallbacks
// when stdout is not a tty.
const cols = process.stdout.columns || 80;
const rows = process.stdout.rows || 24;

const remoteCommand =
  `PLAYBASH_REPORT=${reportPath} ` +
  `PLAYBASH_HOST=${host} ` +
  `COLUMNS=${cols} LINES=${rows} ` +
  `~/.local/bin/playbash-${playbook}`;

// Per-run log file (full uncut stream, ANSI and CRs intact).
const logDir = join(homedir(), '.cache', 'playbash', 'runs');
mkdirSync(logDir, {recursive: true});
const stamp = new Date().toISOString().replace(/[:.]/g, '-');
const logPath = join(logDir, `${stamp}-${host}-${playbook}.log`);
const log = createWriteStream(logPath);

// --- Live rectangle renderer ---

const ANSI_RE = /\x1b\[[0-9;?]*[a-zA-Z]/g;

function visibleLength(s) {
  return s.replace(ANSI_RE, '').length;
}

// Truncate to `width` visible columns, copying ANSI codes through verbatim
// (they take zero columns). Always closes with a reset to avoid bleeding
// colors past the rectangle edge.
function truncateToWidth(s, width) {
  if (visibleLength(s) <= width) return s;
  let out = '';
  let visible = 0;
  let i = 0;
  while (i < s.length && visible < width) {
    if (s[i] === '\x1b' && s[i + 1] === '[') {
      let j = i + 2;
      while (j < s.length && !/[a-zA-Z]/.test(s[j])) j++;
      out += s.slice(i, j + 1);
      i = j + 1;
    } else {
      out += s[i];
      visible++;
      i++;
    }
  }
  return out + '\x1b[0m';
}

class Rectangle {
  constructor(height) {
    this.height = height;
    this.committed = []; // last (height - 1) completed lines
    this.current = '';   // line being built
    // Rectangle is only active when we have a real tty AND a positive
    // height. height === 0 is the explicit "raw passthrough" opt-out.
    this.active = process.stdout.isTTY && height > 0;
  }

  start() {
    if (!this.active) return;
    // Reserve `height` rows by scrolling them in. Cursor ends up on the
    // line immediately below the rectangle, which is our anchor for every
    // subsequent redraw.
    process.stdout.write('\n'.repeat(this.height));
  }

  feed(chunk) {
    const text = chunk.toString('utf8');
    for (let i = 0; i < text.length; i++) {
      const ch = text[i];
      if (ch === '\n') {
        this.commit();
      } else if (ch === '\r') {
        // Progress-bar style overwrite: drop the in-progress line.
        this.current = '';
      } else {
        this.current += ch;
      }
    }
    this.redraw();
  }

  commit() {
    this.committed.push(this.current);
    if (this.committed.length > this.height - 1) this.committed.shift();
    this.current = '';
  }

  redraw() {
    if (!this.active) return;
    const width = process.stdout.columns || 80;
    let out = `\x1b[${this.height}A`; // up to top of rectangle
    for (let i = 0; i < this.height - 1; i++) {
      const line = this.committed[i] || '';
      out += '\r\x1b[2K' + truncateToWidth(line, width) + '\n';
    }
    // In-progress line at the bottom row.
    out += '\r\x1b[2K' + truncateToWidth(this.current, width) + '\n';
    process.stdout.write(out);
  }

  finish() {
    if (!this.active) return;
    // Erase the rectangle and park the cursor at its former top-left, so
    // the summary lines print exactly where the rectangle was.
    let out = `\x1b[${this.height}A`;
    for (let i = 0; i < this.height; i++) out += '\r\x1b[2K\n';
    out += `\x1b[${this.height}A`;
    process.stdout.write(out);
  }
}

const rect = new Rectangle(rectHeight);

// One-shot ssh, used to fetch the sidecar. Plain pipes, no PTY.
function sshCapture(remote) {
  return new Promise((resolve, reject) => {
    const proc = spawn('ssh', [host, '--', remote], {stdio: ['ignore', 'pipe', 'pipe']});
    let stdout = '', stderr = '';
    proc.stdout.on('data', c => (stdout += c));
    proc.stderr.on('data', c => (stderr += c));
    proc.on('error', reject);
    proc.on('close', code => resolve({code, stdout, stderr}));
  });
}

// Run the playbook with -tt to force a remote PTY. The double t suppresses
// the "Pseudo-terminal will not be allocated" warning when our stdin isn't
// a tty. Output is merged on stdout (single PTY stream).
function runPlaybook() {
  return new Promise((resolve, reject) => {
    const child = spawn('ssh', ['-tt', host, '--', remoteCommand], {
      stdio: ['ignore', 'pipe', 'pipe'],
    });
    child.stdout.on('data', chunk => {
      log.write(chunk);
      if (rect.active) {
        rect.feed(chunk);
      } else {
        process.stdout.write(chunk);
      }
    });
    // ssh's own stderr (e.g. "Connection closed") — log it, don't disturb
    // the rectangle. It will appear in the summary's log file.
    child.stderr.on('data', chunk => log.write(chunk));
    child.on('error', reject);
    child.on('close', (code, signal) => resolve({code, signal}));
  });
}

function parseSidecar(text) {
  const events = [];
  for (const line of text.split('\n')) {
    if (!line.trim()) continue;
    try {
      events.push(JSON.parse(line));
    } catch {
      process.stderr.write(`playbash: ignoring malformed sidecar line: ${line}\n`);
    }
  }
  return events;
}

function renderSummary(events) {
  if (events.length === 0) return;
  const byLevel = {info: [], warn: [], error: [], action: []};
  for (const ev of events) if (byLevel[ev.level]) byLevel[ev.level].push(ev);

  if (byLevel.action.length) {
    process.stderr.write('  actions:\n');
    for (const ev of byLevel.action) {
      const kind = ev.kind || 'unknown';
      const target = ev.target ? ` [${ev.target}]` : '';
      process.stderr.write(`    ${kind}${target} — ${ev.msg}\n`);
    }
  }
  if (byLevel.warn.length) {
    process.stderr.write('  warnings:\n');
    for (const ev of byLevel.warn) {
      const target = ev.target ? `${ev.target}: ` : '';
      process.stderr.write(`    ${target}${ev.msg}\n`);
    }
  }
  if (byLevel.error.length) {
    process.stderr.write('  errors:\n');
    for (const ev of byLevel.error) process.stderr.write(`    ${ev.msg}\n`);
  }
}

(async () => {
  const start = Date.now();
  rect.start();

  let result;
  try {
    result = await runPlaybook();
  } catch (err) {
    rect.finish();
    die(`failed to spawn ssh: ${err.message}`, 1);
  }

  rect.finish();
  await new Promise(resolve => log.end(resolve));

  let events = [];
  try {
    const fetch = await sshCapture(`cat ${reportPath} 2>/dev/null; rm -f ${reportPath}`);
    events = parseSidecar(fetch.stdout);
  } catch (err) {
    process.stderr.write(`playbash: failed to fetch sidecar: ${err.message}\n`);
  }

  const elapsed = ((Date.now() - start) / 1000).toFixed(1);
  const status = result.signal
    ? `signal ${result.signal}`
    : result.code === 0
      ? 'ok'
      : `exit ${result.code}`;
  process.stderr.write(`playbash: ${host} ${playbook} — ${status} (${elapsed}s)\n`);
  renderSummary(events);
  process.stderr.write(`playbash: log ${logPath}\n`);

  process.exit(result.code ?? 1);
})();
