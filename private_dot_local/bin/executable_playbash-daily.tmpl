#!/usr/bin/env bash
# playbash-daily — daily maintenance stack.
#
# Mirrors the existing ansible stack-daily.yml: chezmoi update, then
# dcms, then upd -y. Sources playbash.sh so the runner gets structured
# events, but stays directly runnable by hand (helpers fall back to
# pretty-print when $PLAYBASH_REPORT is unset).

set -euCo pipefail
shopt -s expand_aliases

source ~/.local/libs/playbash.sh

playbash_step "chezmoi"
playbash_info "running chezmoi update"
chezmoi update

playbash_step "docker"
playbash_info "refreshing docker images via dcms"
dcms

playbash_step "system"
playbash_info "running upd -y"
upd -y

# upd is now authoritative for reboot/restart/apparmor reporting via
# maintenance.sh — it writes the same events to $PLAYBASH_REPORT that
# we used to write here. No post-hoc check needed.
