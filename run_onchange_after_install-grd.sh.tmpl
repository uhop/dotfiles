{{- /* Configure the GRD system daemon on GNOME hosts flagged as RDP servers.
       Runs only when .detect.desktop == "gnome" AND .remoteDesktop is "server"
       or "both". Idempotent; chezmoi re-runs only when this rendered content
       changes (tied to .detect.desktop / .remoteDesktop values).

       We use the SYSTEM daemon (`grdctl --system`) rather than the user daemon
       because:
       - The user daemon stores credentials in the GNOME keyring (libsecret).
         Over SSH without a live GUI login, the default collection is locked
         and can't be unlocked without the user's Unix password — no clean
         automation path.
       - The system daemon stores credentials in /etc/gnome-remote-desktop/,
         root-owned, mode 0600, encrypted with a TPM-backed key when a TPM is
         present or GKeyFile otherwise. No keyring dance.
       - "server" role semantically means "accept RDP connections, including
         when nobody's logged in on the console." That's the system daemon's
         job. The user daemon is for attaching to a live desktop.

       What this script AUTOMATES:
       - TLS cert + key generation (self-signed, 10-year) at
         /etc/gnome-remote-desktop/rdp-tls.{crt,key}.
       - `grdctl --system rdp enable / disable-view-only / set-port 3389
         / set-tls-cert / set-tls-key`.
       - `systemctl enable --now gnome-remote-desktop.service`.
       - Disabling the user-mode daemon so it doesn't fight for port 3389.

       What it does NOT automate:
       - `grdctl --system rdp set-credentials <user> <password>` — we won't
         bake a password into chezmoi source. The script prints the exact
         command at the end; user runs once.

       Sudo: uses `sudo -n` and bails gracefully if passwordless sudo isn't
       available, printing the sudo'd commands for the user to run manually.
       The fleet's /etc/sudoers.d/chezmoi provides NOPASSWD for apt/dnf and a
       few system tools; grdctl isn't in the allowlist yet, so this will
       typically fall through to the manual path on first apply and become a
       no-op thereafter once state is correct. */ -}}
{{- if and (eq .detect.desktop "gnome") (or (eq .remoteDesktop "server") (eq .remoteDesktop "both")) -}}
#!/usr/bin/env bash
{{ template "install-prelude.sh" . }}

step() { echo -e "\n${BOLD}${PROMPT}==> $1${RESET}"; }

# Echo each command before running it — nothing in the script goes through
# sudo invisibly. Mirrors bootstrap.sh's echoRun but stays local (this script
# doesn't source bootstrap.sh).
run() { echo -e "${PROMPT}\$ $*${RESET}"; "$@"; }

# Render a /tmp/finish-grd-setup.sh helper that prompts for the GRD username
# and password at runtime. Used by both fallback paths (no-sudo, creds-unset)
# so the operator never copy-pastes a command line containing literal
# <grd-user> / <grd-password> placeholders. Safe to re-run; idempotent.
generate_finish_script() {
  cat >| /tmp/finish-grd-setup.sh <<'FINISH_EOF'
#!/usr/bin/env bash
#
# Finish GRD server-role setup on this host. Generated by chezmoi.
#
# Idempotent — safe to re-run. Pick one invocation:
#
#   Interactive (preferred — you will be prompted for username + password):
#     bash /tmp/finish-grd-setup.sh
#
#   Non-interactive (for automation; avoid shell history — use `read` or a
#   secret store, not plain env assignment):
#     GRD_USER=... GRD_PASSWORD=... bash /tmp/finish-grd-setup.sh
#
# The GRD username is GRD-specific; it does NOT have to match any Unix
# account. Pick a strong password — it protects RDP access to this host.
# Credentials are stored under /etc/gnome-remote-desktop/, root-owned 0600,
# TPM-encrypted when available else GKeyFile.

set -euo pipefail

if [ "$(id -u)" -eq 0 ]; then
  echo "Run as your regular user; the script sudos as needed." >&2
  exit 1
fi

: "${GRD_USER:=}"
: "${GRD_PASSWORD:=}"

if [ -z "$GRD_USER" ]; then
  if [ -t 0 ]; then
    read -rp "GRD username: " GRD_USER
  else
    echo "error: GRD_USER not set and no TTY — see usage comment at top of this script." >&2
    exit 1
  fi
fi
if [ -z "$GRD_PASSWORD" ]; then
  if [ -t 0 ]; then
    read -rsp "GRD password: " GRD_PASSWORD
    echo
  else
    echo "error: GRD_PASSWORD not set and no TTY — see usage comment at top of this script." >&2
    exit 1
  fi
fi

crt=/etc/gnome-remote-desktop/rdp-tls.crt
key=/etc/gnome-remote-desktop/rdp-tls.key

if [ ! -f "$crt" ] || [ ! -f "$key" ]; then
  echo "==> Generating TLS cert + key at /etc/gnome-remote-desktop/"
  sudo mkdir -p /etc/gnome-remote-desktop
  sudo openssl req -newkey rsa:4096 -nodes -x509 -days 3650 \
    -keyout "$key" \
    -out    "$crt" \
    -subj   "/CN=$(hostname)"
  sudo chown gnome-remote-desktop:gnome-remote-desktop "$crt" "$key"
  sudo chmod 640 "$key"
  sudo chmod 644 "$crt"
fi

echo "==> Yielding port 3389 from any user-mode daemon"
systemctl --user disable --now gnome-remote-desktop.service 2>/dev/null || true
grdctl rdp disable 2>/dev/null || true

echo "==> Configuring system daemon"
sudo grdctl --system rdp enable
sudo grdctl --system rdp disable-view-only
sudo grdctl --system rdp set-port 3389
sudo grdctl --system rdp set-tls-cert "$crt"
sudo grdctl --system rdp set-tls-key  "$key"
sudo grdctl --system rdp set-credentials "$GRD_USER" "$GRD_PASSWORD"
sudo systemctl enable --now gnome-remote-desktop.service
sudo systemctl restart gnome-remote-desktop.service

echo
echo "GRD server-role setup complete on $(hostname)."
echo "Test from a client (replace the hostname if needed):"
echo "  xfreerdp3 /u:$GRD_USER /v:$(hostname) +clipboard +dynamic-resolution /cert:tofu"
echo
echo "See: https://github.com/uhop/dotfiles/wiki/Remote-GUI"
FINISH_EOF
  chmod +x /tmp/finish-grd-setup.sh
}

step "Configuring gnome-remote-desktop system daemon (role: {{ .remoteDesktop }})"

if ! command -v grdctl >/dev/null 2>&1; then
  echo "${WARN}grdctl not installed; install gnome-remote-desktop and re-run chezmoi apply.${RESET}"
  exit 0
fi

# Detect whether we can escalate non-interactively. If not, generate a helper
# script the user runs interactively — avoids printing a copy-pasteable block
# with literal <grd-user> / <grd-password> placeholders.
if ! sudo -n true 2>/dev/null; then
  generate_finish_script
  cat <<MSG
${WARN}Passwordless sudo not available on this host; skipping system-daemon setup.${RESET}

A setup helper has been written to /tmp/finish-grd-setup.sh. Run it once to
finish server-role configuration — it generates the TLS cert, configures the
system daemon, and prompts interactively for the GRD username + password:

  ${BOLD}bash /tmp/finish-grd-setup.sh${RESET}

See: https://github.com/uhop/dotfiles/wiki/Remote-GUI
MSG
  exit 0
fi

# Generate the TLS cert+key if missing. Self-signed, 10-year, host-local;
# xfreerdp3 clients connect with /cert:tofu and pin on first connect.
grd_tls_dir=/etc/gnome-remote-desktop
grd_tls_crt="$grd_tls_dir/rdp-tls.crt"
grd_tls_key="$grd_tls_dir/rdp-tls.key"
if [ ! -f "$grd_tls_crt" ] || [ ! -f "$grd_tls_key" ]; then
  echo "${PROMPT}Generating GRD TLS cert + key at $grd_tls_dir...${RESET}"
  run sudo -n mkdir -p "$grd_tls_dir"
  run sudo -n openssl req -newkey rsa:4096 -nodes -x509 -days 3650 \
    -keyout "$grd_tls_key" \
    -out    "$grd_tls_crt" \
    -subj   "/CN=$(hostname)" 2>/dev/null
  run sudo -n chown gnome-remote-desktop:gnome-remote-desktop "$grd_tls_crt" "$grd_tls_key"
  run sudo -n chmod 640 "$grd_tls_key"
  run sudo -n chmod 644 "$grd_tls_crt"
fi

# Yield port 3389 from any stray user-mode daemon so the system daemon can bind.
run systemctl --user disable --now gnome-remote-desktop.service 2>/dev/null || true
run grdctl rdp disable 2>/dev/null || true

# Configure the system daemon. All grdctl --system calls are idempotent.
run sudo -n grdctl --system rdp enable
run sudo -n grdctl --system rdp disable-view-only
run sudo -n grdctl --system rdp set-port 3389
run sudo -n grdctl --system rdp set-tls-cert "$grd_tls_crt"
run sudo -n grdctl --system rdp set-tls-key  "$grd_tls_key"

run sudo -n systemctl enable --now gnome-remote-desktop.service

echo
run sudo -n grdctl --system status
echo

# Credentials are the one thing we can't automate — we won't bake a password
# into chezmoi source. The system daemon stores them via GKeyFile (or TPM),
# so there's no keyring-unlock gotcha here; just interactive `set-credentials`.
if ! sudo -n grdctl --system status --show-credentials 2>/dev/null | grep -qE '^\s+Username: [^(]'; then
  generate_finish_script
  cat <<MSG
${BOLD}${PROMPT}GRD credentials not yet set.${RESET} A helper has been written
to /tmp/finish-grd-setup.sh. Run it once; it prompts interactively for the
GRD username + password and sets them via grdctl (no copy-pasteable command
with placeholder strings):

  ${BOLD}bash /tmp/finish-grd-setup.sh${RESET}

The GRD username is GRD-specific — it doesn't have to match any Unix account.
Credentials are stored under /etc/gnome-remote-desktop/, root-owned 0600,
encrypted with TPM if available else GKeyFile. Unattended chezmoi apply
skips the credential step (no TTY); hence this helper.

See: https://github.com/uhop/dotfiles/wiki/Remote-GUI
MSG
fi
{{ end -}}
